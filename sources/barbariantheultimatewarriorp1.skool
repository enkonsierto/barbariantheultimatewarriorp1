; Hit indicator frame table.
;
; .
;
; .
;
; 3-byte entries: frame ID, X adjustment, row offset (scanlines/8 *32).
; .
; Searched by #R38325: if attacker frame IY+8 matches ID, draws ASCII 61 (hit
; indicator glyph, UDG index 13). via #R35996 near attacker column.
; .
; Terminator 128 skips indicator. Called before score table #R46775 by #R35531.
@label=hit_indicator_frame_table
b46747 DEFB 5,5,7    ; Frame 5: X adjust +5, row offset 7
 46750 DEFB 7,6,7    ; Frame 7: X adjust +6, row offset 7
 46753 DEFB 12,6,9   ; Frame 12: X adjust +6, row offset 9
 46756 DEFB 23,6,7   ; Frame 23: X adjust +6, row offset 7
 46759 DEFB 26,7,5   ; Frame 26: X adjust +7, row offset 5
 46762 DEFB 28,5,7   ; Frame 28: X adjust +5, row offset 7
 46765 DEFB 32,7,4   ; Frame 32: X adjust +7, row offset 4
 46768 DEFB 34,5,4   ; Frame 34: X adjust +5, row offset 4
 46771 DEFB 67,7,5   ; Frame 67: X adjust +7, row offset 5
 46774 DEFB 128      ; Terminator skips drawing.

; Score award frame table.
;
; 3-byte entries: (attacker_frame_id, score_low, score_high).
; .
; If IY+8 matches attacker_frame_id, adds DE score delta to #R47429 (P1) or
; R47431 (P2), depending on IYl: 89=P1 barbarian, 98=P2 barbarian.
; .
; Searched by #R35531 via #R38325. Terminated by sentinel 0x80.
;
; .
;
; Called after the hit indicator phase in #R35531. Same search pattern as
; #R46747.
@label=score_award_frame_table
b46775 DEFB 5,50,0   ; Frame 5 (#R43807), 50 points
 46778 DEFB 7,50,0   ; Frame 7 (#R43807), 50 points
 46781 DEFB 12,50,0  ; Frame 12 (#R43857), 50 points
 46784 DEFB 23,200,0 ; Frame 23 (#R43928), 200 points
 46787 DEFB 26,244,1 ; Frame 26 (#R43949), 500 points
 46790 DEFB 28,100,0 ; Frame 28 (#R43964), 100 points
 46793 DEFB 32,100,0 ; Frame 32 (#R43992), 100 points
 46796 DEFB 34,200,0 ; Frame 34 (#R44004), 200 points
 46799 DEFB 67,200,0 ; Frame 67 (#R43949), 200 points
 46802 DEFB 128      ; Terminator.

; Pending combat sound index.
;
; Stores the index of the combat sound triggered this frame.
;
; .
;
; Values: 1=#R39932, 2=#R39926, 3=#R39938, 4=#R39944, 5=#R39950, 6=#R39956.
; .
; Written by #R39518 (bits 4-7 of hit byte 2, shifted right 4 via RRCA x4).
; .
; Read and cleared by #R35531 (hit processor and sound dispatcher).
; .
; When 0, #R35531 returns immediately without any processing. Index 5-6 skip
; the visual indicator and score logic, going directly to the sound dispatch
; table.
@label=pending_sound_index
g46803 DEFB 0        ; Combat sound index. 0=none, 1=Kick, 2=Tackle, 3=Slash,
                     ; 4=Head Cut, 5-6=Guard.

; Attacker state block pointer.
;
; 2-byte pointer to the attacker's character state block.
;
; .
;
; Written by #R39518 with IX (attacker block: #R46425=P1, #R46434=P2).
; .
; Read by #R35531, which loads IY from this address to identify which character
; delivered the hit, used for score attribution (IYl 89 vs 98). Together with
; #R46803, forms the combat event descriptor set by #R39518.
@label=attacker_block_ptr
g46804 DEFW 0        ; Pointer to attacker state block. #R46425=P1 attacker,
                     ; #R46434=P2 attacker.

; Hit indicator screen address.
;
; 2-byte VRAM address where the hit indicator glyph will be drawn.
;
; .
;
; Computed by #R35531 from the attacker X tile position (IY+3), row offset, and
; mirror flag (IY+2 bit 0), then stored here before calling #R35996.
; .
; Written and consumed within the same call to #R35531.
; .
; Skipped if the computed column falls on boundary tiles (0, 1, 30, 31).
@label=hit_indicator_screen_addr
g46806 DEFB 0,0      ; Calculated VRAM address for hit indicator glyph. Written
                     ; by #R35531.

; Timer Flag.
;
; In this address the time is stored (in 2 players mode). If the value is 255
; we are in 1 Player or Demo mode (and we got infinite time).
@label=timer_flag
g46808 DEFB 255      ; Timer flag.

; Flying head state block.
;
; Initialised by #R37944 on decapitation (#R46809 + #R46810 + #R46811 + #R46813
; + #R46815).
;
; .
;
; 8-byte block operated via IX by #R37997 each frame.
; .
; Re-initialised by #R37964 via #R37950 (new tile source + trajectory,
; direction reset to 0, state=1).
; .
; A parallel block at #R46817 reuses this same layout for the P2 overlay
; renderer, allowing #R38103 and #R38158 to serve both without modification.
; .
; #TABLE(data)
; { Offset | Address | Field }
; { IX+0 | #R46809 | Direction: 0=right, 1=left }
; { IX+1 | #R46810 | State: 0=inactive, 1=bouncing, 255=landed }
; { IX+2,3 | #R46811 | Tile animation sequence pointer (#R46835 P1/#R46853 P2)
; }
; { IX+4,5 | #R46813 | Movement control pointer (#R47017 normal/#R47085 after
; goblin kick) }
; { IX+6,7 | #R46815 | Current framebuffer address }
; TABLE#
@label=head_state
g46809 DEFB 0        ; IX+0: Direction flag. 0=right, 1=left. Set by #R37944,
                     ; reset to 0 by #R37964.
@label=head_state_flag
 46810 DEFB 0        ; IX+1: State. 0=inactive (#R38186), 1=bouncing (#R37944 /
                     ; #R37950), 255=landed (#R38180).
@label=head_frame_seq
 46811 DEFW 46835    ; IX+2,3: Tile frame sequence pointer. Advanced +1/frame
                     ; by #R37997 to read the next tile index byte. #R46835
                     ; player head, #R46853 P2 head (normal decap); after
                     ; goblin kick. Byte 255 triggers landed state via #R38180.
@label=head_traj_ptr
 46813 DEFW 47017    ; IX+4,5: Trajectory data pointer. 2-byte pairs
                     ; (control_byte, magnitude); advanced +2/frame by #R37997.
                     ; #R47017 normal decapitation, #R47085 after goblin kick.
@label=head_screen_addr
 46815 DEFW 0        ; IX+6,7: Current framebuffer address. Updated every frame
                     ; by #R37997, read by #R38137 for shadow placement.

; Player 2 overlay state block.
;
; 9-byte block reusing the same layout as the head state block at #R46809,
; allowing #R38103 and #R38158 to serve both renderers without modification.
;
; .
;
; Written each frame by #R38220 before jumping to #R38103.
@label=p2_overlay_block_state
g46817 DEFB 0        ;  IX+0: mirror flag (0=facing right, 1=facing left).
                     ; Copied from #R46436 bit 0.
 46818 DEFB 1        ;  IX+1: not written by #R38220; not read.
 46819 DEFW 47219    ;  IX+2,3: pointer to current tile index entry = #R47223 +
                     ; P2 frame index.
 46821 DEFW 0        ;  IX+4,5: not used by P2 overlay path. Retains head state
                     ; values.
 46823 DEFW 24074    ;  IX+6,7: framebuffer destination address. Computed by
                     ; #R38220.

; Unused buffer.
;
; .
;
; .
;
; Unused buffer. 46825 is written to 0 by #R37866 (redundant, already 0). 46826
; retains its init value of 6 and is never read or written at runtime. Likely a
; remnant of a 9-byte P2 overlay state block before the IX8 field was removed.
@label=unused_buffer
u46825 DEFB 0,6

; Energy bar UDG indices.
;
; 7-entry table of packed UDG indices for 3-segment energy bar (0-6 segments).
;
; .
;
; Indexed by current energy / 2 (IY+7 >> 1). Each byte packs 3 x 2-bit segment
; types (0=empty, 1=low, 2=med, 3=full).
; .
; Index = energy >> 1 (IY+7). Used by #R39391 to select UDGs for HUD blit at
; VRAM 16416(P1)/16445(P2).
@label=energy_bar_attrs
b46827 DEFB 0        ; 0 segs: all empty
 46828 DEFB 1        ; 1 seg:  medium circle, empty, empty
 46829 DEFB 2        ; 2 segs: full circle, empty, empty
 46830 DEFB 6        ; 3 segs: full circle, medium circle, empty
 46831 DEFB 10       ; 4 segs: full circle, full circle, empty
 46832 DEFB 26       ; 5 segs: full circle, full circle, medium circle
 46833 DEFB 42       ; 6 segs: full circle, full circle, full circle

; Horizontal distance between fighters.
;
; Computed by #R39856 as absolute difference of tile X positions.
;
; .
;
; Read by #R39518 to validate hit range conditions.
@label=fighter_distance
g46834 DEFB 0

; P1 head tile sequence.
;
; 17-entry tile index sequence for the severed P1 head animation.
; .
; Consumed by #R37997 one index per frame via the tile sequence pointer at
; IX+2,3 (#R46811). Each byte is a tile index resolved against sprite bank base
; #R40192 by #R38103.
; .
; Terminated by sentinel 255 at #R46852, which triggers #R38180 to mark the
; head as landed (#R46810 = 255).
;
; .
;
; Tile base: #R40192. 17 active tile IDs + 1 sentinel = 18 bytes total.
@label=p1_head_tile_seq
b46835 DEFB 1,2,4,5   ; Tile IDs: 1,2,4,5 (cycle 1).
 46839 DEFB 1,2,4,5   ; Tile IDs: 1,2,4,5 (cycle 2).
 46843 DEFB 1,2,4,5   ; Tile IDs: 1,2,4,5 (cycle 3).
 46847 DEFB 1,1,2,2,2 ; Tile IDs: 1,1,2,2,2 (final phase).
 46852 DEFB 255       ; Sentinel 255: end of sequence, triggers #R38180.

; P2 head tile sequence.
;
; 17-entry tile index sequence for the severed P2 head animation.
; .
; Structure identical to #R46835. Tile ID 18 is absent (sequence jumps directly
; 17->19). Each byte resolved against sprite bank base 40192 by #R38103.
; .
; Terminated by sentinel 255 at #R46870, triggering #R38180 (#R46810 = 255).
;
; .
;
; Tile base: #R40192. 17 active tile IDs + 1 sentinel = 18 bytes total.
@label=p2_head_tile_seq
b46853 DEFB 16,17,19,20    ; Tile IDs: 16,17,19,20 (cycle 1, tile ID 18
                           ; absent).
 46857 DEFB 16,17,19,20    ; Tile IDs: 16,17,19,20 (cycle 2).
 46861 DEFB 16,17,19,20    ; Tile IDs: 16,17,19,20 (cycle 3).
 46865 DEFB 16,16,17,17,17 ; Tile IDs: 16,16,17,17,17 (final phase).
 46870 DEFB 255            ; Sentinel 255: end of sequence, triggers #R38180.

; Final boss spell tile sequence (unused).
;
; Tile index sequence alternating IDs 18 and 22, resolved against sprite bank
; base #R40192. Belongs to the final boss projectile spell attack, present in
; another version of the game. The final boss does not appear in this build and
; this sequence is not referenced by any runtime code.
;
; .
;
; Dead data retained from another game version. Format identical to #R46835 and
; #R46853 (tile IDs + sentinel 255).
u46871 DEFB 18,22,18,22,18,22,18,22 ; {Tile IDs: 18,22 alternating (spell
 46879 DEFB 18,22,18,22,18,22,18    ; projectile animation frames).}
 46886 DEFB 255                     ; Sentinel 255: end of sequence.

; Unused
u46887 DEFB 0,0

; AI difficulty entry table / Head trajectory data
;
; 32-byte tables indexed by R AND 31 (0-31). AI decision weights for levels 0-5
; (passive to aggressive). Used by #R35765 to bias movement choices..
@label=ai_level_0
b46889 DEFB 2,2,3,3,4,4,5,5   ; {fight 0 (most passive, avg sub_index 5.75).
 46897 DEFB 5,5,6,6,6,6,6,6   ; Range: 2-7. No sub_index 0 or 1 possible at any
 46905 DEFB 6,6,7,7,7,7,7,7   ; random value; the AI always picks at least
 46913 DEFB 7,7,7,7,7,7,7,7   ; sub_index 2, guaranteeing a moderate-to-heavy
                              ; movement block.}
; AI Level 1
@label=ai_level_1
 46921 DEFB 1,1,2,3,3,4,4,4   ; {fight 1 (avg sub_index 5.38). Range: 1-7.
 46929 DEFB 5,5,5,5,5,6,6,6   ;
 46937 DEFB 6,6,6,6,6,7,7,7   ;
 46945 DEFB 7,7,7,7,7,7,7,7   ; }
; AI Level 2
@label=ai_level_2
 46953 DEFB 0,0,1,1,2,2,2,3   ; {fight 2 (avg sub_index 4.38). Range: 0-7.
 46961 DEFB 3,3,3,4,4,4,4,5   ;
 46969 DEFB 5,5,5,5,6,6,6,6   ;
 46977 DEFB 6,7,7,7,7,7,7,7   ; }
; AI Level 4
@label=ai_level_4
 46985 DEFB 0,0,0,0,0,1,1,1   ; {fight 4 (avg sub_index 3.12). Range: 0-7.
 46993 DEFB 1,1,2,2,2,2,3,3   ;
 47001 DEFB 3,3,4,4,4,4,5,5   ;
 47009 DEFB 5,5,6,6,6,7,7,7   ; }
; Normal trajectory data.
; .
; Table of 2-byte step pairs (control, magnitude) for the severed head after a
; normal decapitation. One pair is consumed per frame by #R37997 via the
; trajectory pointer at IX4,5 (#R46813).
; .
; Control byte: bit 0 set (value 1) moves the head up by magnitude scanlines;
; bit 1 set (value 2) moves it down; value 0 holds position. Magnitude is the
; vertical delta in scanlines applied that frame.
; .
; The head rises 9 scanlines over 2 frames (6+3), holds one frame at the peak,
; then falls with increasing speed (2, 4, 6, 8, 10, 12, 14 scanlines per
; frame), bounces slightly upward (4+2), and settles to the ground.
; .
; Loaded into IX4,5 (#R46813) by #R37944 at the moment of decapitation. 18 step
; pairs, 36 bytes total.
; .
; Spell trajectory data.
@label=normal_traj_data
 47017 DEFB 1,6,1,3           ; Rise: up 6, up 3 scanlines.
 47021 DEFB 0,0               ; Hold: peak position.
 47023 DEFB 2,2,2,4,2,6,2,8   ; Fall: down 2, 4, 6, 8 scanlines (accelerating).
 47031 DEFB 2,10,2,12         ; Fall: down 10, 12 scanlines.
 47035 DEFB 2,14,1,4          ; Fall: down 14; bounce: up 4 scanlines.
 47039 DEFB 1,2,0,0           ; Bounce: up 2; hold.
 47043 DEFB 2,2,2,4           ; Settle: down 2, 4 scanlines.
 47047 DEFB 0,0,0,0,0,0       ; Landed: hold.
; AI Level 5
@label=ai_level_5
 47053 DEFB 0,0,0,0,0,0,0,1   ; {fight 5 (avg sub_index 2.62). Range: 0-7.
 47061 DEFB 1,1,1,1,2,2,2,2   ;
 47069 DEFB 2,3,3,3,3,4,4,4   ;
 47077 DEFB 4,5,5,5,6,6,7,7   ; }
; Goblin-kick head trajectory.
; .
; Table of 2-byte step pairs (control, magnitude) for the severed head after
; the goblin kick (#R37964). Replaces the active trajectory pointer at IX4,5
; (#R46813) via #R37950.
; .
; Same format as #R47017: control byte 1 moves up, 2 moves down, 0 holds.
; Magnitude is the vertical delta in scanlines applied that frame.
; .
; The head rises 9 scanlines over 2 frames (6+3), holds one frame, falls 9
; scanlines (6+3), holds, bounces up 3 scanlines, holds, settles down 3
; scanlines, then rests.
; .
; Loaded into IX4,5 (#R46813) by #R37964 via #R37950 after the goblin kick. 17
; step pairs, 34 bytes total.
@label=kicked_traj_data
 47085 DEFB 1,6,1,3           ; Rise: up 6, up 3 scanlines.
 47089 DEFB 0,0               ; Hold.
 47091 DEFB 2,6,2,3           ; Fall: down 6, down 3 scanlines.
 47095 DEFB 0,0               ; Hold.
 47097 DEFB 1,3,0,0           ; Bounce: up 3; hold.
 47101 DEFB 2,3,0,0           ; Settle: down 3; hold.
 47105 DEFB 0,0,0,0,0,0,0,0   ; {Landed: hold.
 47113 DEFB 0,0,0,0,0,0       ; }
; AI Level 6
@label=ai_level_6
 47119 DEFB 0,0,0,0,0,0,0,0   ; {fight 6 (avg sub_index 1.59). Range: 0-6. Only
 47127 DEFB 0,0,0,1,1,1,1,1   ; entry where max sub_index never reaches 7; the
 47135 DEFB 1,1,1,2,2,2,2,2   ; AI cannot select the most aggressive movement
 47143 DEFB 3,3,3,4,4,5,5,6   ; block even at maximum random variance.}
; Trajectory-format data fragment. Four 2-byte pairs (control=2, magnitude):
; (2,8),(2,8),(2,10),(2,10). Control byte 2 with moderate-to-high constant
; magnitudes matches a stabilised falling arc phase. No confirmed code
; reference loads this address as a trajectory pointer. Likely dead data,
; possibly a remnant of the drax spell movement.
 47151 DEFB 2,8,2,8,2,10,2,10 ; Trajectory-format data fragment.
; AI Level 7
@label=ai_level_7
 47159 DEFB 0,0,0,0,0,0,0,0   ; {fight 7 (most aggressive, avg sub_index
 47167 DEFB 0,0,0,0,0,0,1,1   ; ~1.09). Range: 0-5. Even at maximum difficulty
 47175 DEFB 1,1,1,1,1,1,2,2   ; the AI cannot lock to sub_index 0; some passive
 47183 DEFB 2,2,3,3,4,4,5,5   ; outcomes (sub_index 4-5) remain possible at the
                              ; high end. Occupies 47159-47190. Bytes
                              ; 47181-47190 are positions 22-31 of this table,
                              ; NOT the start of fight 3.}
; AI Level 3
; .
; Located at 47191, after fights 4, 5, 6, 7 in memory despite being fight 3 in
; the logical sequence (pointer table at #R47559 resolves order).
; .
; Fits correctly between F2 (avg 4.38) and F4 (avg 3.12),
; .
; confirming the monotonically increasing difficulty curve.
@label=ai_level_3
 47191 DEFB 0,0,0,1,1,1,2,2   ; {fight 3 (avg sub_index 3.57). Range: 0-7.
 47199 DEFB 2,3,3,3,3,4,4,4   ;
 47207 DEFB 4,5,5,5,5,6,6,6   ;
 47215 DEFB 6,6,6,7,7,7,7,7   ; }

; Per-frame overlay tile index table.
;
; One byte per P2 animation frame. Each byte is an index into the P2 sprite
; bank at #R40192 (tiles 0-52), selecting the overlay tile to draw over the P2
; at that frame. Value 255 means no overlay.
; .
; Indexed by P2 frame index #R46442. Read by #R38220 via ADD HL,DE.
@label=p2_overlay_tile_table
b47223 DEFB 8,9,10,11,12,13,23,31
 47231 DEFB 12,37,14,255,15,255,255,255
 47239 DEFB 255,23,21,21,24,21,26,28
 47247 DEFB 28,30,29,31,31,255,34,255
 47255 DEFB 255,255,255,255,255,255,255,255
 47263 DEFB 255,255,255,35,35,35,33,7
 47271 DEFB 7,7,7,7,12,31,31,37
 47279 DEFB 21,21,23,23,23,23,21,26
 47287 DEFB 21,26,28,21,31,31,33,23
 47295 DEFB 30,36,36,25,7,23,35,35
 47303 DEFB 35,21,255,41,255,255,41,255
 47311 DEFB 255,7,14,255,12,7,7,7
 47319 DEFB 255,255,255,255,255,255,255,255
 47327 DEFB 255,255

; Per-frame overlay position table.
;
; One byte per P2 animation frame. Encodes the framebuffer offset for the
; overlay relative to the P2's tile:
; .
; bits 0-5 = scanline offset downward from framebuffer row 94 (0-63 lines).
; .
; bits 6-7 = fine column offset rightward from P2 X tile (0-3 tiles).
; .
; When P2 is mirrored (#R46436 bit 0 set), #R38220 inverts the column offset as
; 6-L before adding to the X tile.
; .
; Indexed by P2 frame index #R46442. Read by #R38220 via #R38318.
@label=p2_overlay_pos_table
b47329 DEFB 148,148,148,148,85,85,85,85
 47337 DEFB 74,65,103,105,103,91,14,0
 47345 DEFB 205,0,0,0,0,85,86,85
 47353 DEFB 85,83,149,20,20,21,213,149
 47361 DEFB 149,0,213,0,0,0,0,0
 47369 DEFB 0,0,0,0,0,0,0,86
 47377 DEFB 86,86,85,148,148,148,148,148
 47385 DEFB 74,105,105,91,83,85,85,85
 47393 DEFB 85,85,83,149,86,149,20,85
 47401 DEFB 149,149,85,85,21,63,63,107
 47409 DEFB 148,85,85,85,85,86,0,58
 47417 DEFB 0,0,58,0,0,148,14,0
 47425 DEFB 103,148,148,148

; Player 1 score buffer.
;
; In this address the player's 1 score is stored.
;
; .
;
; Written by #R35531.
@label=p1_score
g47429 DEFB 0,0

; Player 2 score buffer.
;
; In this address the player's 2 score is stored.
;
; .
;
; Written by #R35531.
@label=p2_score
g47431 DEFB 0,0

; P1 keyboard scancode table.
;
; 5-byte table: Fire, Up, Down, Left, Right scancodes for P1 (controller type
; 1).
;
; .
;
; Written by #R36363 key-assignment loop when P1 selects custom keyboard
; (#R36316 sets IX=#R47433).
; .
; Read by #R35825 each frame when P1 controller type is 1.
; .
; The contents of the table are assignments in loading time.
@label=p1_keyboard_table
g47433 DEFB 34       ; Right = P  (34)
 47434 DEFB 37       ; Up  = Q  (37)
 47435 DEFB 38       ; Down  = A  (38)
 47436 DEFB 18       ; Left    = I  (18)
 47437 DEFB 26       ; Fire  = O  (26)

; Pause key Scancode Buffer
;
; Pause Scancode Buffer only configurable when choosing keyboard.
;
; .
;
; Cleared to 0 by #R36316 and #R36627/#R36642 before key-assignment.
; .
; Captured by #R36363 only if 0 (not yet assigned).
; .
; Read by #R35240 (game loop) and #R35514 (pause handler) via #R35910.
@label=pause_scancode
g47438 DEFB 24       ; Pause key scancode. 0=unassigned.

; Quit Scancode Buffer
;
; Quit scancode buffer only configurable when choosing keyboard.
;
; .
;
; Cleared to 0 by #R36316 and #R36627/#R36642 before key-assignment.
; .
; Captured by #R36363 only if 0 (not yet assigned).
; .
; Read by #R35240 (game loop) via #R35910.
@label=quit_scancode
g47439 DEFB 32       ; Quit key scancode. 0=unassigned.

; P2 keyboard scancode table.
;
; 5-byte table: Fire, Up, Down, Left, Right scancodes for P2 (controller type
; 2).
;
; .
;
; Pre-loaded with this keys: 35,27,19,3,11.
; .
; Written by #R36363 key-assignment loop when P2 is assigned a custom keyboard
; .
; (#R36347 sets IX=#R47440). Used in 2P options 2 and 3.
; .
; Read by #R35825 each frame when P2 controller type is 2.
@label=p2_keyboard_table
g47440 DEFB 35       ; Fire  = key 0
 47441 DEFB 27       ; Up    = key 9
 47442 DEFB 19       ; Down  = key 8
 47443 DEFB 3        ; Left  = key 6
 47444 DEFB 11       ; Right = key 7

; Sinclair Interface 2 port 2 fixed scancode table.
;
; 5-byte read-only table for controller type 3 (Sinclair Interface 2, keys
; 6-0).
; .
; Values: 35,27,19,3,11 (keyboard keys 0,9,8,6,7).
; .
; Never written at runtime. Read by #R35825 when controller type is 3.
@label=sinclair_joystick_2_table
b47445 DEFB 35       ; Fire  = key 0
 47446 DEFB 27       ; Up    = key 9
 47447 DEFB 19       ; Down  = key 8
 47448 DEFB 3        ; Left  = key 6
 47449 DEFB 11       ; Right = key 7

; Sinclair Interface 2 port 1 fixed scancode table.
;
; 5-byte read-only table for controller type 4 (Sinclair Interface 1, keys
; 1-5).
; .
; Values: 4,12,20,36,28 (keyboard keys 5,4,3,1,2).
; .
; Never written at runtime. Read by #R35825 when P2 controller type is 4
; .
; (2P option 1: Sinclair2 + Sinclair1).
@label=sinclair_joystick_1_table
b47450 DEFB 4        ; Fire  = key 5
 47451 DEFB 12       ; Up    = key 4
 47452 DEFB 20       ; Down  = key 3
 47453 DEFB 36       ; Left  = key 1
 47454 DEFB 28       ; Right = key 2

; Mask scratch buffer
;
; Temporary 3-byte copy of framebuffer bytes before AND-masking for sprite
; transparency. Written by #R37159. Read by #R37200.
@label=mask_scratch_buffer
g47455 DEFB 0,0,0

; Input class lookup table.
;
; .
;
; .
;
; 16-byte table indexed by the lower 4 bits of the key state bitmask.
; .
; Converts all 16 possible directional button combinations into one of 9
; meaningful input classes (0-8), used as column offsets into the 9-byte
; movement transition rows at #R44907 via #R44795 and #R44851. Read by #R39211
; via #R38318.
; .
; Key bitmask lower 4 bits: bit 0=Right, bit 1=Left, bit 2=Down, bit 3=Up.
; Left/Right may already be swapped by #R39142 for mirrored characters.
; .
; #TABLE(data)
; { Index | Buttons held | Class | Meaning }
; { 0x0 | (none) | 0 | Stand / neutral }
; { 0x1 | Right | 1 | Move towards (forward) }
; { 0x2 | Left | 2 | Move away (backward) }
; { 0x3 | Right+Left | 0 | Cancel (treated as neutral) }
; { 0x4 | Down | 3 | Crouch }
; { 0x5 | Down+Right | 5 | Crouch-forward }
; { 0x6 | Down+Left | 7 | Crouch-backward }
; { 0x7 | Down+Right+Left | 0 | Cancel (treated as neutral) }
; { 0x8 | Up | 4 | Jump }
; { 0x9 | Up+Right | 6 | Jump-forward }
; { 0xA | Up+Left | 8 | Jump-backward }
; { 0xB | Up+Right+Left | 0 | Cancel (treated as neutral) }
; { 0xC | Up+Down | 0 | Cancel (treated as neutral) }
; { 0xD | Up+Down+Right | 0 | Cancel (treated as neutral) }
; { 0xE | Up+Down+Left | 0 | Cancel (treated as neutral) }
; { 0xF | All dirs | 0 | Full cancel (neutral) }
; TABLE#
@label=input_lookup_table
b47458 DEFB 0,1,2,0,3,5,7,0 ; {16 input class bytes, one per directional
 47466 DEFB 4,6,8,0,0,0,0,0 ; bitmask combination (0x00-0x0F).}

; ISR frame counter
;
; Incremented each interrupt (50 Hz PAL). When it reaches 9 it is reset to 0.
;
; .
;
; Written and read exclusively by #R38500 (ISR).
; .
; Acts as a frequency divider: the combat timer #R46808 is decremented once
; every 9 interrupts, giving an effective timer rate of 50/9 ~= 5.56 Hz.
; .
; Initialised to 0 by #R35291 at the start of each game round.
@label=isr_counter
g47474 DEFB 0        ; ISR frame counter. Range 0-8. Resets to 0 on tick 9.

; 2-frame animation and hit-detection gate counter.
;
; Incremented each frame by #R40092. Cycles 0-1-0-1.
;
; .
;
; Checked at the start of the frame by #R39827 (animation update) and R39968
; (tackle): both skip when non-zero.
; .
; Checked after R40092 by #R39468 (hit detection): runs when zero after the
; increment, i.e., the opposite frame from animations.
; .
; Net effect: animations and hit detection alternate each frame and never
; execute simultaneously.
@label=frame_counter_hit
g47475 DEFB 0        ; 2-frame gate counter. 0 animations run, hit detection
                     ; skips. 1 animations skip, hit detection runs.

; Keyboard glyph lookup table
;
; Maps keyboard scancodes (0-39) to UDG indices for drawing key symbols on the
; key assignment screen.
;
; .
;
; Used by #R35937: HL=47476; CALL #R38318 to read glyph index for scancode in
; A.
; .
; Maps keyboard row/column scancodes to UDG glyphs for key config screen
; rendering via #R35937/#R38318.
@label=key_glyph_table
b47476 DEFB 66       ; 'B' (scancode 0)
 47477 DEFB 72       ; 'H' (scancode 1)
 47478 DEFB 89       ; 'Y' (scancode 2)
 47479 DEFB 54       ; '6' (scancode 3)
 47480 DEFB 53       ; '5' (scancode 4)
 47481 DEFB 84       ; 'T' (scancode 5)
 47482 DEFB 71       ; 'G' (scancode 6)
 47483 DEFB 86       ; 'V' (scancode 7)
 47484 DEFB 78       ; 'N' (scancode 8)
 47485 DEFB 74       ; 'J' (scancode 9)
 47486 DEFB 85       ; 'U' (scancode 10)
 47487 DEFB 55       ; '7' (scancode 11)
 47488 DEFB 52       ; '4' (scancode 12)
 47489 DEFB 82       ; 'R' (scancode 13)
 47490 DEFB 70       ; 'F' (scancode 14)
 47491 DEFB 67       ; 'C' (scancode 15)
 47492 DEFB 77       ; 'M' (scancode 16)
 47493 DEFB 75       ; 'K' (scancode 17)
 47494 DEFB 73       ; 'I' (scancode 18)
 47495 DEFB 56       ; '8' (scancode 19)
 47496 DEFB 51       ; '3' (scancode 20)
 47497 DEFB 69       ; 'E' (scancode 21)
 47498 DEFB 68       ; 'D' (scancode 22)
 47499 DEFB 88       ; 'X' (scancode 23)
 47500 DEFB 62       ; '>' (scancode 24)'SYMBOL SHIFT'
 47501 DEFB 76       ; 'L' (scancode 25)
 47502 DEFB 79       ; 'O' (scancode 26)
 47503 DEFB 57       ; '9' (scancode 27)
 47504 DEFB 50       ; '2' (scancode 28)
 47505 DEFB 87       ; 'W' (scancode 29)
 47506 DEFB 83       ; 'S' (scancode 30)
 47507 DEFB 90       ; 'Z' (scancode 31)
 47508 DEFB 58       ; ':' (scancode 32)'SPACE'
 47509 DEFB 61       ; '=' (scancode 33)'ENTER'
 47510 DEFB 80       ; 'P' (scancode 34)
 47511 DEFB 48       ; '0' (scancode 35)
 47512 DEFB 49       ; '1' (scancode 36)
 47513 DEFB 81       ; 'Q' (scancode 37)
 47514 DEFB 65       ; 'A' (scancode 38)
 47515 DEFB 63       ; '?' (scancode 39)'CAPS SHIFT'
 47516 DEFB 59,60    ; Unused padding bytes (';'=59,'<'=60) - scancodes >39
                     ; invalid

; 5-digit decimal divider table.
;
; Five 2-byte little-endian powers of 10 used by #R36063 to decompose a value
; into individual decimal digits: 10000, 1000, 100, 10, 1.
@label=divder_table
b47518 DEFW 10000
 47520 DEFW 1000
 47522 DEFW 100
; 2-digit display entry point. #R35247 calls #R36067 with IX=47524 to print the
; round timer using only the last two divisors (10 and 1).
 47524 DEFB 10,0
 47526 DEFB 1,0

; Snake animation pointer table.
;
; Table of 14 active 16-bit pointers to snake sprite frames in #R33472, indexed
; by the energy bar draw phase (bits 7-4 of IY+7). Forms a ping-pong cycle
; through 4 frames: 1-1-1-2-3-3-4-4-3-3-2-2-1-1
; .
; Used by #R39317 via #R38304 to resolve the frame pointer for each phase.
@label=snake_pointer_table
b47528 DEFW 33472    ; {Phase 0-2  -> #R33472 snake frame 1 (idle)
 47530 DEFW 33472    ;
 47532 DEFW 33472    ; }
 47534 DEFW 33563    ; Phase 3    -> #R33563 snake frame 2
 47536 DEFW 33654    ; {Phase 4-5  -> #R33654 snake frame 3
 47538 DEFW 33654    ; }
 47540 DEFW 33745    ; {Phase 6-7  -> #R33745 snake frame 4 (peak)
 47542 DEFW 33745    ; }
 47544 DEFW 33654    ; {Phase 8-9  -> #R33654 snake frame 3
 47546 DEFW 33654    ; }
 47548 DEFW 33563    ; {Phase 10-11-> #R33563 snake frame 2
 47550 DEFW 33563    ; }
 47552 DEFW 33472    ; {Phase 12-13-> #R33472 snake frame 1 (idle)
 47554 DEFW 33472    ; }
 47556 DEFW 33472    ; Entry 14 is never accessed by #R39317.

; Fight counter.
;
; Tracks how many combats have been played in the current session. Range 0-7.
;
; .
;
; Read by #R35487 and #R36105.
; .
; RESET to 0 by #R35487 only when a fight ends by timeout #R46808=0. On normal
; wins the counter is not reset here.
; .
; initialised to 255 at #R35251. First call to #R36793 wraps it to 0.
; Incremented at the start of each fight. When counter reaches 7, #R35487 no
; longer calls R35458, so stage stops alternating from fight 9 onwards. This
; 8-fight limit is inherited from 1-player mode which has exactly 8 fights.
@label=fight_counter
g47558 DEFB 0        ; Fight counter. 0-7, capped at 7 from fight 8 onwards.

; AI difficulty level pointers.
;
; 16 bits pointers, one per fight level (fight_counter 0-7 from #R47558.
;
; .
;
; Each pointer targets a 32-byte difficulty entry table. The entry is indexed
; by the pseudo-random value (R register AND 31, range 0-31) to yield a
; sub_index (0-7) used to pick within the 8-byte block at #R47974. Higher fight
; numbers point to
; .
; entries that return higher sub_indices, selecting more aggressive movement
; IDs within each block.
; .
; Difficulty curve (avg sub_index, monotonically increasing): F0(5.75) >
; F1(5.38) > F2(4.38) > F3(3.57) > F4(3.12) > F5(2.62) > F6(1.59) > F7(~1.09)
@label=ai_difficulty_table
b47559 DEFW 46889
 47561 DEFW 46921
 47563 DEFW 46953
 47565 DEFW 47191
 47567 DEFW 46985
 47569 DEFW 47053
 47571 DEFW 47119
 47573 DEFW 47159

; Tackle overlap detection flag
;
; Blocks multiple overlap triggers until cleared. Set by #R39088 on eligible
; overlap.
;
; .
;
; 0: Eligible for overlap/tackle. 1: Tackle sequence active.
@label=tackle_overlap_flag
b47575 DEFB 0

; Tackle collision flag
;
; Prevents multiple tackle triggers per sequence. Reset by #R35381 new-round.
;
; .
;
; 0: Able to receive a tackle. 1: Not able to receive a tackle.
@label=tackle_collision_flag
b47576 DEFB 0

; Unused buffer
u47577 DEFB 0

; Secondary AI state-to-profile-column table.
;
; 40-byte table (#R47578-47617) indexed by AI state #R46834 (range 0-39).
;
; .
;
; Each entry is a byte offset (0-7) selecting which column of the 8-byte
; profile block at R47798 is used to obtain the movement_block_id.
; .
; This allows the AI combat state (distance, posture, reaction) to bias the
; profile column independently of the extra_state selection.
; .
; Used by #R35765: Call #R38318 with HL=#R47578 and A=#R46834.
@label=second_ai_state_table
b47578 DEFB 0,1,2,3,4,5,5,6
 47586 DEFB 6,6,6,6,6,6,7,7
 47594 DEFB 7,7,7,7,7,7,7,7
 47602 DEFB 7,7,7,7,7,7,7,7
 47610 DEFB 7,7,7,7,7,7,7,7

; AI behaviour profile pointer table.
;
; Two-section block: a 90-entry 2-byte LE pointer table followed immediately by
; 22 AI profile blocks of 8 bytes each.
;
; .
;
; SECTION 1 (#R47618): 90 x 2-byte LE pointers indexed by extra_state (#R46442
; for P1, #R46433 for P2). Each pointer targets one of the 22 profile blocks
; below. Multiple extra_state values share the same profile.
; .
; SECTION 2 (#R47798): 22 profile blocks x 8 bytes. Each byte is a
; movement_block_id (0-22) selecting an 8-byte row in #R47974. The byte used is
; chosen by #R47578[#R46834] (range 0-7), so the AI state determines which
; column of the profile is active.
; .
; Typical profile structure: first 3 bytes = passive/neutral blocks, middle 3
; bytes = aggressive blocks, last 2 bytes = attack-forward blocks (block 4 and
; 8, both identical: mostly movement-1/attack-5).
