; Composite tile definition data
;
; Composite tile definitions: edge-mask sequences for sprites.
;
; .
;
; 164-byte packed stream (used by #R37218 via #R37317 and #R48433).
; .
; Byte format:
; .
; bits 7-6  render mode: 11=AND-mask #R37161, 00=DirectCopy #R37333,
; 01=EdgeMask-L #R37296 bit6=1, 10=EdgeMask-R #R37296 bit6=0.
; .
; bit  5    end-of-definition signal when this byte is read as the NEXT byte
; after rendering a sub-tile. Has NO effect on rendering itself. bit5=1
; terminates the current sequence AND serves as the first definition byte of
; the following entry (packed shared layout).
; .
; bits 4-0  scanline count (0-31) for this sub-tile.
; .
; Invariant: scanline counts per entry sum to 21 (one full tile column height).
; .
; The only pure terminator is the final byte at 48432 which has no next entry.
; .
; The terminator byte for entry N is ALSO the first definition byte of entry
; N+1.
; .
; No wasted bytes except 48432 (final terminator only).
b48269 DEFB 240,133             ; Entry  0: AND,16sc | EMR,5sc [21sc]
 48271 DEFB 240,69              ; Entry  1: AND,16sc | EML,5sc [21sc]
 48273 DEFB 229,144             ; Entry  2: AND,5sc | EMR,16sc [21sc]
 48275 DEFB 228,81              ; Entry  3: AND,4sc | EML,17sc [21sc]
 48277 DEFB 240,69              ; Entry  4: AND,16sc | EML,5sc [21sc]
 48279 DEFB 241,68              ; Entry  5: AND,17sc | EML,4sc [21sc]
 48281 DEFB 164,194,130,199,134 ; Entry  6: EMR,4sc | AND,2sc | EMR,2sc |
                                ; AND,7sc | EMR,6sc [21sc]
 48286 DEFB 104,200,69          ; Entry  7: EML,8sc | AND,8sc | EML,5sc [21sc]
 48289 DEFB 103,201,69          ; Entry  8: EML,7sc | AND,9sc | EML,5sc [21sc]
 48292 DEFB 242,131             ; Entry  9: AND,18sc | EMR,3sc [21sc]
 48294 DEFB 99,200,74           ; Entry 10: EML,3sc | AND,8sc | EML,10sc [21sc]
 48297 DEFB 228,134,198,133     ; Entry 11: AND,4sc | EMR,6sc | AND,6sc |
                                ; EMR,5sc [21sc]
 48301 DEFB 107,196,70          ; Entry 12: EML,11sc | AND,4sc | EML,6sc [21sc]
 48304 DEFB 226,83              ; Entry 13: AND,2sc | EML,19sc [21sc]
 48306 DEFB 236,73              ; Entry 14: AND,12sc | EML,9sc [21sc]
 48308 DEFB 170,194,72,129      ; Entry 15: EMR,10sc | AND,2sc | EML,8sc |
                                ; EMR,1sc [21sc]
 48312 DEFB 166,79              ; Entry 16: EMR,6sc | EML,15sc [21sc]
 48314 DEFB 164,204,133         ; Entry 17: EMR,4sc | AND,12sc | EMR,5sc [21sc]
 48317 DEFB 104,200,69          ; Entry 18: EML,8sc | AND,8sc | EML,5sc [21sc]
 48320 DEFB 171,197,133         ; Entry 19: EMR,11sc | AND,5sc | EMR,5sc [21sc]
 48323 DEFB 169,5,135           ; Entry 20: EMR,9sc | DC,5sc | EMR,7sc [21sc]
 48326 DEFB 116,1               ; Entry 21: EML,20sc | DC,1sc [21sc]
 48328 DEFB 242,131             ; Entry 22: AND,18sc | EMR,3sc [21sc]
 48330 DEFB 230,143             ; Entry 23: AND,6sc | EMR,15sc [21sc]
 48332 DEFB 242,67              ; Entry 24: AND,18sc | EML,3sc [21sc]
 48334 DEFB 103,6,72            ; Entry 25: EML,7sc | DC,6sc | EML,8sc [21sc]
 48337 DEFB 231,78              ; Entry 26: AND,7sc | EML,14sc [21sc]
 48339 DEFB 113,4               ; Entry 27: EML,17sc | DC,4sc [21sc]
 48341 DEFB 239,134             ; Entry 28: AND,15sc | EMR,6sc [21sc]
 48343 DEFB 164,197,68,7        ; Entry 29: EMR,4sc | AND,5sc | EML,4sc |
                                ; DC,7sc [20sc] ANOMALY sum!=21
 48347 DEFB 107,10              ; Entry 30: EML,11sc | DC,10sc [21sc]
 48349 DEFB 236,137             ; Entry 31: AND,12sc | EMR,9sc [21sc]
 48351 DEFB 168,4,137           ; Entry 32: EMR,8sc | DC,4sc | EMR,9sc [21sc]
 48354 DEFB 228,145             ; Entry 33: AND,4sc | EMR,17sc [21sc]
 48356 DEFB 103,3,75            ; Entry 34: EML,7sc | DC,3sc | EML,11sc [21sc]
 48359 DEFB 106,197,70          ; Entry 35: EML,10sc | AND,5sc | EML,6sc [21sc]
 48362 DEFB 232,77              ; Entry 36: AND,8sc | EML,13sc [21sc]
 48364 DEFB 107,3,71            ; Entry 37: EML,11sc | DC,3sc | EML,7sc [21sc]
 48367 DEFB 231,142             ; Entry 38: AND,7sc | EMR,14sc [21sc]
 48369 DEFB 170,203             ; Entry 39: EMR,10sc | AND,11sc [21sc]
 48371 DEFB 172,201             ; Entry 40: EMR,12sc | AND,9sc [21sc]
 48373 DEFB 163,8,202           ; Entry 41: EMR,3sc | DC,8sc | AND,10sc [21sc]
 48376 DEFB 38,143              ; Entry 42: DC,6sc | EMR,15sc [21sc]
 48378 DEFB 230,79              ; Entry 43: AND,6sc | EML,15sc [21sc]
 48380 DEFB 108,2,199           ; Entry 44: EML,12sc | DC,2sc | AND,7sc [21sc]
 48383 DEFB 228,74,195,68       ; Entry 45: AND,4sc | EML,10sc | AND,3sc |
                                ; EML,4sc [21sc]
 48387 DEFB 109,8               ; Entry 46: EML,13sc | DC,8sc [21sc]
 48389 DEFB 235,74              ; Entry 47: AND,11sc | EML,10sc [21sc]
 48391 DEFB 102,207             ; Entry 48: EML,6sc | AND,15sc [21sc]
 48393 DEFB 104,201,68          ; Entry 49: EML,8sc | AND,9sc | EML,4sc [21sc]
 48396 DEFB 234,75              ; Entry 50: AND,10sc | EML,11sc [21sc]
 48398 DEFB 165,204,132         ; Entry 51: EMR,5sc | AND,12sc | EMR,4sc [21sc]
 48401 DEFB 100,204,69          ; Entry 52: EML,4sc | AND,12sc | EML,5sc [21sc]
 48404 DEFB 229,16              ; Entry 53: AND,5sc | DC,16sc [21sc]
 48406 DEFB 242,3               ; Entry 54: AND,18sc | DC,3sc [21sc]
 48408 DEFB 228,145             ; Entry 55: AND,4sc | EMR,17sc [21sc]
 48410 DEFB 230,15              ; Entry 56: AND,6sc | DC,15sc [21sc]
 48412 DEFB 241,132             ; Entry 57: AND,17sc | EMR,4sc [21sc]
 48414 DEFB 39,73,5             ; Entry 58: DC,7sc | EML,9sc | DC,5sc [21sc]
 48417 DEFB 42,133,6            ; Entry 59: DC,10sc | EMR,5sc | DC,6sc [21sc]
 48420 DEFB 226,135,12          ; Entry 60: AND,2sc | EMR,7sc | DC,12sc [21sc]
 48423 DEFB 235,138             ; Entry 61: AND,11sc | EMR,10sc [21sc]
 48425 DEFB 227,132,195,75      ; Entry 62: AND,3sc | EMR,4sc | AND,3sc |
                                ; EML,11sc [21sc]
 48429 DEFB 235,69,197          ; Entry 63: AND,11sc | EML,5sc | AND,5sc [21sc]
 48432 DEFB 32                  ; Terminator.

