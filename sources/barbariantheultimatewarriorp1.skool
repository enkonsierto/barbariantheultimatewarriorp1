                                    ; fr51:fall+slash+dmg/close
                                    ; fr52:fall+slash+dmg/near
 45108 DEFB 53,20,54,20,55,20,57,19 ; fr53:fall+slash+dmg/near
                                    ; fr54:fall+slash+dmg/near
