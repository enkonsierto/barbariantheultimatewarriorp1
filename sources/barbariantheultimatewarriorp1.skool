 34210 DEFB 22,41,24,41,27,41,26,41
 34218 DEFB 24,41,24,41,22,41,24,24
 34226 DEFB 24,41,22,41,20,41,19,41
 34234 DEFB 17,41,15,41,17,17,17,17
 34242 DEFB 17,17,17,17,17,17,17,17
 34250 DEFB 17,17,17,17,17,17,17,17
 34258 DEFB 17,17,17,17,17,17,17,17
 34266 DEFB 17,17,17,17,17,17,17,17
