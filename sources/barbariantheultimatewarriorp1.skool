; Movement flags table
;
; One byte per movement ID (0-39). Bit flags controlling combat activation,
; interruptibility and draw order.
;
; .
;
; Bit 7: combat-active (1=in-combat movement);
; .
; Bit 6: non-interruptible (input ignored);
; .
; Bit 0: draw on top (when overlapping).
; .
; Bits 1-5 always 0. Read on movement change for state flags (IY+2 bit 7) and
; render priority.
@mov_flags_table
b44755 DEFB 0        ; mv0 idle:          0x00 pre-combat
 44756 DEFB 0        ; mv1 walk forward:   0x00 pre-combat
 44757 DEFB 0        ; mv2 walk backward:  0x00 pre-combat
 44758 DEFB 129      ; mv3 sword spin:     0x81 combat-active, draw-top
 44759 DEFB 128      ; mv4 jump:           0x80 combat-active
 44760 DEFB 129      ; mv5 crouch slash:   0x81 combat-active, draw-top
 44761 DEFB 128      ; mv6 crouch:         0x80 combat-active
 44762 DEFB 129      ; mv7 headcut move:   0x81 combat-active, draw-top
 44763 DEFB 193      ; mv8 death decap:    0xC1 combat-active,
                     ; non-interruptible, draw-top
 44764 DEFB 129      ; mv9 fwd slash:      0x81 combat-active, draw-top
 44765 DEFB 128      ; mv10 guard1:        0x80 combat-active
 44766 DEFB 129      ; mv11 top slash:     0x81 combat-active, draw-top
 44767 DEFB 128      ; mv12 kick:          0x80 combat-active
 44768 DEFB 128      ; mv13 damage recv:   0x80 combat-active
 44769 DEFB 129      ; mv14 overhead slash:0x81 combat-active, draw-top
 44770 DEFB 128      ; mv15 headbutt:      0x80 combat-active
 44771 DEFB 128      ; mv16 guard2:        0x80 combat-active
 44772 DEFB 128      ; mv17 roll forward:  0x80 combat-active
 44773 DEFB 128      ; mv18 roll backward: 0x80 combat-active
 44774 DEFB 192      ; mv19 victory:       0xC0 combat-active,
                     ; non-interruptible
 44775 DEFB 128      ; mv20 crouch stand:  0x80 combat-active
 44776 DEFB 128      ; mv21 crouch strike: 0x80 combat-active
 44777 DEFB 128      ; mv22 guard2b:       0x80 combat-active
 44778 DEFB 128      ; mv23 crouch b:      0x80 combat-active
 44779 DEFB 128      ; mv24 rollback b:    0x80 combat-active
 44780 DEFB 128      ; mv25 fall:          0x80 combat-active
 44781 DEFB 192      ; mv26 goblin a:      0xC0 combat-active,
                     ; non-interruptible
 44782 DEFB 193      ; mv27 death:         0xC1 combat-active,
                     ; non-interruptible, draw-top
 44783 DEFB 192      ; mv28 arena enter:   0xC0 combat-active,
                     ; non-interruptible
 44784 DEFB 193      ; mv29 drag L decap:  0xC1 combat-active,
                     ; non-interruptible, draw-top
 44785 DEFB 129      ; mv30 goblin b:      0x81 combat-active, draw-top
 44786 DEFB 193      ; mv31 drag R decap:  0xC1 combat-active,
                     ; non-interruptible, draw-top
 44787 DEFB 193      ; mv32 drag L:        0xC1 combat-active,
                     ; non-interruptible, draw-top
 44788 DEFB 193      ; mv33 drag R:        0xC1 combat-active,
                     ; non-interruptible, draw-top
 44789 DEFB 192      ; mv34 change side:   0xC0 combat-active,
                     ; non-interruptible
 44790 DEFB 192      ; mv35 walk unused:   0xC0 combat-active,
                     ; non-interruptible
 44791 DEFB 192      ; mv36 win seq:       0xC0 combat-active,
                     ; non-interruptible
 44792 DEFB 192      ; mv37 stand:         0xC0 combat-active,
                     ; non-interruptible
 44793 DEFB 192      ; mv38 goblin c:      0xC0 combat-active,
                     ; non-interruptible
 44794 DEFB 192      ; mv39 endgame:       0xC0 combat-active,
                     ; non-interruptible

; Movement transition pointer tables.
;
; Two adjacent 28-entry sub-tables, 2 bytes per entry (little-endian), one per
; movement ID 0-27. Each entry is a pointer to a 9-byte transition row in
; #R44907.
;
; .
;
; Both tables are indexed by movement ID via #R38304, called from #R39211.
; .
; Each pointed row holds one movement ID per input class (0-8) from #R47458.
; 255 means no transition is defined for that input class.
; .
; Multiple movement IDs may share the same row pointer when their transition
; profiles are identical.
; .
; Movement IDs 28-39 are absent: all are either non-interruptible or
; goblin-only and never reach #R39211 via #R39156.
; .
; No-fire table: selected by #R39211 when Fire (IY+1 bit 4) is not pressed.
; Covers movement IDs 0-27.
@label=no_fire_transition_table
w44795 DEFW 44907
 44797 DEFW 44907
 44799 DEFW 44907
 44801 DEFW 44907
 44803 DEFW 44907
 44805 DEFW 44916
 44807 DEFW 44925
 44809 DEFW 44934
 44811 DEFW 44943
 44813 DEFW 44934
 44815 DEFW 44952
 44817 DEFW 44907
 44819 DEFW 44907
 44821 DEFW 44943
 44823 DEFW 44907
 44825 DEFW 44907
 44827 DEFW 44907
 44829 DEFW 44961
 44831 DEFW 44943
 44833 DEFW 44943
 44835 DEFW 44943
 44837 DEFW 44943
 44839 DEFW 44907
 44841 DEFW 44970
 44843 DEFW 44979
 44845 DEFW 44907
 44847 DEFW 44943
 44849 DEFW 44943
; Fire-pressed table: selected by #R39211 when Fire (IY+1 bit 4) is pressed.
; Covers movement IDs 0-27.
; .
; Non-interruptible movements (bit 6 of #R44755 set) are filtered out by
; #R39156 before #R39211 is called and never index this table.
@label=fire_transition_table
 44851 DEFW 44988
 44853 DEFW 44988
 44855 DEFW 44988
 44857 DEFW 44988
 44859 DEFW 44988
 44861 DEFW 44997
 44863 DEFW 44997
 44865 DEFW 44988
 44867 DEFW 44988
 44869 DEFW 44988
 44871 DEFW 44988
 44873 DEFW 44988
 44875 DEFW 44988
 44877 DEFW 44988
 44879 DEFW 44988
 44881 DEFW 44988
 44883 DEFW 44988
 44885 DEFW 44961
 44887 DEFW 44988
 44889 DEFW 44988
 44891 DEFW 44988
 44893 DEFW 44988
 44895 DEFW 44988
 44897 DEFW 45006
 44899 DEFW 44988
 44901 DEFW 44988
 44903 DEFW 44988
 44905 DEFW 44988

; Movement transition table.
;
; 12 rows x 9 bytes each. Each row is indexed by input class 0-8 via #R47458,
; and holds the movement ID to transition into for that input.
;
; .
;
; A value of 255 means no transition is defined for that input combination.
; .
; Pointed to by #R44795 no-fire and #R44851 fire pressed.
; .
; Multiple movements may share the same row identical transition profile.
; .
; Input class columns 0neutral, 1fwd, 2back, 3crouch, 4jump, 5crouch-fwd,
; 6jump-fwd, 7crouch-back, 8jump-back.
; .
; Resolved by #R39211 once per frame per character.
@label=st_free
b44907 DEFB 0,1,2,23,4,17,10,18,16    ; STFREE Neutral->Idle, Fwd->Walk Fwd,
                                      ; Bwd->Walk Bwd, Crouch->Crouch B,
                                      ; Jump->Jump, CrFwd->Roll Fwd,
                                      ; JmpFwd->Guard 1, CrBwd->Roll Bwd,
                                      ; JmpBwd->Guard 2
@label=st_cr_slash
 44916 DEFB 20,1,2,6,4,17,10,18,16    ; STCRSLASH Neutral->Crouch Stand,
                                      ; Fwd->Walk Fwd, Bwd->Walk Bwd,
                                      ; Crouch->Crouch, Jump->Jump, CrFwd->Roll
                                      ; Fwd, JmpFwd->Guard 1, CrBwd->Roll Bwd,
                                      ; JmpBwd->Guard 2
@label=st_crouching
 44925 DEFB 20,20,20,6,20,17,20,18,20 ; STCROUCHING Neutral->Crouch Stand,
                                      ; Fwd->Crouch Stand, Bwd->Crouch Stand,
                                      ; Crouch->Crouch, Jump->Crouch Stand,
                                      ; CrFwd->Roll Fwd, JmpFwd->Crouch Stand,
                                      ; CrBwd->Roll Bwd, JmpBwd->Crouch Stand
@label=st_free2
 44934 DEFB 0,1,2,23,4,17,10,18,16    ; STFREE_B Identical data to #R44907.
                                      ; Neutral->Idle, Fwd->Walk Fwd, Bwd->Walk
                                      ; Bwd, Crouch->Crouch B, Jump->Jump,
                                      ; CrFwd->Roll Fwd, JmpFwd->Guard 1,
                                      ; CrBwd->Roll Bwd, JmpBwd->Guard 2
@label=st_combat
 44943 DEFB 0,1,2,6,4,17,10,18,16     ; STCOMBAT Neutral->Idle, Fwd->Walk Fwd,
                                      ; Bwd->Walk Bwd, Crouch->Crouch,
                                      ; Jump->Jump, CrFwd->Roll Fwd,
                                      ; JmpFwd->Guard 1, CrBwd->Roll Bwd,
                                      ; JmpBwd->Guard 2
@label=st_guard1
 44952 DEFB 22,1,2,23,4,17,10,18,16   ; STGUARD1 Neutral->Guard 2B (sticky
                                      ; guard), Fwd->Walk Fwd, Bwd->Walk Bwd,
                                      ; Crouch->Crouch B, Jump->Jump,
                                      ; CrFwd->Roll Fwd, JmpFwd->Guard 1,
                                      ; CrBwd->Roll Bwd, JmpBwd->Guard 2
@label=st_roll_fwd
 44961 DEFB 24,24,24,6,24,24,24,24,24 ; STROLLFWD All inputs->Roll Bwd except
                                      ; Crouch->Crouch
@label=st_crouch_lock
 44970 DEFB 6,6,6,6,6,6,6,6,6         ; STCROUCHLOCK All inputs->Crouch
@label=st_roll_bk
 44979 DEFB 0,1,2,0,4,0,10,18,16      ; STROLLBK Neutral->Idle, Fwd->Walk Fwd,
                                      ; Bwd->Walk Bwd, Crouch->Idle,
                                      ; Jump->Jump, CrFwd->Idle, JmpFwd->Guard
                                      ; 1, CrBwd->Roll Bwd, JmpBwd->Guard 2
@label=st_attack
 44988 DEFB 0,9,7,23,11,12,15,14,3    ; STATTACK Neutral->Idle, Fwd->Fwd Slash,
                                      ; Bwd->Headcut, Crouch->Crouch B,
                                      ; Jump->Top Slash, CrFwd->Kick,
                                      ; JmpFwd->Headbutt, CrBwd->Overhead,
                                      ; JmpBwd->Sword Spin
@label=st_cr_attack
 44997 DEFB 20,20,20,5,20,20,20,20,20 ; STCRATTACK All inputs->Crouch Stand
                                      ; except Crouch->Crouch Slash
@label=st_locked_atk
 45006 DEFB 5,5,5,5,5,5,5,5,5         ; STLOCKEDATK All inputs->Crouch Slash

; Hit section pointer tables. Dispatch indexed by attacker frame.
;
; .
;
; .
;
; Each sub-table is a list of 2-byte pairs (defender_frame, hit_type_index)
; terminated by 0xFF. hit_type_index is an index into #R46308.
; .
; Used by #R39492 to test if IY+8 (defender frame) is vulnerable to the current
; attacker frame IX+8.
; .
; Attacker frames with hit sections:
@label=hit_detection_table
b45015 DEFB 5,252,175  ; Frame 5 points to #R45052
 45018 DEFB 7,111,176  ; Frame 7 points to #R45167
 45021 DEFB 12,228,176 ; Frame 12 points to #R45284
 45024 DEFB 23,95,177  ; Frame 23 points to #R45407
 45027 DEFB 26,208,177 ; Frame 26 points to #R45520
 45030 DEFB 28,69,178  ; Frame 28 points to #R45637
 45033 DEFB 32,172,178 ; Frame 32 points to #R45740
 45036 DEFB 34,255,178 ; Frame 34 points to #R45823
 45039 DEFB 36,60,179  ; Frame 36 points to #R45884
 45042 DEFB 37,167,179 ; Frame 37 points to #R45991
 45045 DEFB 38,16,180  ; Frame 38 points to #R46096
 45048 DEFB 67,121,180 ; Frame 67 points to #R46201
 45051 DEFB 128        ; Terminator.

; Hit section: attacker frame 5.
;
; Hitbox active when attacker animation frame index = 5. Pairs:
; (defender_frame, hit_type index into #R46308). Terminated by 0xFF.
;
; .
;
; Kick contact frame (initial). Most defender stances react with fall+slash+dmg
; at adjacent range (type 19).
; .
; fr5 is blocked (guard2/near, type 14). fr7 is fully blocked (guard2/any, type
; 6).
; .
; fr23 has dual entry: type 19 (fall, adjacent) and type 16 (guard1, d1-3
; range).
; .
; Crouching and rolling frames (fr50-fr62) react with fall+slash at near or
; close range (types 20-21).
; .
; Used by #R39468.
@label=hit_frame_5
b45052 DEFB 0,19,1,19,2,19,3,19     ; fr0:fall+slash+dmg/adj
                                    ; fr1:fall+slash+dmg/adj
