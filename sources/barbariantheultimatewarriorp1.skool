 34506 DEFB 24,41,24,41,24,41,22,22
 34514 DEFB 22,41,20,41,22,41,22,41
 34522 DEFB 27,41,29,41,31,41,34,41
 34530 DEFB 32,41,32,41,32,41,31,31
 34538 DEFB 31,41,29,41,31,31,31,41
 34546 DEFB 34,34,34,41,32,41,31,41
 34554 DEFB 29,41,27,41,25,41,24,41
 34562 DEFB 22,41,20,41,19,41,17,41
 34570 DEFB 15,41,13,41,12,41,12,12
 34578 DEFB 12,41,12,41,13,41,13,13
 34586 DEFB 13,41,13,41,10,41,10,10
 34594 DEFB 10,41,10,41,7,41,7,7
 34602 DEFB 7,41,7,5,0,41,0,0
 34610 DEFB 0,41,0,41,1,41,1,1
 34618 DEFB 1,41,1,41,254,41,254,254
 34626 DEFB 254,41,254,41,251,41,251,251
 34634 DEFB 251,41,251,249,244,244,244,244
 34642 DEFB 244,244,244,244,244,244,244,244
 34650 DEFB 244,244,244,244,244,244,244,244
 34658 DEFB 244,244,244,244,244,244,252,41
 34666 DEFB 19,19,15,15
 34670 DEFB 64                              ; End marker (64).

; Bass music data.
;
; Bass sequence for channel 2.
;
; .
;
; #HTML(<audio src="../audio/bass.ogg" controls>Your browser does not support
; the <code>audio</code> element.</audio>)
; .
; Format identical to #R34105: values 0-40 = notes, 41 = control, 64 = end.
; .
; Referenced by #R33871 (initial pointer).
; .
; 565 bytes of bass data that complement the melody.
@label=bass_data
b34671 DEFB 41                            ; Bass data (includes notes,
                                          ; separators and controls).
; Entry point for loop restart during music playback. (Never used).
 34672 DEFB 12,41,17,41,17,41,15,15
 34680 DEFB 15,41,17,17,17,41,15,15
 34688 DEFB 15,41,17,41,20,41,19,41
 34696 DEFB 17,41,17,41,15,41,17,17
 34704 DEFB 17,41,15,41,13,41,12,41
 34712 DEFB 10,41,8,41,249,249,249,41
 34720 DEFB 244,41,249,249,249,41,244,244
 34728 DEFB 244,41,249,249,249,41,244,41
 34736 DEFB 249,41,244,41,249,249,249,41
 34744 DEFB 244,41,249,249,249,41,244,41
 34752 DEFB 249,41,244,41,247,41,244,41
 34760 DEFB 12,41,17,41,17,41,15,15
 34768 DEFB 15,41,17,17,17,41,15,15
 34776 DEFB 15,41,17,41,20,41,19,41
 34784 DEFB 17,41,17,41,15,41,17,17
 34792 DEFB 17,41,15,41,13,41,12,41
 34800 DEFB 10,41,8,41,249,249,249,41
 34808 DEFB 244,41,249,249,249,41,244,244
 34816 DEFB 244,41,249,249,249,41,244,41
 34824 DEFB 249,41,244,41,249,249,249,41
 34832 DEFB 244,41,249,249,249,41,244,41
 34840 DEFB 1,41,1,41,1,41,3,3
 34848 DEFB 3,41,254,41,3,3,3,41
 34856 DEFB 7,7,7,41,5,41,3,41
 34864 DEFB 254,41,8,41,7,41,3,41
 34872 DEFB 5,41,5,41,5,41,3,3
 34880 DEFB 3,41,254,41,3,3,3,41
 34888 DEFB 7,7,7,41,5,41,7,41
 34896 DEFB 8,41,12,41,10,41,12,41
 34904 DEFB 0,41,5,41,5,41,3,3
 34912 DEFB 3,41,5,5,5,41,3,3
 34920 DEFB 3,41,5,41,8,41,7,41
 34928 DEFB 5,41,5,41,3,41,5,5
 34936 DEFB 5,41,3,41,1,41,0,41
 34944 DEFB 254,41,252,41,249,249,249,41
 34952 DEFB 244,41,249,249,249,41,244,244
 34960 DEFB 244,41,249,249,249,41,244,41
 34968 DEFB 249,41,244,41,249,249,249,41
 34976 DEFB 244,41,249,249,249,41,244,41
 34984 DEFB 249,41,244,41,247,41,244,41
 34992 DEFB 249,41,249,41,249,41,252,252
 35000 DEFB 252,41,249,41,252,41,254,41
 35008 DEFB 0,0,0,41,5,41,8,41
 35016 DEFB 13,41,12,41,8,41,12,41
 35024 DEFB 18,41,17,17,17,41,12,41
 35032 DEFB 8,41,12,41,17,17,17,41
 35040 DEFB 15,15,15,41,13,41,13,41
 35048 DEFB 13,41,15,15,15,41,10,41
 35056 DEFB 15,15,15,41,19,19,19,41
 35064 DEFB 17,41,15,41,12,41,10,41
 35072 DEFB 8,41,8,41,8,41,7,7
 35080 DEFB 7,41,5,41,7,41,7,41
 35088 DEFB 10,41,12,41,15,41,19,41
 35096 DEFB 17,41,17,41,17,41,15,15
 35104 DEFB 15,41,10,41,15,15,15,41
 35112 DEFB 19,19,19,41,17,41,15,41
 35120 DEFB 13,41,12,41,10,41,8,41
 35128 DEFB 7,41,5,41,3,41,1,41
 35136 DEFB 0,41,254,41,12,12,12,12
 35144 DEFB 12,12,12,12,12,12,12,12
 35152 DEFB 12,12,12,12,12,12,12,12
 35160 DEFB 12,12,12,12,12,12,12,12
 35168 DEFB 12,41,12,10,12,12,12,12
 35176 DEFB 12,12,12,12,12,12,12,12
 35184 DEFB 12,12,12,12,12,12,12,12
 35192 DEFB 12,12,12,12,12,12,12,12
 35200 DEFB 12,41,12,10,12,12,12,12
 35208 DEFB 12,12,12,12,12,12,12,12
 35216 DEFB 12,12,12,12,12,12,12,12
 35224 DEFB 12,12,12,12,12,12,20,41
 35232 DEFB 251,251,247,247
 35236 DEFB 64                            ; End marker (64).

; Unused
;
; 3 unused bytes between the end of the bass music data and the game entry
; point at #R35240. Not referenced by any code.
u35237 DEFB 0,0,0

@start
@org=35240
; Game Entry Point
;
; Sets up the system and runs the menu.
@label=entry_point
c35240 DI            ; Game Loaded (Entry Point)
 35241 LD SP,0       ; Initialises the stack pointer to 0.
 35244 CALL 48896    ; Jumps to the game start routine.
; This entry point is used by the routine at #R35381.
*35247 DI            ; Disable interrupts.
 35248 LD SP,0       ; Initialises the stack pointer to 0.
 35251 LD A,255      ; {Write 255 to the fight counter buffer. (#R47558).
 35253 LD (47558),A  ; }
 35256 CALL 36130    ; Runs the main menu via #R36130.
 35259 LD HL,0       ; {Clears the stack and zeroes, #R47429 and #R47431.
 35262 PUSH HL       ; (Scores Buffer).
 35263 LD (47429),HL ;
 35266 LD (47431),HL ; }
 35269 CALL 35426    ; Resets and draws the Player 1 score HUD via #R35426.
 35272 CALL 35435    ; Resets and draws the Player 2 score HUD via #R35435.
 35275 LD HL,16559   ; Sets the time HUD screen address.
 35278 POP DE        ; Loads DE = 0 for the initial time value.
 35279 LD B,2        ; B = 2 two digits to print.
 35281 LD IX,47524   ; Points IX to the time value buffer #R47524.
 35285 CALL 36067    ; Converts the time value to ASCII and draws it via
                     ; R36063.
 35288 CALL 35414    ; Sets the round timer mode via #R35414.
; This entry point is used by the routine at #R35487.
*35291 XOR A         ; A = 0.
 35292 LD (47474),A  ; {Clears #R47474, #R46810 and #R46443 to 0.
 35295 LD (46810),A  ;
 35298 LD (46443),A  ; }
 35301 CALL 38547    ; Copies the stage 1 background to the screen buffer via
                     ; #R38547.
 35304 CALL 38849    ; Paints the stage to the screen row by row via R38849.
 35307 CALL 36776    ; Resets the P1 state block via #R36776 tile 0, full
                     ; energy, facing right.
 35310 CALL 36793    ; Resets the P2 state block via #R36793 tile 23, full
                     ; energy, facing left.
; This entry point is used by the routine at #R35514.
@label=game_loop
*35313 CALL 38547    ; Copy active stage background to screen buffer via
                     ; #R38547.
 35316 CALL 39617    ; Main character update and render dispatch (both fighters
                     ; + goblin) via #R39617.
 35319 CALL 37997    ; Severed head physics update and rendering via #R37997.
 35322 CALL 39258    ; Snake energy bar animation update via #R39258.
 35325 CALL 39968    ; Per-frame movement auto-update via #R39968.
 35328 EI            ; Enable interrupts.
 35329 HALT          ; Wait for 50Hz frame interrupt (frame sync).
 35330 DI            ; Disable interrupts.
 35331 CALL 38412    ; Copy screen buffer to video RAM via #R38412.
 35334 CALL 35450    ; Align hit indicator tile address via #R35450.
 35337 CALL 40092    ; Per-frame screen effect update via #R40092.
 35340 CALL 39468    ; Per-frame hit collision detection between fighters via
                     ; #R39468.
 35343 CALL 35531    ; Hit processor: score award and sound dispatch via
                     ; #R35531.
 35346 CALL 35426    ; Refresh player 1 score display via #R35426.
 35349 CALL 35435    ; Refresh player 2 score display via #R35435.
 35352 CALL 36105    ; Update time / fight counter HUD via #R36105.
 35355 LD A,(47439)  ; Load quit key scancode from #R47439.
 35358 CALL 35910    ; Test if quit key is pressed via #R35910.
 35361 JR NC,35381   ; Quit pressed (carry clear): jump to new round reset at
                     ; #R35381.
 35363 LD A,(47438)  ; Load pause key scancode from #R47438.
 35366 CALL 35910    ; Test if pause key is pressed via #R35910.
@label=pause_handler_entry
 35369 JP NC,35514   ; Pause pressed (carry clear): jump to pause handler at
                     ; #R35514.
 35372 LD A,(46808)  ; Read round timer #R46808.
 35375 OR A          ; Test if zero.
 35376 JP Z,35487    ; Timer = 0 (2P timeout): jump to post-fight handler at
                     ; #R35487.
 35379 JR 35313      ; Loop back to next frame at #R35313.

; Game Over, Game Reset.
;
; Used by the routines at #R35240, #R37631 and #R37843.
;
; .
;
; Resets game state and returns to the menu sequence at #R35247.
; .
; IY+7 is a packed byte: bits 7-4 hold the snake animation draw phase (0=idle,
; 1-13=active cycle), bits 3-0 hold the current energy value (0-13). Writing
; 0x10 arms the snake animation for one step before #R36776 and #R36793 restore
; energy to 13.
@label=game_reset
c35381 LD A,16       ; {Sets energy to 16 (0x10) in both player state blocks,
 35383 LD (46432),A  ; priming the animation. Energy is restored to 13 by
 35386 LD (46441),A  ; #R36776 at #R35307 and #R36793 at #R35310.}
 35389 CALL 39258    ; Runs one snake animation frame for both players via
                     ; R39258; the HP bar UDG segments are not updated here.
 35392 XOR A         ; A = 0.
 35393 LD (47576),A  ; Clear tackle collision flag #R47576.
 35396 LD (46454),A  ; Reset active stage index to 0 (stage 1) at #R46454.
 35399 LD HL,26752   ; HL = stage 1 graphics base #R26752.
 35402 LD (46459),HL ; Set active stage graphics pointer #R46459 to stage 1.
 35405 LD HL,46614   ; HL = stage 1 attribute data #R46614.
 35408 LD (46461),HL ; Set active stage attributes pointer #R46461 to stage 1.
 35411 JP 35247      ; Jump to game menu sequence at #R35247.

; Sets infinite time or not.
;
; Sets the timer depending if there are two or one (human) players.
;
; .
;
; Called on each game restart via #R35288. If #R46808 is already 255 (initial
; value on load, or 1P/demo mode), returns immediately.
; .
; Otherwise writes 101 to #R46808 for 2P mode: the extra counts above 90
; compensate for the timer decrement between menu selection and game start, so
; the HUD reads 90 when combat begins.
; .
; Subsequent rounds bypass this routine and load 90 directly via #R36519.
@label=set_infinite_time
c35414 LD A,(46808)  ; Load round timer #R46808 into A.
 35417 CP 255        ; If 255, already in infinite time mode; return.
 35419 RET Z         ; Return.
 35420 LD A,101      ; A = 101: 2 Player mode.
 35422 LD (46808),A  ; Later 90 will be written in the #R46808 via #R36519.
 35425 RET           ; Return.

; Score display updater.
;
; Redraws the 5-digit score for one player to the HUD.
;
; .
;
; Called every frame from the game loop and once at initialisation via #R35240.
; .
; Entry at #R35426 targets Player 1; entry at #R35435 targets Player 2.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX and shadow registers.
@label=paint_score
c35426 LD HL,16553   ; Sets HL to the Player 1 score HUD tile address.
 35429 LD DE,(47429) ; Loads the Player 1 score value address into DE.
 35433 JR 35442      ; Jumps to the shared print path.
; This entry point updates the Player 2 score.
; .
; Used by the routines at #R35240 and #R37819.
*35435 LD HL,16562   ; First tile address of the Player 2 score HUD.
 35438 LD DE,(47431) ; VRAM destination for Player 2 score R47431.
*35442 PUSH AF       ; Preserves A.
 35443 LD B,5        ; Sets digit count to 5.
 35445 CALL 36063    ; Converts and draws the score via #R36063.
 35448 POP AF        ; Restores A.
 35449 RET           ; Return.

; Aligns the hit indicator screen address to a tile boundary.
;
; Used by the routine at #R35240.
;
; .
;
; #R35531 stores the hit indicator address with a +2 column offset. This
; routine strips it each frame by applying AND F8h to the low byte of #R46806,
; ready for the next draw call.
; .
; DESTROYS: A, HL
@label=align_hit_indicator
c35450 LD HL,(46806) ; {HL = #R46806, load the low byte into A.
 35453 LD A,(HL)     ; }
 35454 AND 248       ; AND F8h: clear bits 2-0, strip the +2 column offset.
 35456 LD (HL),A     ; Write aligned low byte back to #R46806.
 35457 RET           ; Return.

; Switches the active stage graphics and attribute pointers.
;
; Toggles #R46454 between 0 and 1, then resolves the corresponding graphics and
; attribute pointers from #R46455 and #R46463, storing them as the active stage
; for the next background paint.
@label=change_stage_ptr
c35458 LD A,(46454)  ; {Load active stage index #R46454, toggle it (XOR 1) and
 35461 XOR 1         ; write back.
 35463 LD (46454),A  ; }
 35466 PUSH AF       ; Preserve toggled index for the second lookup.
 35467 LD HL,46455   ; {HL = graphics pointer table #R46455; resolve new
 35470 CALL 38304    ; graphics pointer via #R38304.}
 35473 POP AF        ; Restore index for the second lookup.
 35474 LD (46459),HL ; Store new graphics pointer in #R46459.
 35477 LD HL,46463   ; {HL = attributes pointer table #R46463; resolve new
 35480 CALL 38304    ; attributes pointer via #R38304.}
 35483 LD (46461),HL ; Store new attributes pointer in #R46461.
 35486 RET           ; Return.

; Post-fight handler. Stage alternation and counter/time reset.
;
; Used by the routines at #R35240 and #R37791.
;
; .
;
; Called from #R35376 on 2P timeout (#R46808=0) or from #R37796 on 1P win
; (#R46808 always 255 during combat). Alternates stage via #R35458 unless fight
; counter has reached 7. Resets fight counter to 0 and restores time to 90 only
; on timeout (2P mode). On 1P win (time=255), counter advances normally with no
; reset.
@label=post_fight_handler
c35487 LD A,(47558)  ; Read the fight counter buffer #R47558.
 35490 INC A         ; Increment only for comparison - will not be stored.
 35491 CP 8          ; Would counter+1 reach 8? (1P fight limit)
 35493 CALL NZ,35458 ; If not fight 8, alternate the stage via #R35458.
 35496 LD A,(46808)  ; Load time buffer #R46808: 255=won by combat, 0=timeout.
 35499 OR A          ; If 0: round ended by timeout (2P mode); if 255: P1
                     ; victory by combat.
 35500 JR NZ,35511   ; If non-zero (P1 victory), skip the time reset.
 35502 XOR A         ; Timeout path: Reset the fight counter to 0 at #R47558.
 35503 LD (47558),A  ;
 35506 LD A,90       ; {Restore the time to 90 at #R46808.
 35508 LD (46808),A  ; }
*35511 JP 35291      ; Return to the game loop.

; Pause handler.
;
; Called from #R35369.
;
; .
;
; Entered from the main game loop when the pause key #R47438 is pressed.
; .
; Plays a sound via #R39944, waits 112ms to debounce the initial press, then
; polls #R47438 via #R35910 until the pause key is pressed again to resume.
; .
; IN None. OUT None. DESTROYS AF, BC.
@label=pause_handler_routine
c35514 CALL 39944    ; Play pause sound via #R39944.
 35517 CALL 39846    ; Wait 112ms to absorb the initial key press.
*35520 LD A,(47438)  ; Load pause key scancode from #R47438.
 35523 CALL 35910    ; Test pause key state via #R35910. Carry=1 released,
                     ; carry=0 pressed.
 35526 JR C,35520    ; Key released - loop back, waiting for the second press.
 35528 JP 35313      ; Key pressed again - resume, jump to game loop at
                     ; #R35313.

; Hit processor, score award and sound dispatcher.
;
; Called once per frame from the game loop. Reads the pending combat event from
; #R46803.
;
; .
;
; If 0, returns immediately. Events 5-6 (guard) skip the visual/score logic and
; jump directly to sound dispatch.
; .
; Events 1-4 (hit): draws a hit indicator glyph (#R26216) near the attacker
; column if the frame is in #R46747, awards score if the frame is in #R46775,
; then clears #R46803 and plays the sound for the event.
; .
; Sound index: 1=#R39932, 2=#R39926, 3=#R39938, 4=#R39944, 5=#R39950,
; 6=#R39956.
; .
; IN None. OUT None. DESTROYS AF, BC, DE, HL, IY.
@label=hit_processor
c35531 LD A,(46803)  ; Load pending event code from #R46803. Return if none.
 35534 OR A          ; {Return if no event pending.
 35535 RET Z         ; }
 35536 PUSH AF       ; Save event/sound index.
 35537 CP 5          ; {Guard events 5-6: skip visual and score, jump directly
 35539 JP Z,35677    ; to sound dispatch.
 35542 CP 6          ;
 35544 JP Z,35677    ; }
 35547 LD IY,(46804) ; IY = attacker state block pointer from #R46804.
 35551 LD A,(IY+8)   ; A = current animation frame index (IY+8).
 35554 LD HL,46747   ; Search hit-indicator table #R46747 for this frame. Z=1
                     ; if found, DE=row/column data.
 35557 CALL 38325    ; Call #R38325 to search the table.
 35560 JR NZ,35644   ; Frame not in table - skip drawing hit indicator.
 35562 PUSH DE       ; Save DE (row/column data) while computing screen
                     ; address.
 35563 LD E,(IY+3)   ; E = attacker X tile column (IY+3).
 35566 LD D,0        ; D = 0, DE = 16-bit column index.
 35568 LD HL,22848   ; HL = start of attribute row 22848 (screen row for hit
                     ; indicator).
 35571 ADD HL,DE     ; HL += attacker column offset.
 35572 POP DE        ; Restore DE (row offset in D, original X column in E).
 35573 LD A,D        ; {A = D (row offset). If 0, already on the right row.
 35574 OR A          ; }
 35575 JR Z,35584    ; Skip row advance if row offset is 0.
 35577 LD BC,32      ; Advance HL one attribute row (32 bytes) D times.
*35580 ADD HL,BC     ; Advance one row.
 35581 DEC A         ; Decrement row counter.
 35582 JR NZ,35580   ; Loop until row offset consumed.
*35584 BIT 0,(IY+2)  ; Test mirror flag (IY+2 bit 0): determines column
                     ; direction for hit indicator.
 35588 JR Z,35599    ; Not mirrored - column = base + X tile.
 35590 LD C,8        ; Mirrored: shift right 8 columns, then subtract X tile
                     ; (column = base + 8 - X).
 35592 ADD HL,BC     ; HL += 8.
 35593 LD C,E        ; C = X tile column.
 35594 AND A         ; Clear carry before SBC.
 35595 SBC HL,BC     ; HL -= X tile (mirrored column placement).
 35597 JR 35601      ; Jump to boundary check.
*35599 LD C,E        ; Not mirrored: C = X tile column.
 35600 ADD HL,BC     ; HL += X tile (normal column placement).
*35601 LD B,L        ; {Save column byte for boundary check (B = L).
 35602 LD A,L        ; }
 35603 AND 31        ; Mask column to 0-31.
 35605 OR A          ; Skip if column is on a boundary tile (0, 1, 30 or 31).
 35606 JR Z,35644    ; Column 0 - skip.
 35608 CP 1          ; {Column 1 - skip.
 35610 JR Z,35644    ; }
 35612 CP 31         ; {Column 31 - skip.
 35614 JR Z,35644    ; }
 35616 CP 30         ; {Column 30 - skip.
 35618 JR Z,35644    ; }
 35620 LD L,B        ; Restore L from saved column byte B.
 35621 LD A,(HL)     ; {Align column to tile boundary (AND 248) and add
 35622 AND 248       ; 2-column offset.}
 35624 OR 2          ; OR 2: place indicator 2 columns into the tile.
 35626 LD (HL),A     ; Store final VRAM pixel address in HL.
 35627 LD (46806),HL ; Save hit indicator VRAM address to #R46806 for #R35450
                     ; to align each frame.
 35630 LD A,H        ; {Convert pixel address H to attribute area: isolate
 35631 AND 3         ; sector bits (AND 3).}
 35633 RLCA          ; {Shift sector bits left 3 to form attribute page high
 35634 RLCA          ; byte.
 35635 RLCA          ; }
 35636 OR 64         ; OR 64: set attribute page base (0x40xx).
 35638 LD H,A        ; H = attribute address high byte.
 35639 LD A,61       ; A = ASCII 61 (hit indicator glyph, UDG index 13).
 35641 CALL 35996    ; Draw hit indicator glyph at computed screen address via
                     ; #R35996.
*35644 LD A,(IY+8)   ; Reload frame index (IY+8) for score table lookup.
 35647 LD HL,46775   ; Search score-award table #R46775 for this frame. Z=1 if
                     ; found, DE=score delta.
 35650 CALL 38325    ; Call #R38325 to search the table.
 35653 JR NZ,35677   ; Frame not in score table - jump to sound dispatch.
 35655 LD A,IYl      ; A = attacker character type (IYl).
 35657 CP 89         ; Is attacker P1 (type 89)?
 35659 JR Z,35670    ; Yes (P1) - jump to P1 score update at 35670.
 35661 LD HL,(47431) ; P2 path: HL = P2 score buffer #R47431.
 35664 ADD HL,DE     ; Add score delta DE to P2 score.
 35665 LD (47431),HL ; Write updated P2 score to #R47431.
 35668 JR 35677      ; Jump to sound dispatch.
*35670 LD HL,(47429) ; P1 path: HL = P1 score buffer #R47429.
 35673 ADD HL,DE     ; Add score delta DE to P1 score.
 35674 LD (47429),HL ; Write updated P1 score to #R47429.
*35677 XOR A         ; Clear pending event code in #R46803.
 35678 LD (46803),A  ; Write 0 to #R46803.
 35681 POP AF        ; Restore event/sound index from stack.
 35682 CP 1          ; {Sound 1 - kick #R39932.
 35684 JP Z,39932    ; }
 35687 CP 2          ; {Sound 2 - tackle #R39926.
 35689 JP Z,39926    ; }
 35692 CP 3          ; {Sound 3 - slash #R39938.
 35694 JP Z,39938    ; }
 35697 CP 4          ; {Sound 4 - head cut #R39944.
 35699 JP Z,39944    ; }
 35702 CP 5          ; {Sound 5 - guard 1 #R39950.
 35704 JP Z,39950    ; }
 35707 CP 6          ; {Sound 6 - guard 2 #R39956.
 35709 JP Z,39956    ; }
 35712 RET           ; Return.

; Input and AI dispatcher.
;
; Called once per character from #R39617.
;
; .
;
; IY points to the active character state block. Selects between human input
; and AI, or returns immediately if the character is inactive. Human-controlled
; characters read the keyboard/joystick and store the key bitmask in IY+1.
; CPU-controlled characters call #R35765 to generate an AI key bitmask in their
; state block.
; .
; IN IY character state block.
; .
; OUT (IY+1) key state bitmask (human or AI).
; .
; DESTROYS AF, A. IY is preserved on return.
@label=input_ai_dispatcher
c35713 LD A,(IY+0)   ; A = (IY+0) controller type / active flag.
 35716 BIT 7,A       ; Test bit 7: 0 = human-controlled, 1 = CPU-controlled.
 35718 JR NZ,35729   ; If bit 7 set (CPU), branch to AI path at 35729.
 35720 OR A          ; Human path: A = 0 means inactive character.
 35721 RET Z         ; If inactive (IY+0 = 0), return immediately.
 35722 CALL 35825    ; Call #R35825 to read human input for this controller
                     ; type.
 35725 LD (IY+1),A   ; Store key bitmask returned in A into (IY+1).
 35728 RET           ; Return (human-controlled case done).
*35729 LD A,IYl      ; CPU path: A = (IY+1) character type (89=P1, 98=P2).
 35731 CP 89         ; Is this P1 type (89)?
 35733 JR NZ,35750   ; If not P1, branch to P2 AI path at 35750.
 35735 LD A,(46442)  ; Load P1 extra state byte from #R46442 (AI profile /
                     ; difficulty).
 35738 PUSH IY       ; Preserve caller IY.
 35740 LD IY,46425   ; Set IY to P1 state block base #R46425.
 35744 CALL 35765    ; Call #R35765 to run P1 AI and write synthetic key state
                     ; into IY+1.
 35747 POP IY        ; Restore original IY.
 35749 RET           ; Return (CPU-controlled P1 done).
*35750 LD A,(46433)  ; P2 AI path: load P2 extra state byte from #R46433.
 35753 PUSH IY       ; Preserve caller IY.
 35755 LD IY,46434   ; Set IY to P2 state block base #R46434.
 35759 CALL 35765    ; Call #R35765 to run P2 AI and write synthetic key state
                     ; into IY+1.
 35762 POP IY        ; Restore original IY.
 35764 RET           ; Return (CPU-controlled P2 done).

; Character AI engine.
;
; Called by #R35713 with A = extra state byte (#R46442 for P1, #R46433 for P2)
; and IY pointing to the active character state block.
;
; .
;
; Performs a 4-step lookup chain:
; .
; 1. extra state -> AI profile block (#R47798) via pointer table #R47618.
; .
; 2. Fighter distance (#R46834) -> profile column 0-7 via #R47578.
; .
; 3. Profile column -> movement block ID (0-22) -> 8-byte row in #R47974 (x8
; offset).
; .
; 4. R register (pseudo-random, masked 0-31) + fight counter (#R47558) ->
; difficulty entry (#R47559) -> subindex (0-7) -> movement ID from #R47974.
; .
; Maps the movement ID to a key-state bitmask and stores it in IY+1 so the
; movement engine sees it as real input.
; .
; IN  A = extra state byte. IY = character state block.
; .
; OUT (IY+1) = AI-generated key state bitmask.
; .
; DESTROYS AF, BC, DE, HL.
@label=character_ai_engine
c35765 LD HL,47618   ; HL = profile pointer table base #R47618. A = extra state
                     ; index.
 35768 CALL 38304    ; Resolve AI profile pointer via #R38304; HL = profile
                     ; block address in #R47798.
 35771 PUSH HL       ; Preserve profile block pointer.
 35772 LD A,(46834)  ; A = fighter distance #R46834.
 35775 LD HL,47578   ; HL = secondary AI state-to-column table #R47578.
 35778 CALL 38318    ; Map distance to profile column (0-7) via #R38318; A =
                     ; column index.
 35781 POP HL        ; Restore profile block pointer.
 35782 CALL 38318    ; Read movement block ID from profile at column A via
                     ; #R38318; A = block ID (0-22).
 35785 LD DE,8       ; DE = 8 (byte stride per block in #R47974).
 35788 CALL 35976    ; HL = A * 8 via #R35976; byte offset into the movement
                     ; selection table.
 35791 LD DE,47974   ; DE = movement table base #R47974.
 35794 ADD HL,DE     ; HL = table base + offset; points to the selected 8-byte
                     ; movement block.
 35795 PUSH HL       ; Preserve movement block pointer.
 35796 LD A,R        ; A = R register; pseudo-random source.
 35798 AND 31        ; Mask A to 0-31; random index into the difficulty entry.
 35800 PUSH AF       ; Preserve random value.
 35801 LD A,(47558)  ; A = fight counter #R47558 (0-7); difficulty level index.
 35804 LD HL,47559   ; HL = difficulty table base #R47559.
 35807 CALL 38304    ; Resolve difficulty entry pointer for this fight level
                     ; via #R38304.
 35810 POP AF        ; Restore random value.
 35811 CALL 38318    ; Index into difficulty entry using random value via
                     ; #R38318; A = subindex (0-7).
 35814 POP HL        ; Restore movement block pointer.
 35815 CALL 38318    ; Read movement ID from block at subindex A via #R38318; A
                     ; = movement ID.
 35818 CALL 39142    ; Mirror movement ID if necessary, via #R39142
                     ; (input-class table #R47458, mirror-corrected for IY+2
                     ; bit 0).
 35821 LD (IY+1),A   ; Store AI key bitmask in (IY+1).
 35824 RET           ; Return.

; Human controller input reader.
;
; Called by #R35713 with A = controller type (IY+0) and IY pointing to the
; character state block. For keyboard/Sinclair controllers, reads 5 scancodes
; (Fire, Up, Down, Left, Right) from the table for this controller type and
; builds a key-state bitmask.
; .
; For Kempston, reads the joystick port directly. Returns A with bits 0-4 set
; for pressed keys: bit 0 = Right, bit 1 = Left, bit 2 = Down, bit 3 = Up, bit
; 4 = Fire.
;
; .
;
; IN A = controller type (1-5). IY = character state block.
; .
; OUT A = key state bitmask (bits 0-4). (Caller stores it in IY+1).
; .
; DESTROYS AF, BC, DE, HL.
; .
; Scancode tables: 1 = P1 keyboard #R47433, 2 = P2 keyboard #R47440 (Sinclair2
; defaults), 3 = Sinclair2 fixed #R47445 (keys 6-0), 4 = Sinclair1 fixed
; #R47450 (keys 1-5), 5 = Kempston joystick (port 31).
@label=human_input_reader
c35825 LD HL,47433   ; HL = P1 keyboard scancode table #R47433 (default for
                     ; type 1).
 35828 CP 1          ; Is controller type = 1?
 35830 JR Z,35861    ; Yes: use P1 keyboard table at #R47433 (jump to scan
                     ; loop).
 35832 LD HL,47440   ; HL = P2 keyboard scancode table #R47440 (type 2).
 35835 CP 2          ; Is controller type = 2?
 35837 JR Z,35861    ; Yes: use P2 keyboard table at #R47440.
 35839 LD HL,47445   ; HL = Sinclair 2 fixed scancode table #R47445 (type 3).
 35842 CP 3          ; Is controller type = 3?
 35844 JR Z,35861    ; Yes: use Sinclair 2 table at #R47445.
 35846 LD HL,47450   ; HL = Sinclair 1 fixed scancode table #R47450 (type 4).
 35849 CP 4          ; Is controller type = 4?
 35851 JR Z,35861    ; Yes: use Sinclair 1 table at #R47450.
 35853 CP 5          ; Is controller type = 5 (Kempston)?
 35855 RET NZ        ; If controller type is not 1-5, return with A unchanged
                     ; (no input).
 35856 IN A,(31)     ; Read Kempston joystick state from port 31 into A.
 35858 AND 31        ; Mask to lower 5 bits (Right, Left, Down, Up, Fire).
 35860 RET           ; Return with Kempston key state in A.
*35861 LD E,0        ; E = 0 (result accumulator). D = 5 (remaining keys to
                     ; scan).
 35863 LD D,5        ; Start of keyboard scan loop (5 keys).
*35865 LD A,(HL)     ; A = (HL) read next scancode from table.
 35866 INC HL        ; HL++ advance scancode table pointer.
 35867 CALL 35910    ; Test key state via #R35910: Carry=1 released, Carry=0
                     ; pressed.
 35870 CCF           ; CCF invert carry so pressed -> Carry=1.
 35871 RL E          ; RL E rotate carry into E; builds bitmask LSB-first
                     ; (Right,Left,Down,Up,Fire).
 35873 DEC D         ; D- decrement remaining-key counter.
 35874 JR NZ,35865   ; Loop until all 5 keys have been processed.
 35876 LD A,E        ; A = E: copy final key-state bitmask to A.
 35877 RET           ; Return with A = key-state bitmask.

; Keyboard scanner: detects single pressed key for input config (redefine
; keys).
;
; Used by the routine at #R35937.
;
; .
;
; Scans 8 keyboard rows (port 0xFE) to find exactly one keypress. Used by key
; assignment (#R35937) to capture scancodes without conflicts.
; .
; OUT: D=scancode (0-39) or 255 (none/multiple); Z=0 if valid key.
; .
; DESTROYS: AF,BC,DE,H.
@label=keyb_scan
c35878 LD DE,65327   ; D = 255 (no-key sentinel); E = 111b (row/column base
                     ; counter).
 35881 LD BC,65278   ; B = 0xFE (keyboard row mask); C = 0xFE (ULA keyboard
                     ; port).
*35884 IN A,(C)      ; IN A,(C) read 5 key bits for this row from port 0xFE.
 35886 CPL           ; CPL invert bits (active-low): 1 = pressed, 0 = released.
 35887 AND 31        ; AND 31 mask to bits 4-0 (the 5 keys of this row).
 35889 JR Z,35903    ; If no key bits set in this row, jump to next row.
 35891 INC D         ; First key in this scan: INC D makes D = 0.
 35892 RET NZ        ; If D was already 0, a previous row already had a key ->
                     ; two keys pressed; abort and return immediately with D=0,
                     ; Z clear.
 35893 LD H,A        ; H = pressed key bitmask for this row (5 bits).
 35894 LD A,E        ; A = current row/column base (E).
*35895 SUB 8         ; Subtract 8 repeatedly to align A to the correct row base
                     ; slot.
 35897 SRL H         ; SRL H shift key bitmask right; lowest set bit falls into
                     ; carry.
 35899 JR NC,35895   ; If carry clear, no key at this column; loop to check
                     ; next column.
 35901 RET NZ        ; Single column found: return now; D already holds
                     ; scancode.
 35902 LD D,A        ; D = A: store computed scancode (row base + column
                     ; offset).
*35903 DEC E         ; E- advance row/column base for next row.
 35904 RLC B         ; RLC B rotate row mask left to select next keyboard row.
 35906 JR C,35884    ; If more rows remain (carry clear), loop back to read
                     ; next row.
 35908 CP A          ; All rows scanned with no key found: CP A sets Z flag.
 35909 RET Z         ; Return with Z set and D = 255 (no key pressed or
                     ; conflict).

; Key state tester
;
; Used by the routines at #R35240, #R35514, #R35825, #R36130, #R36212 and
; #R36508.
;
; .
;
; Converts the scancode and returns if the key is pressed or not in the carry
; flag.
; .
; INPUT: A the scancode.
; .
; OUTPUT: Current key state in the carry flag (1 released, 0 pressed).
; .
; DESTROYS: A, BC, carry.
@label=key_state_test
c35910 LD C,A        ; C scancode to test.
 35911 AND 7         ; {Extract row index bits 5-3 add 1 to get 1-based row
 35913 INC A         ; number in A and B.}
 35914 LD B,A        ; B row number used as shift counter.
 35915 SRL C         ; {Shift row bits into the low position to isolate the row
 35917 SRL C         ; index in A.
 35919 SRL C         ; }
 35921 LD A,5        ; {Extract column index bits 2-0 into A.
 35923 SUB C         ; }
 35924 LD C,A        ; C column index bit position within the row byte.
 35925 LD A,254      ; Form keyboard port high byte for this row 0xFE base.
*35927 RRCA          ; {Shift row mask B times to select the correct keyboard
 35928 DJNZ 35927    ; half-row port address.}
 35930 IN A,(254)    ; Read 5-key state from the ULA keyboard port into A.
*35932 RRA           ; {Shift right C times to place the target key bit into
 35933 DEC C         ; the carry flag.
 35934 JR NZ,35932   ; }
 35936 RET           ; Returns with carry set key released, carry clear key
                     ; pressed.

; Single-key capture prompt.
;
; Used by the routine at #R36363.
;
; .
;
; Redefining keys, waits for the player to press a key, draws its glyph on
; screen and plays a confirmation sound. Returns the scancode of the chosen key
; in A. Loops indefinitely until a valid key press is detected (D != 255).
; .
; Called from #R36347 in a loop to assign each of the 5 action keys (Fire, Up,
; Down, Left, Right, and optionally Pause and Quit).
; .
; INPUT  HL = VRAM address where the key glyph will be drawn.
; .
; OUTPUT A  = scancode of the selected key.
; .
; DESTROYS AF, BC, DE.
@label=catch_key
c35937 PUSH HL       ; Preserve VRAM address.
 35938 LD A,63       ; Load ASCII 63 ('?') as the prompt glyph.
 35940 CALL 35996    ; Draw '?' at HL via #R35996 to signal awaiting input.
 35943 CALL 39846    ; Short delay via #R39846.
 35946 CALL 35878    ; Scan keyboard via #R35878; D = scancode, or 255 if no
                     ; key pressed.
 35949 POP HL        ; Restore VRAM address.
 35950 LD A,D        ; {If D = 255 (no key), loop back to #R35937.
 35951 CP 255        ;
 35953 JR Z,35937    ; }
 35955 PUSH AF       ; Save scancode.
 35956 PUSH HL       ; Preserve VRAM address.
 35957 LD HL,47476   ; HL = key-glyph lookup table base (#R47476).
 35960 CALL 38318    ; Read display glyph index for this scancode via #R38318.
 35963 POP HL        ; Restore VRAM address.
 35964 CALL 35996    ; Draw the key glyph at HL via #R35996.
 35967 PUSH IX       ; Preserve IX.
 35969 CALL 39944    ; Play confirmation sound via #R39944.
 35972 POP IX        ; Restore IX.
 35974 POP AF        ; Recover scancode into A.
 35975 RET           ; Return with A = scancode of the selected key.

; Binary multiplier. Computes HL = A * DE.
;
; Used by the routine at #R35765.
;
; .
;
; General-purpose 8bits * 16bits unsigned multiply using shift-and-add.
; .
; Iterates 8 times, one per bit of A LSB first. If the current bit is set, adds
; DE to the HL accumulator. DE is left-shifted each iteration to track the
; positional value of each bit.
; .
; Called from #R35765 with DE=8 to compute a byte offset into the AI movement
; table #R47974 (effective result: HL = A * 8).
; .
; INPUT  A  = multiplicand (8-bit unsigned), DE = multiplier (16-bit unsigned).
; .
; OUTPUT HL = A * DE (16-bit result).
; .
; DESTROYS HL, DE, B.
@label=bin_multiply
c35976 LD HL,0       ; {HL = 0 (result accumulator). Test A; return immediately
 35979 OR A          ; if A = 0.
 35980 RET Z         ; }
 35981 LD B,8        ; B = 8 (bit counter, one iteration per bit of A).
*35983 SRL A         ; {Shift A right; bit 0 into carry. If carry clear, skip
 35985 JP NC,35989   ; addition.}
 35988 ADD HL,DE     ; Bit was set: add current positional value DE to
                     ; accumulator HL.
*35989 SLA E         ; {Left-shift DE (SLA E / RL D) to advance to next bit
 35991 RL D          ; position.}
 35993 DJNZ 35983    ; Repeat for all 8 bits.
 35995 RET           ; Return with HL = A * DE.

; Single UDG character renderer
;
; Used by the routines at #R35531, #R35937, #R36022, #R36063, #R39367 and
; #R48896.
;
; .
;
; Draws one 8x8 UDG tile from the font table at #R23720 to a VRAM address. Used
; to render scores, keys glyphs, menu labels and the hit indicator.
; .
; Converts the ASCII code to a font index (SUB 48), multiplies by 8 to get the
; byte offset, and adds the UDG font base to locate the 8-byte tile data.
; Copies one byte per scanline row, calling #R36895 after each row to advance
; to the next VRAM scanline.
; .
; INPUT: A = ASCII code (48+). HL = VRAM destination address. OUTPUT: None.
; .
; DESTROYS: AF, BC, DE, HL.
@label=draw_character
c35996 PUSH HL       ; Preserves the VRAM destination address.
 35997 SUB 48        ; Converts ASCII code to font index (index = A - 48).
 35999 LD L,A        ; {Places font index in HL (L = index, H = 0).
 36000 LD H,0        ; }
 36002 ADD HL,HL     ; {Multiplies font index by 8 to obtain the byte offset
 36003 ADD HL,HL     ; into the font table.
 36004 ADD HL,HL     ; }
 36005 LD DE,23720   ; Loads the UDG font base address #R23720 into DE.
 36008 ADD HL,DE     ; HL now points to the first byte of the font data for
                     ; this character.
 36009 POP DE        ; Restores the VRAM destination address into DE.
 36010 EX DE,HL      ; Swaps registers so HL = VRAM destination, DE = font
                     ; source.
 36011 LD B,8        ; Sets row counter to 8, one iteration per scanline.
*36013 LD A,(DE)     ; {Copies one font scanline byte to the screen.
 36014 LD (HL),A     ; }
 36015 CALL 36895    ; Advances HL to the next VRAM scanline via #R36895.
 36018 INC DE        ; Advances to the next font row.
 36019 DJNZ 36013    ; Repeats for all 8 scanlines.
 36021 RET           ; Return.

; Null-terminated word renderer.
;
; Used by the routines at #R36037 and #R36130.
;
; .
;
; Draws a null-terminated string from DE to screen at HL, one character per
; tile.
; .
; Called by R36037 and R36130 to render individual words within a menu line.
; .
; INPUT: DE = character data address (null-terminated). HL = VRAM destination
; address.
; .
; OUTPUT: HL = VRAM address of the column after the last drawn character. DE:
; points past the null terminator.
; .
; DESTROYS AF, BC, DE, HL.
@label=draw_word
c36022 LD A,(DE)     ; Reads the first character byte into A.
*36023 PUSH DE       ; {Preserves DE and HL before the draw call.
 36024 PUSH HL       ; }
 36025 CALL 35996    ; Draws the character via #R35996.
 36028 POP HL        ; {Restores HL and DE.
 36029 POP DE        ; }
 36030 INC L         ; {Advances HL to the next column and DE to the next
 36031 INC DE        ; character.}
 36032 LD A,(DE)     ; Reads the next character byte.
 36033 OR A          ; Tests for null terminator. (0 = end of word).
 36034 JR NZ,36023   ; Loops back if more characters remain.
 36036 RET           ; Return.

; String line renderer.
;
; Used by the routines at #R36130, #R36212, #R36363 and #R36508.
;
; .
;
; Renders a full line of text composed of multiple words to screen.
; .
; For each index, resolves the word address via #R36053 and draws it via
; #R36022. Stops when index value is 255.
; .
; INPUT: HL = VRAM destination address. DE = string index list address
; (#R48795).
; .
; OUTPUT: None. DESTROYS: HL, DE.
@label=draw_string
c36037 PUSH DE       ; Preserves the index list pointer.
 36038 LD A,(DE)     ; Reads the current word index into A.
 36039 CALL 36053    ; Resolves word index to character data address in DE.
 36042 CALL 36022    ; Draws the word. HL advances to the next free column.
 36045 POP DE        ; Restores the index list pointer.
 36046 INC DE        ; Advances to the next index.
 36047 LD A,(DE)     ; Reads the next index.
 36048 CP 255        ; Tests for end-of-line sentinel (255).
 36050 JR NZ,36037   ; Loops back if more words remain.
 36052 RET           ; Return.

; Word index to address resolver.
;
; Resolves a word index to its character data address from the string pointer
; table at #R48737.
;
; .
;
; INPUT: A = word index. HL = VRAM address.
; .
; OUTPUT: HL = VRAM address (preserved). DE = word data address. DESTROYS:
; None.
@label=word_addr_solver
c36053 PUSH HL       ; Preserves the VRAM address.
 36054 LD HL,48737   ; Loads the string pointer table base #R48737 into HL.
 36057 CALL 38304    ; Resolves the pointer for index A via #R38304; result in
                     ; HL.
 36060 POP DE        ; Recovers the VRAM address into DE.
 36061 EX DE,HL      ; Swaps registers: HL=VRAM address, DE=word address.
 36062 RET           ; Return.

; Decimal number renderer.
;
; Converts an unsigned 16-bit value to decimal digits and draws them using the
; UDG font. Used at #R35426.
;
; .
;
; Extracts each digit from most to least significant using repeated subtraction
; against a divider table pointed by IX (e.g. 10000, 1000, 100, 10, 1). Each
; digit is converted to ASCII (add 48) and drawn via #R35996. Uses the shadow
; register set to preserve the digit count and value across draw calls.
; .
; Callers may set IX before jumping to #R36067 to use a narrower divider table
; (e.g. #R47524 for 2-digit display).
; .
; INPUT: B = number of digits to print (1-5). DE value to convert. HL = start
; VRAM address. IX = divider table address.
; .
; OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX and shadow registers.
@label=print_dec_number
c36063 LD IX,47518   ; Loads the default 5-digit divider table #R47518 into IX;
                     ; callers may skip this instruction by jumping to #R36067
                     ; with a custom IX.
; This entry point is used by the routines at #R35240 and #R36105.
*36067 PUSH BC       ; {Preserves B and DE, switches to shadow registers, moves
 36068 PUSH DE       ; the value into HL and restores the digit count in B.
 36069 EXX           ;
 36070 POP HL        ;
 36071 POP BC        ; }
*36072 LD E,(IX+0)   ; {Loads the current divider into DE and initialises the
 36075 LD D,(IX+1)   ; digit counter C to 255.}
 36078 LD C,255      ; {Clears carry before the subtraction loop.
 36080 AND A         ; }
*36081 SBC HL,DE     ; {Subtracts the divider from HL repeatedly, counting in
 36083 INC C         ; C, until underflow; restores the last valid HL.
 36084 JR NC,36081   ;
 36086 ADD HL,DE     ; }
 36087 LD A,C        ; {Converts the digit count in C to ASCII (add 48) and
 36088 ADD A,48      ; returns to the main register set.
 36090 EXX           ; }
 36091 PUSH HL       ; {Draws the digit via #R35996, then advances HL to the
 36092 CALL 35996    ; next character column.
 36095 POP HL        ;
 36096 INC HL        ; }
 36097 EXX           ; {Switches back to the shadow set and advances IX to the
 36098 INC IX        ; next divider entry.
 36100 INC IX        ; }
 36102 DJNZ 36072    ; Decrements B and loops for the remaining digits.
 36104 RET           ; Return.

; Time or fight counter display updater.
;
; Used by the routines at #R35240 and #R37852.
;
; .
;
; Redraws the 2-digit time HUD every frame.
; .
; If #R46808 is 255 (infinite time, 1P/demo mode), displays the fight counter
; from #R47558 instead.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX.
@label=update_time_display
c36105 LD A,(46808)  ; Loads the round timer from #R46808.
 36108 CP 255        ; Tests for 255 (infinite time mode).
 36110 JR NZ,36115   ; Non-255: uses the timer value directly.
 36112 LD A,(47558)  ; 255: loads the fight counter from #R47558 instead.
*36115 LD HL,16559   ; Sets HL to the 2-digit timer HUD tile address (16559).
 36118 LD E,A        ; {Places the value into DE with high byte 0.
 36119 LD D,0        ; }
 36121 LD B,2        ; Sets B=2 for two digits.
 36123 LD IX,47524   ; Points IX to the 2-digit divider table #R47524.
 36127 JP 36067      ; Tail-calls the decimal printer at #R36067.

; Main Menu loop
;
; Used by the routine at #R35240.
;
; .
;
; Draws the main menu text and runs the rainbow colour animation loop until a
; valid option key (0-3) is pressed.
; .
; On selection jumps to the corresponding game mode: 0=demo, 1=1P, 2=2P,
; 3=developer info screen.
; .
; INPUT  None. OUTPUT None (tail-calls game mode entry points).
; .
; DESTROYS AF, BC, DE, HL.
@label=main_menu
c36130 CALL 38699    ; Fade out any previous screen content to black via
                     ; #R38699.
; This entry point is used by the routines at #R36212, #R36363 and #R36508.
*36133 LD HL,18501   ; Set HL to the top menu text position 18501.
 36136 LD DE,48795   ; Point DE to the first menu string pointer #R48795
                     ; ("SELECT OPTION").
 36139 CALL 36037    ; Draw the string via #R36037.
 36142 LD HL,18566   ; Advance to next line position 18566.
 36145 INC DE        ; Advance to next string pointer.
 36146 CALL 36037    ; Draw "0 DEMO".
 36149 LD HL,18598   ; Advance to next line 18598.
 36152 INC DE        ; Advance to next string.
 36153 CALL 36037    ; Draw "1 ONE PLAYER".
 36156 LD HL,18630   ; Advance to next line 18630.
 36159 INC DE        ; Advance to next string.
 36160 CALL 36037    ; Draw "2 TWO PLAYER".
 36163 CALL 36706    ; Run the rainbow animation #R36706.
*36166 CALL 33840    ; Play music and wait for any key via #R33840.
 36169 LD A,35       ; {Test for '0' key scancode 35 via #R35910.
 36171 CALL 35910    ; }
 36174 JP NC,36673   ; Jump to demo mode #R36673 if pressed.
 36177 LD A,36       ; {Test for '1' key scancode 36.
 36179 CALL 35910    ; }
 36182 JR NC,36212   ; Jump to 1P mode #R36212 if pressed.
 36184 LD A,28       ; {Test for '2' key scancode 28.
 36186 CALL 35910    ; }
 36189 JP NC,36508   ; Jump to 2P mode #R36508 if pressed.
 36192 LD A,20       ; {Test for '3' key scancode 20.
 36194 CALL 35910    ; }
 36197 JR C,36166    ; Loop back if not pressed.
 36199 LD HL,18501   ; For option 3: set HL back to top position 18501.
 36202 PUSH DE       ; Preserve DE.
 36203 LD DE,48662   ; Point DE to developer string #R48662 ("FINAL
                     ; V8:5>11>87").
 36206 CALL 36022    ; Draw it via #R36022 (overwrites "SELECT OPTION").
 36209 POP DE        ; Restore DE.
 36210 JR 36166      ; Loop back to animation and key wait.

; One-player mode selector.
;
; Used by the routine at #R36130.
;
; .
;
; Entered from main menu #R36130 when '1' key pressed.
; .
; Replaces "0 DEMO" menu label with "0 START GAME", enables P1 energy loss,
; sets infinite time, configures P1 human/P2 CPU control.
; .
; Then shows controller sub-menu (Sinclair2/Kempston/Keyboard) and jumps to
; main loop on selection.
; .
; INPUT  None. OUTPUT None (tails to fadeout or key assignment). DESTROYS AF.
@label=one_player_mode
c36212 LD A,25       ; A=25: "START GAME" string index #R48737.
 36214 LD (48799),A  ; Patch #R48798 from 28 ("0 DEMO") to 25 ("0 START GAME").
 36217 XOR A         ; A=0 (NOP opcode).
 36218 LD (39371),A  ; Self-modify #R39371 RET Z->NOP: enables P1 energy
                     ; depletion.
 36221 LD A,255      ; A=255.
 36223 LD (46808),A  ; Set #R46808=255 (infinite time, 1P mode).
 36226 LD A,(46425)  ; Load #R46425 (P1 control byte).
 36229 AND 127       ; AND $7F: clear bit 7 (P1 human-controlled).
 36231 LD (46425),A  ; Store back to #R46425.
 36234 LD A,(46434)  ; Load #R46434 (P2 control byte).
 36237 OR 128        ; OR $80: set bit 7 (P2 CPU-controlled).
 36239 LD (46434),A  ; Store back to #R46434.
 36242 CALL 36673    ; Fade out via #R36673.
 36245 LD HL,18566   ; HL=18566: controller sub-menu position 1.
 36248 LD DE,48809   ; DE=#R48809: controller strings table.
 36251 CALL 36037    ; Draw first option via #R36037.
 36254 LD HL,18598   ; HL=18598: position 2.
 36257 INC DE        ; Next string index.
 36258 CALL 36037    ; Draw second option.
 36261 LD HL,18630   ; HL=18630: position 3.
 36264 INC DE        ; Next string index.
 36265 CALL 36037    ; Draw third option.
 36268 CALL 36706    ; Rainbow animation #R36706.
*36271 LD A,36       ; Test '1' scancode 36.
 36273 CALL 35910    ; Check pressed via #R35910.
 36276 JR NC,36294   ; Jump to Sinclair2 if pressed.
 36278 LD A,28       ; Test '2' scancode 28 (Kempston).
 36280 CALL 35910    ; Check pressed.
 36283 JR NC,36305   ; Jump to Kempston if pressed.
 36285 LD A,20       ; Test '3' scancode 20 (Keyboard).
 36287 CALL 35910    ; Check pressed.
 36290 JR NC,36316   ; Jump to keyboard setup if pressed.
 36292 JR 36271      ; No key pressed: loop back to animation+key test.
*36294 LD A,3        ; Sinclair2 path: A=3 (type 3, Sinclair Interface 2, port
                     ; 2, keys 6-0).
 36296 LD (46425),A  ; Write controller type 3 to P1 state #R46425.
 36299 CALL 36673    ; Fade out via #R36673.
 36302 JP 36133      ; Jump back to main menu loop #R36133.
*36305 LD A,5        ; Kempston path: A=5 (type 5, Kempston joystick, port 31).
 36307 LD (46425),A  ; Write controller type 5 to P1 state #R46425.
 36310 CALL 36673    ; Fade out via #R36673.
 36313 JP 36133      ; Jump back to main menu loop #R36133.
; This entry point is used by the routine at #R36508.
*36316 XOR A         ; Custom keyboard path: A=0.
 36317 LD (47439),A  ; Clear quit key scancode #R47439 (will be
                     ; player-assigned).
 36320 LD (47438),A  ; Clear pause key scancode #R47438 (will be
                     ; player-assigned).
 36323 LD IX,47433   ; IX=#R47433: P1 keyboard scancode table base.
 36327 LD A,1        ; {Write type 1 (P1 keyboard) to P1 state #R46425.
 36329 LD (46425),A  ; }
 36332 LD A,(46434)  ; {Get #R46434 (P2 control byte) and sets as
 36335 SET 7,A       ; CPU-controlled (SET 7,A).}
 36337 LD (46434),A  ; Store back to #R46434.
 36340 LD A,1        ; {Write "1 " to Menu String #R48824 so it will be printed
 36342 LD (48824),A  ; "SELECT KEYS PLAYER1".}
 36345 JR 36363      ; Jump to shared key assignment loop #R36363.

; P2 controller setup for key-assignment.
;
; Used by the routine at #R36508.
;
; .
;
; Sets P2 controller type to Keyboard and jumps to #R36363 to define keyboard.
; .
; Called from #R36508 (2P mode, options 2 and 3: P1 Sinclair + P2 Keyboard, P1
; Kempston + P2 Keyboard).
; .
; INPUT: None. OUTPUT: None (falls through to #R36363). DESTROYS: AF, IX.
@label=control_setup
c36347 LD IX,47440   ; IX=#R47440: P2 keyboard scancodes table.
 36351 LD A,2        ; {Write controller type 2 (P2 keyboard) to P2 state block
 36353 LD (46434),A  ; #R46434.}
 36356 LD A,2        ; {Write "2 " to Menu String #R48824 so it will be printed
 36358 LD (48824),A  ; "SELECT KEYS PLAYER2".}
 36361 JR 36363      ; Jump to shared key-assignment loop at #R36363.

; Key assignment loop.
;
; Used by the routines at #R36212 and #R36347.
;
; .
;
; Draws the key-assignment screen using the string table at #R48820, then
; captures 5 action keys (Fire, Up, Down, Left, Right) storing each scancode
; into consecutive bytes of the IX table via #R35937.
; .
; Pause (#R47438) and Quit (#R47439) are captured conditionally: only if their
; buffer is 0.
; .
; After all keys are captured, waits ~1.57s (14 x 112ms) then fades to black
; via #R36673 and jumps back to the main menu loop at #R36133.
; .
; NOTE: The CALL at #R36502 is temporarily patched to RET (0xC9) by #R36508
; option "4" so that P1 key capture returns here instead of jumping to #R36133,
; allowing a second call to #R36347 for P2 key capture.
; .
; INPUT: IX = target scancode table (#R47433 P1 keyboard or #R47440 P2
; keyboard).
; .
; OUTPUT: IX table filled with captured scancodes. #R47438 and #R47439 updated.
; .
; DESTROYS: AF, BC, DE, HL, IX.
@label=key_assign
c36363 CALL 36673    ; Fades out current screen.
 36366 LD HL,18501   ; HL = 18501 (title row VRAM address).
 36369 LD DE,48820   ; DE = #R48820 (key-assignment screen string index table).
 36372 CALL 36037    ; Draws title string. "SELECT KEYS PLAYER"
 36375 LD HL,18566   ; HL = 18566 (screen address).
 36378 INC DE        ; Advances DE to next string index.
 36379 LD B,4        ; B = 4 (four loops).
*36381 PUSH BC       ; {Preserves BC and HL.
 36382 PUSH HL       ; }
 36383 CALL 36037    ; Draws string key during 4 loops (Fire, Up, Down, Left).
 36386 POP HL        ; Restores HL.
 36387 LD BC,32      ; BC = 32 (one screen row width).
 36390 ADD HL,BC     ; Advances HL to next row.
 36391 INC DE        ; Advances DE to next string index.
 36392 POP BC        ; Restores BC.
 36393 DJNZ 36381    ; Loops 4 times.
 36395 LD HL,20486   ; HL = 20486 (Fire label row, lower third of screen).
 36398 CALL 36037    ; Draws Right key label ("KEY FOR RIGHT").
 36401 LD HL,20518   ; HL = 20518 (Pause label row).
 36404 INC DE        ; Advances DE to next string index.
 36405 CALL 36037    ; Draws Pause key label.
 36408 LD HL,20550   ; HL = 20550 (Quit label row).
 36411 INC DE        ; Advances DE to next string index.
 36412 CALL 36037    ; Draws Quit key label.
 36415 CALL 36706    ; Draws rainbow colour animation.
 36418 LD HL,18582   ; HL = 18582 (VRAM slot for first key glyph).
 36421 LD B,4        ; B = 4 (key capture counter).
*36423 PUSH BC       ; {Preserves BC and HL.
 36424 PUSH HL       ; }
 36425 CALL 35937    ; Captures key: waits for keypress, draws glyph, returns
                     ; scancode in A.
 36428 LD (IX+0),A   ; Stores scancode in current table slot.
 36431 INC IX        ; Advances IX to next table slot.
 36433 POP HL        ; Restores HL.
 36434 CALL 39846    ; Short delay.
 36437 CALL 39846    ; Short delay.
 36440 LD BC,32      ; BC = 32 (one screen row).
 36443 ADD HL,BC     ; Advances HL to next VRAM capture slot.
 36444 POP BC        ; Restores BC.
 36445 DJNZ 36423    ; Loops 4 times for capture the keys.
 36447 LD HL,20502   ; HL = 20502 (VRAM slot for Right key glyph).
 36450 CALL 35937    ; Captures RIGHT key.
 36453 LD (IX+0),A   ; Stores Right scancode in table slot.
 36456 CALL 39846    ; Short delay.
 36459 CALL 39846    ; Short delay.
 36462 LD A,(47438)  ; Reads Pause scancode buffer.
 36465 OR A          ; Tests if unassigned (0).
 36466 LD HL,20534   ; HL = 20534 (VRAM slot for Pause key glyph).
 36469 CALL Z,35937  ; Captures Pause key if unassigned.
 36472 LD (47438),A  ; Stores Pause scancode.
 36475 CALL 39846    ; Short delay.
 36478 CALL 39846    ; Short delay.
 36481 LD A,(47439)  ; Reads Quit scancode buffer.
 36484 OR A          ; Tests if unassigned (0).
 36485 LD HL,20566   ; HL = 20566 (VRAM slot for Quit key glyph).
 36488 CALL Z,35937  ; Captures Quit key if unassigned.
 36491 LD (47439),A  ; Stores Quit scancode.
 36494 LD A,14       ; A = 14 (delay loop counter).
*36496 CALL 39846    ; Delays 112ms.
 36499 DEC A         ; Decrements counter.
 36500 JR NZ,36496   ; Loops 14 times (1.57s total).
 36502 CALL 36673    ; Fades to black and returns to main menu loop. Patched to
                     ; RET by #R36508 during P1 key capture in 2P mode,
                     ; redirecting control back here instead of jumping to
                     ; #R36133.
 36505 JP 36133      ; Returns to main menu loop.

; Two-player mode selector.
;
; Entered from main menu #R36130 when '2' key pressed.
;
; .
;
; Replaces "0 DEMO" menu label with "0 START GAME", enables P1 energy loss,
; sets 90-second timer, configures both players human-controlled. Shows
; extended 5-option controller sub-menu and handles key assignment as needed.
; .
; INPUT: None. OUTPUT: None (tails to fadeout or key assignment). DESTROYS: AF.
@label=two_player_mode
c36508 LD A,25       ; A=25: "START GAME" string index (#R48737).
 36510 LD (48799),A  ; Patch #R48798 from 28 ("0 DEMO") to 25 ("0 START GAME").
 36513 XOR A         ; A=0 (NOP opcode).
 36514 LD (39371),A  ; Self-modify #R39371 RET Z->NOP: enables P1 energy
                     ; depletion.
 36517 LD A,90       ; A=90.
 36519 LD (46808),A  ; Set #R46808=90 (countdown timer, 2P mode).
 36522 LD A,(46425)  ; Load #R46425 (P1 control byte).
 36525 AND 127       ; AND $7F: clear bit 7 (P1 human-controlled).
 36527 LD (46425),A  ; Store back to #R46425.
 36530 LD A,(46434)  ; Load #R46434 (P2 control byte).
 36533 AND 127       ; AND $7F: clear bit 7 (P2 human-controlled).
 36535 LD (46434),A  ; Store back to #R46434.
 36538 CALL 36673    ; Fade out via #R36673.
 36541 LD HL,18501   ; HL=18501: controller sub-menu position 1.
 36544 LD DE,48854   ; DE=#R48854: 2P controller strings table.
 36547 CALL 36037    ; Draw first option via #R36037.
 36550 LD HL,18566   ; HL=18566: position 2.
 36553 INC DE        ; Next string index.
 36554 CALL 36037    ; Draw second option.
 36557 LD HL,18598   ; HL=18598: position 3.
 36560 INC DE        ; Next string index.
 36561 CALL 36037    ; Draw third option.
 36564 LD HL,18630   ; HL=18630: position 4.
 36567 INC DE        ; Next string index.
 36568 CALL 36037    ; Draw fourth option.
 36571 LD HL,18662   ; HL=18662: position 5.
 36574 INC DE        ; Next string index.
 36575 CALL 36037    ; Draw fifth option.
 36578 CALL 36706    ; Rainbow animation #R36706.
*36581 LD A,36       ; Test '1' scancode 36 (P1 Sinclair + P2 Sinclair).
 36583 CALL 35910    ; Check pressed via #R35910.
 36586 JR NC,36612   ; Jump to Both Sinclair Joystick setup.
 36588 LD A,28       ; Test '2' scancode 28 (P1 Sinclair + P2 Keyboard).
 36590 CALL 35910    ; Check pressed.
 36593 JP NC,36627   ; Jump to P1 Sinclair + P2 keys.
 36596 LD A,20       ; Test '3' scancode 20 (P1 Kempston + P2 Keyboard).
 36598 CALL 35910    ; Check pressed.
 36601 JR NC,36642   ; Jump to P1 Kempston + P2 keys.
 36603 LD A,12       ; Test '4' scancode 12 (P1 keyboard + P2 Keyboard).
 36605 CALL 35910    ; Check pressed.
 36608 JR NC,36657   ; Jump to Both keyboards setup.
 36610 JR 36581      ; Loop back if no key.
; Sets controller type and jumps to Control Setup.
*36612 CALL 36673    ; Menu fade out #R36673. (Both Sinclair)
 36615 LD A,3        ; A=3: P1=Sinclair (port 2).
 36617 LD (46425),A  ; Store to #R46425.
 36620 INC A         ; A=4: P2=Sinclair (port 1).
 36621 LD (46434),A  ; Store to #R46434.
 36624 JP 36133      ; Jump to Main menu #R36133.
*36627 LD A,3        ; P1 Sinclair2 + P2 Keyboard: A=3.
 36629 LD (46425),A  ; Store to #R46425.
 36632 XOR A         ; A=0.
 36633 LD (47439),A  ; Clear #R47439 (quit key).
 36636 LD (47438),A  ; Clear #R47438 (pause key).
 36639 JP 36347      ; Jump to P2 key assignment #R36347.
*36642 LD A,5        ; P1 Kempston + P2 Keyboard: A=5.
 36644 LD (46425),A  ; Store to #R46425.
 36647 XOR A         ; A=0.
 36648 LD (47439),A  ; Clear #R47439 (quit).
 36651 LD (47438),A  ; Clear #R47438 (pause).
 36654 JP 36347      ; Jump to P2 key assignment #R36347.
*36657 LD A,201      ; Both keyboards: A=$C9 (RET opcode).
 36659 LD (36502),A  ; Patch #R36502 CALL converts to RET (stay after P1 keys).
 36662 CALL 36316    ; P1 keyboard assignment #R36316.
 36665 LD A,205      ; A=$CD (CALL opcode).
 36667 LD (36502),A  ; Restore #R36502 CALL.
 36670 JP 36347      ; Jump to P2 key assignment #R36347.

; Menu fade-out transition.
;
; Used by the routines at #R36130, #R36212, #R36363 and #R36508.
;
; .
;
; Gradually darkens the menu by decrementing the ink attribute of three rows
; over 7 steps with 112ms delay between each step, producing a fade-to-black
; effect. Then self-modifies #R39846 to skip its internal wait, clears the
; screen instantly, and restores #R39846 to its original value before
; returning.
; .
; Called from #R36130 when transitioning away from the menu screen.
; .
; DESTROYS AF, BC, HL.
@label=menu_fade_out
c36673 LD B,7        ; 7-step fade loop counter (3 rows each loop).
*36675 PUSH BC       ; Saves the loop counter.
 36676 LD HL,22754   ; Points to the first tile of the game window.
 36679 INC HL        ; Adds 1.
 36680 LD BC,6671    ; B=26 (Columns), C=3 (Rows).
 36683 CALL 38640    ; Decrements ink of three menu rows.
 36686 CALL 39846    ; Waits 112ms.
 36689 POP BC        ; Restores the loop counter.
 36690 DJNZ 36675    ; Repeats until counter reaches 0.
 36692 LD A,201      ; {Self-modifying code: patches #R39846 with RET so the
 36694 LD (39846),A  ; wait is skipped.}
 36697 CALL 38699    ; Clears the screen without waiting.
 36700 LD A,1        ; {Restores #R39846 to its original value.
 36702 LD (39846),A  ; }
 36705 RET           ;

; Menu rainbow colour animation.
;
; Cycles 7 times (112 ms each), incrementing ink tint across 7 menu rows: white
; -> yellow -> cyan -> green -> magenta -> green -> cyan (pause/quit
; conditional).
@label=rainbow_animation
c36706 LD B,7        ; Set a counter of 7 loops.
*36708 PUSH BC       ; Preserves the counter.
 36709 CALL 39846    ; Waits 112 ms.
 36712 LD A,7        ; Target ink colour: white (7).
 36714 LD HL,22853   ; First attribute row base address for this colour step.
 36717 LD BC,5377    ; B=21 tiles per row, C=1 row to step.
 36720 CALL 38664    ; Advance ink colour toward the target value via R38664.
 36723 DEC A         ; Target ink colour: yellow (6).
 36724 LD HL,22918   ; Set the initial screen address to colour.
 36727 CALL 38664    ; Increments in 1 the attribute ink.
 36730 ADD HL,DE     ; Selects the next line below.
 36731 DEC A         ; Target ink colour: cyan (5).
 36732 CALL 38664    ; Increments in 1 the attribute ink.
 36735 ADD HL,DE     ; Selects the next line below.
 36736 DEC A         ; Target ink colour: green (4).
 36737 CALL 38664    ; Increments in 1 the attribute ink.
 36740 ADD HL,DE     ; Selects the next line below.
 36741 DEC A         ; Target ink colour: magenta (3).
 36742 CALL 38664    ; Increments in 1 the attribute ink.
 36745 ADD HL,DE     ; Selects the next line below.
 36746 INC A         ; Target ink colour: green (4).
 36747 CALL 38664    ; Increments in 1 the attribute ink.
; These two attribute writes only fire if #R47439 quit and #R47438 pause
; scancodes are still 0 not yet assigned. In practice both are non-zero during
; normal gameplay, so these rows are never coloured at runtime. They would only
; activate before any key assignment has occurred.
 36750 ADD HL,DE     ; Selects the next line below.
 36751 INC A         ; Target ink colour: cyan (5) - conditional on pause/quit
                     ; unassigned.
 36752 LD E,A        ; {Compares if #R47439 is 0 (now is 032).
 36753 LD A,(47439)  ;
 36756 OR A          ;
 36757 LD A,E        ; }
 36758 CALL Z,38664  ; If is 0 increments in 1 the attribute ink.
 36761 ADD HL,DE     ; Selects the next line below.
 36762 INC A         ; Target ink colour: cyan (5) - conditional on pause/quit
                     ; unassigned.
 36763 LD E,A        ; {Compares if #R47438 is 0 (now is 024).
 36764 LD A,(47438)  ;
 36767 OR A          ;
 36768 LD A,E        ; }
 36769 CALL Z,38664  ; If is 0 increments in 1 the attribute ink.
; End of the routine.
 36772 POP BC        ; Recovers BC
 36773 DJNZ 36708    ; Repeats the routine 7 times.
 36775 RET           ; Returns.

; Reset P1 state block for new round.
;
; Called by #R37631 after P2 death and by #R37663 after P1 death.
;
; .
;
; Resets player 1 to its initial combat state at the start of each round. Sets
; position and energy via #R36822, then clears the mirror flag so player 1
; always starts facing right (towards the P2).
; .
; INPUT: None, OUTPUT: None, DESTROYS: AF.
@label=reset_p1_state_block
c36776 LD IY,46425   ; {IY = #R46425 (player 1 state block). A = 0 as movement
 36780 XOR A         ; ID for #R36822.}
 36781 CALL 36822    ; Reset position to tile 0 (left side) and energy to 13
                     ; via #R36822.
 36784 LD A,(46427)  ; {Read #R46427 mirror/flags byte, clear bit 0 (mirror
 36787 RES 0,A       ; flag) so player 1 faces right at round start, write back
 36789 LD (46427),A  ; to #R46427.}
 36792 RET           ; Return.

; Reset P2 state block for new round.
;
; Called from #R35240 at game start and from #R37631/#R37645 at the end of each
; fight, after the winning sequence completes.
;
; .
;
; Increments the fight counter then place the P2 at right sid) with full energy
; and movement 28 (enter the arena), and sets bit 0 of IY+2 so the P2 starts
; mirrored (facing left, towards player 1).
; .
; Symmetric counterpart to #R36776 which resets player 1 at tile 0, mirror flag
; cleared (facing right).
@label=reset_p2_state_block
c36793 LD A,(47558)  ; {Increment fight counter #R47558; if 7 skip write.
 36796 INC A         ;
 36797 CP 8          ;
 36799 JR Z,36804    ;
 36801 LD (47558),A  ; }
*36804 LD IY,46434   ; { Points P2 state block (#R46434); Sets A=23 (rightmost
 36808 LD A,23       ; tile); call #R36822 to reset position and energy.
 36810 CALL 36822    ; }
 36813 LD A,(46436)  ; { Set P2 mirror flag: SET 0 on IY+2 (#R46436) so P2
 36816 SET 0,A       ; faces left towards P1.
 36818 LD (46436),A  ; }
 36821 RET           ;  Return.

; Character position and energy reset.
;
; Used by the routines at #R36776 and #R36793.
;
; .
;
; Writes A to IY+3 (X tile position), applies movement 28 (idle stand) via
; #R36838, sets IY+7 to 13 (full energy), then tail-calls #R39367 to
; immediately refresh the on-screen energy bar.
; .
; INPUT:  A =starting X tile position (0=left for P1, 23=right for P2). IY =
; character state block (#R46425 or #R46434).
; .
; OUTPUT: None. DESTROYS AF, BC.
@label=pos_energy_reset
c36822 LD (IY+3),A   ;  Write A to IY+3: place character at starting X tile.
 36825 LD A,28       ; { Apply movement 28 (enter the arena) to IY via #R36838.
 36827 CALL 36838    ; }
 36830 LD A,13       ; { Set IY+7 to 13: full energy.
 36832 LD (IY+7),A   ; }
 36835 JP 39367      ;  Call #R39367 to redraw the energy bar.

; Set character movement.
;
; Used by the routines at #R36822, #R37536, #R37701, #R37772, #R37866, #R39194,
; #R39367, #R39617, #R39968 and #R40077.
;
; .
;
; Changes and stores the active movement ID for the character pointed by IY
; (#R36776 or #R36793).
; .
; Updates the mirror flag, stores the new frame data pointer and stores it.
; .
; INPUT: A = new movement ID. IY = character state block.
; .
; OUTPUT: IY = character state block with updated mirror flag (IY+2), frame
; pointer (IY+4, IY+5) initial frame index (IY+8). DESTROYS: AF, BC.
@label=set_char_moves
c36838 LD B,(IY+6)   ; {Load current movement ID from IY+6 into B; compare with
 36841 CP B          ; A. Return if equal (no change).
 36842 RET Z         ; }
; This entry point is used by the routine at #R37536.
*36843 PUSH HL       ; {Preserve HL and A.
 36844 PUSH AF       ; }
 36845 CALL 39245    ; Call #R39245: reads movement properties byte from table
                     ; at #R44755 using A as index.
 36848 LD B,(IY+2)   ; {Load IY+2 (mirror/flags) into B; AND result with bit 7
 36851 AND 128       ; only; merge with B; store back to IY+2.
 36853 OR B          ;
 36854 LD (IY+2),A   ; }
 36857 POP AF        ; Recover A (new movement ID).
 36858 LD (IY+6),A   ; Store new movement ID in IY+6.
 36861 LD HL,44421   ; Load #R44421 (movement frame pointer table) into HL.
 36864 CALL 38304    ; Call #R38304: resolve 2-byte pointer from table using A
                     ; as index; result in HL.
 36867 LD (IY+4),L   ; {Store resolved frame pointer low byte in IY+4, high
 36870 LD (IY+5),H   ; byte in IY+5.}
 36873 LD A,(HL)     ; {Read first byte of frame data into A; store as initial
 36874 LD (IY+8),A   ; frame index in IY+8.}
 36877 POP HL        ; Recover HL.
 36878 RET           ; Return.

; Calculates the VRAM address of the scanline above.
;
; Given a VRAM scanline address in HL, steps back one scanline, handling
; tile-row and screen-third boundaries in the non-linear ZX Spectrum screen
; layout.
;
; .
;
; INPUT: HL = current VRAM scanline address. OUTPUT: HL = address of the
; scanline above. DESTROYS: A, F.
@label=calc_prev_scanline_addr
c36879 DEC H         ; Steps back one scanline (H = $100, 256 bytes).
 36880 LD A,H        ; {Checks whether the decrement crossed a tile boundary
 36881 CPL           ; (lower 3 bits of H become 7 when wrapping backward).
 36882 AND 7         ; }
 36884 RET NZ        ; Within the same tile; address is ready.
 36885 LD A,L        ; {Moves up one tile row (L encodes the tile row; subtract
 36886 SUB 32        ; 32 to reach the row above).
 36888 LD L,A        ; }
 36889 RET C         ; Tile-row underflow carried into the screen-third;
                     ; address is ready.
 36890 LD A,H        ; {No carry; the screen-third was over-decremented - adds
 36891 ADD A,8       ; 8 to H to correct it.
 36893 LD H,A        ; }
 36894 RET           ; Return.

; Calculates the VRAM address of the scanline below.
;
; Given a VRAM scanline address in HL, steps forward one scanline, handling
; tile-row and screen-third boundaries in the non-linear ZX Spectrum screen
; layout.
;
; .
;
; INPUT: HL = current VRAM scanline address. OUTPUT: HL = address of the
; scanline below. DESTROYS: A, F.
@label=calc_next_scanline_addr
c36895 INC H         ; Steps forward one scanline (H encodes the scanline index
                     ; within the tile).
 36896 LD A,H        ; {Checks whether the increment crossed a tile boundary
 36897 AND 7         ; (lower 3 bits of H become 0 when wrapping forward).}
 36899 RET NZ        ; Within the same tile; address is ready.
 36900 LD A,L        ; {Moves down one tile row (L encodes the tile row; add 32
 36901 ADD A,32      ; to reach the row below).
 36903 LD L,A        ; }
 36904 RET C         ; Tile-row overflow carried into the screen-third; address
                     ; is ready.
 36905 LD A,H        ; {No carry; the screen-third was over-incremented -
 36906 SUB 8         ; subtracts 8 from H to correct it.
 36908 LD H,A        ; }
 36909 RET           ; Return.

; Tile render engine.
;
; Used by the routines at #R37449, #R38103 and #R38137.
;
; .
;
; Reads one tile control byte from the source address and dispatches to one of
; four renderers based on its bit fields.
; .
; Control byte: bit 7 = composite tile flag; bits 1-0 = render mode (00 direct
; copy, 11 AND-mask overlay, 01/10 edge mask); bit 6 = mirror flag, swaps left
; and right edge renderers when set.
; .
; INPUT: DE = tile data address. HL = framebuffer destination address. OUT:
; None. DESTROYS: AF, B, C.
@label=tile_render_engine
c36910 LD A,(DE)     ; {Reads the control byte from the tile source and
 36911 INC E         ; advances the address.}
 36912 BIT 7,A       ; {Bit 7 set: composite tile - dispatches to #R37218.
 36914 JP NZ,37218   ; }
 36917 LD C,A        ; {Isolates bits 1-0; dispatches to AND-mask overlay
 36918 AND 3         ; (#R37159) if bits 1-0 are 11.
 36920 CP 3          ;
 36922 JP Z,37159    ; }
 36925 OR A          ; {Dispatches to direct-copy renderer (#R37331) if bits
 36926 JP Z,37331    ; 1-0 are 00.}
 36929 LD A,C        ; {Restores the control byte; if the mirror flag (bit 6)
 36930 BIT 6,A       ; is set, flips bits 1-0 to swap left and right edge
 36932 JR Z,36936    ; renderers.
 36934 XOR 3         ; }
*36936 BIT 0,A       ; {Bit 0 set: dispatches to the AND-mask loop renderer
 36938 JP NZ,36996   ; (#R36996).}
 36941 LD B,21       ; B=21 (scanline counter)
; Left-edge AND-mask renderer loop (21 scanlines).
; .
; Outer loop for the left-edge AND-mask tile renderer. Calls #R36949 21 times
; (B=21), once per scanline of the tile.
@label=left_edge_loop
*36943 CALL 36949    ; Render one scanline via #R36949 (left-edge AND-mask
                     ; renderer)
 36946 DJNZ 36943    ; Loop 21 times
 36948 RET           ; Return

; Left-edge AND-mask tile renderer.
;
; Used by the routines at #R36910 and #R37159.
;
; .
;
; Renders one scanline of a 3-byte-wide tile. Scans each byte for transparency
; (0xFF); the first visible byte receives a left-edge column mask via #R37057,
; and any remaining visible bytes are written directly to the framebuffer.
; .
; Called 21 times per tile by the outer loop at #R36943. On return, DE and HL
; point to the start of the next scanline.
; .
; INPUT: DE = tile source address (within a single 256-byte page). HL =
; framebuffer destination. OUTPUT: None. DESTROYS: AF, C.
@label=left_edge_renderer
c36949 LD C,255      ; Sets 0xFF as the transparent sentinel.
 36951 LD A,(DE)     ; {Reads byte 0; if not transparent, applies the left-edge
 36952 CP C          ; column mask via #R37057; otherwise skips to the byte-1
 36953 JR Z,36960    ; check.
 36955 CALL 37057    ; }
 36958 JR 36980      ; Byte 0 masked: jumps to write bytes 1 and 2 directly.
*36960 INC E         ; {Byte 0 transparent: reads byte 1; if not transparent,
 36961 INC L         ; applies the left-edge mask via #R37057; otherwise skips
 36962 LD A,(DE)     ; to the byte-2 check.
 36963 CP C          ;
 36964 JR Z,36971    ;
 36966 CALL 37057    ; }
 36969 JR 36984      ; Byte 1 masked: jumps to write byte 2 directly.
*36971 INC E         ; {Bytes 0 and 1 transparent: reads byte 2 and applies the
 36972 INC L         ; mask if visible; falls through to the scanline advance.
 36973 LD A,(DE)     ;
 36974 CP C          ;
 36975 CALL NZ,37057 ;
 36978 JR 36988      ; }
*36980 INC E         ; {Writes the remaining visible bytes directly to the
 36981 INC L         ; framebuffer without masking.
 36982 LD A,(DE)     ;
 36983 LD (HL),A     ;
*36984 INC E         ;
 36985 INC L         ;
 36986 LD A,(DE)     ;
 36987 LD (HL),A     ; }
*36988 PUSH DE       ; {Advances the framebuffer destination 30 bytes to the
 36989 LD DE,30      ; next scanline and steps the source pointer past this
 36992 ADD HL,DE     ; scanline.
 36993 POP DE        ;
 36994 INC E         ;
 36995 RET           ; }

; Right-edge AND-mask renderer loop (21 scanlines)
;
; Used by the routine at #R36910.
;
; .
;
; Outer loop for the right-edge AND-mask tile renderer. Calls #R37004 21 times
; (B=21), once per scanline of the tile.
@label=right_edge_loop
c36996 LD B,21       ; B=21 (scanline counter).
; This entry point is used by the routine at #R37296.
*36998 CALL 37004    ; Render one scanline via #R37004.
 37001 DJNZ 36998    ; Loop 21 times.
 37003 RET           ; Return.

; Right-edge tile scanline renderer.
;
; Renders one scanline of a 3-byte-wide tile onto the framebuffer, scanning
; from right to left.
; .
; Locates the rightmost opaque byte (value != 255), applies the right-edge
; column mask via #R37114, then direct-blits any remaining bytes to its left.
; .
; Counterpart to #R36949, which masks the left edge via #R37057.
;
; .
;
; Transparent sentinel is 255. Tile bytes are ordered left to right: byte 0
; (leftmost), byte 1 (middle), byte 2 (rightmost).
; .
; IN: HL framebuffer scanline start address. DE tile source row start address.
; .
; OUT: HL advanced by 32 to the next scanline. DE advanced by 3 to the next
; tile row.
; .
; DESTROYS AF, C.
@label=right_edge_renderer
c37004 LD C,255      ; Set transparent sentinel (255) in C.
 37006 INC L         ; {Advance both pointers to tile byte 2 (rightmost).
 37007 INC L         ;
 37008 INC E         ;
 37009 INC E         ; }
 37010 LD A,(DE)     ; {Read rightmost tile byte; test for transparency.
 37011 CP C          ; }
 37012 JR Z,37019    ; Transparent: check byte 1.
 37014 CALL 37114    ; Rightmost byte is opaque: apply right-edge column mask
                     ; via #R37114.
 37017 JR 37039      ; Byte 2 handled: direct-copy remaining bytes to the left.
*37019 DEC E         ; {Byte 2 transparent: step both pointers back to byte 1.
 37020 DEC L         ; }
 37021 LD A,(DE)     ; {Read middle tile byte; test for transparency.
 37022 CP C          ; }
 37023 JR Z,37030    ; Transparent: check byte 0.
 37025 CALL 37114    ; Middle byte is the rightmost opaque: apply right-edge
                     ; column mask via #R37114.
 37028 JR 37043      ; Byte 1 handled: direct-copy byte 0 to the left.
*37030 DEC E         ; {Bytes 2 and 1 transparent: step both pointers back to
 37031 DEC L         ; byte 0.}
 37032 LD A,(DE)     ; {Read leftmost tile byte; test for transparency.
 37033 CP C          ; }
 37034 CALL NZ,37114 ; Sole opaque byte: apply right-edge column mask via
                     ; #R37114 if not transparent.
 37037 JR 37047      ; Jump to scanline advance.
*37039 DEC E         ; {Step both pointers back to byte 1.
 37040 DEC L         ; }
 37041 LD A,(DE)     ; {Direct-blit byte 1 to framebuffer.
 37042 LD (HL),A     ; }
*37043 DEC E         ; {Step both pointers back to byte 0.
 37044 DEC L         ; }
 37045 LD A,(DE)     ; {Direct-blit byte 0 to framebuffer.
 37046 LD (HL),A     ; }
*37047 PUSH DE       ; {Advance framebuffer pointer to next scanline (+32
 37048 LD DE,32      ; bytes).
 37051 ADD HL,DE     ;
 37052 POP DE        ; }
 37053 INC E         ; {Advance tile source pointer to next tile row (+3
 37054 INC E         ; bytes).
 37055 INC E         ; }
 37056 RET           ; Return.

; Generate left-edge column mask for partial tile blending.
;
; Called from #R36949 for non-0xFF tile bytes at left tile boundary.
;
; .
;
; Counts leading 1-bits from bit 7 (MSB) to find first transparent column,
; loads MSB-packed mask (128,192,224,240,248,252,254) into A and falls through
; to #R37100.
; .
; INPUT: A = left-edge tile byte, HL = framebuffer address, DE = tile source.
; .
; OUTPUT: A = pixel mask or 0 (fully transparent). DESTROYS: A, C.
@label=left_mask_gen
c37057 LD C,A        ; C = A (left-edge tile byte).
 37058 BIT 7,C       ; BIT 7,C: if bit 7 clear, byte is #00 fully transparent -
                     ; jump #R37111.
 37060 JR Z,37111    ;
 37062 LD A,128      ; A = 0x80 (10000000b) test bit 6.
 37064 BIT 6,C       ; {if bit 6 clear: 1 visible column - jump #R37100 with
 37066 JR Z,37100    ; mask 0x80.}
 37068 LD A,192      ; A = 0xC0 (11000000b) test bit 5.
 37070 BIT 5,C       ; {if bit 5 clear: 2 visible columns - jump #R37100 with
 37072 JR Z,37100    ; mask 0xC0.}
 37074 LD A,224      ; A = 0xE0 (11100000b) test bit 4.
 37076 BIT 4,C       ; {if bit 4 clear: 3 visible columns - jump #R37100 with
 37078 JR Z,37100    ; mask 0xE0.}
 37080 LD A,240      ; A = 0xF0 (11110000b) test bit 3.
 37082 BIT 3,C       ; {if bit 3 clear: 4 visible columns - jump #R37100 with
 37084 JR Z,37100    ; mask 0xF0.}
 37086 LD A,248      ; A = 0xF8 (11111000b) test bit 2.
 37088 BIT 2,C       ; {if bit 2 clear: 5 visible columns - jump #R37100 with
 37090 JR Z,37100    ; mask 0xF8.}
 37092 LD A,252      ; A = 0xFC (11111100b) test bit 1.
 37094 BIT 1,C       ; {if bit 1 clear: 6 visible columns - jump #R37100 with
 37096 JR Z,37100    ; mask 0xFC.}
 37098 LD A,254      ; all bits 7..1 set: 7 visible columns, A = 0xFE
                     ; (11111110b) fall through to #R37100.

; Apply edge mask and blend tile byte to framebuffer.
;
; Used by the routines at #R37057 and #R37114.
;
; .
;
; Shared endpoint for the left-edge mask generator (#R37057) and the right-edge
; mask generator (#R37114) when a sprite partially overlaps a tile column
; boundary.
; .
; The caller passes a pixel mask in A (1,3,7,15,31,63,127 or the MSB-packed
; equivalents for the left edge). The routine clears the transparent columns in
; the framebuffer byte and overlays the visible sprite columns from the tile
; byte.
; .
; INPUT: A = pixel mask. HL = framebuffer address. DE = tile source address of
; the byte to blend in.
; .
; OUTPUT None. Framebuffer byte at (HL) updated in place.
; .
; DESTROYS A, C.
@label=mask_and_blend
c37100 LD C,A        ; save mask (A) into C before A is overwritten.
 37101 LD A,(HL)     ; A = framebuffer byte at HL.
 37102 AND C         ; Clear the transparent pixels in the background.
 37103 LD (HL),A     ; Write back to framebuffer the masked background.
 37104 LD A,(DE)     ; A = tile source byte at DE.
 37105 XOR C         ; Invert mask bits to keep the visible sprite pixels.
 37106 LD C,A        ; Now C contains the modified tile byte.
 37107 LD A,(HL)     ; A = framebuffer byte at HL (already masked).
 37108 OR C          ; OR C to overlay the sprite pixels.
 37109 LD (HL),A     ; Write blended result back to framebuffer.
 37110 RET           ; Return.

; Write transparent tile byte to framebuffer.
;
; Shared exit for #R37057/#R37114 when tile byte has no visible columns on
; edge.
;
; .
;
; Tile encoding guarantees bit 7 (left) or bit 0 (right) clear = entire byte
; 0x00. Writes 0 to clear framebuffer destination byte, preserving background.
; .
; INPUT: C = tile byte (0x00), HL = framebuffer address.
; .
; OUTPUT: None. DESTROYS: A.
@label=mask_byte_clear
c37111 LD A,C        ; {A = C (0x00 - no sprite pixels on this edge); Write 0
 37112 LD (HL),A     ; to framebuffer byte at HL.}
 37113 RET           ; Return.

; Generate right-edge column mask for partial tile blending.
;
; Called from #R37004 for non-0xFF tile bytes at right tile boundary.
;
; .
;
; Counts trailing 1-bits from bit 0 (LSB) to find first transparent column,
; loads LSB-packed mask (1,3,7,15,31,63,127) into A and jumps to #R37100.
; .
; INPUT: A = right-edge tile byte, HL = framebuffer address, DE = tile source.
; .
; OUTPUT: A = pixel mask or 0 (fully transparent). DESTROYS: A, C.
@label=right_mask_gen
c37114 LD C,A        ; C = right-edge tile byte. Tests bit 0: set means at
                     ; least the rightmost pixel column is visible.
 37115 BIT 0,C       ; {Bit 0 clear: byte is 0x00, no visible columns - jump to
 37117 JR Z,37111    ; #R37111.}
 37119 LD A,1        ; Bit 0 set. A = 0x01 (00000001b); test bit 1.
 37121 BIT 1,C       ; {Bit 1 clear: 1 visible column - jump to #R37100 with
 37123 JR Z,37100    ; mask 0x01.}
 37125 LD A,3        ; A = 0x03 (00000011b); test bit 2.
 37127 BIT 2,C       ; {Bit 2 clear: 2 visible columns - jump to #R37100 with
 37129 JR Z,37100    ; mask 0x03.}
 37131 LD A,7        ; A = 0x07 (00000111b); test bit 3.
 37133 BIT 3,C       ; {Bit 3 clear: 3 visible columns - jump to #R37100 with
 37135 JR Z,37100    ; mask 0x07.}
 37137 LD A,15       ; A = 0x0F (00001111b); test bit 4.
 37139 BIT 4,C       ; {Bit 4 clear: 4 visible columns - jump to #R37100 with
 37141 JR Z,37100    ; mask 0x0F.}
 37143 LD A,31       ; A = 0x1F (00011111b); test bit 5.
 37145 BIT 5,C       ; {Bit 5 clear: 5 visible columns - jump to #R37100 with
 37147 JR Z,37100    ; mask 0x1F.}
 37149 LD A,63       ; A = 0x3F (00111111b); test bit 6.
 37151 BIT 6,C       ; {Bit 6 clear: 6 visible columns - jump to #R37100 with
 37153 JR Z,37100    ; mask 0x3F.}
 37155 LD A,127      ; A = 0x7F (01111111b); bits 6..0 all set: 7 visible
                     ; columns.
 37157 JR 37100      ; Jump to #R37100 with mask 0x7F.

; Renders a 3-byte-wide sprite tile over 21 scanlines using AND masking.
;
; Per scanline: saves 3 framebuffer bytes to AND-mask scratch (#R47455), loads
; mask from tile data via #R36949, draws sprite pixels via #R37004, then ANDs
; with scratch mask for transparency.
;
; .
;
; Framebuffer/tile pointers use alternate register bank (EXX) so #R37004
; auto-advances to next scanline.
; .
; INPUT: B = scanlines (21), HL = framebuffer address, DE = tile data pointer.
; .
; OUTPUT: None. DESTROYS: AF,BC,DE,HL (and shadows).
@label=tile_renderer
c37159 LD B,21       ; B = 21 (full tile height).
; This entry point is used by the routine at #R37218.
*37161 PUSH BC       ; save B (scanlines remaining).
 37162 PUSH HL       ; {save HL (framebuffer), DE (tile ptr).
 37163 PUSH DE       ; }
 37164 EXX           ; EXX: framebuffer HL/tile DE -> alternate registers.
 37165 POP DE        ; DE = tile data (recovered).
 37166 POP HL        ; HL = framebuffer (recovered).
 37167 PUSH HL       ; re-save HL for AND step (#R37199).
 37168 LD A,(HL)     ; {save 3 background bytes to AND-mask scratch (#R47455).
 37169 LD (47455),A  ;
 37172 INC L         ;
 37173 LD A,(HL)     ;
 37174 LD (47456),A  ;
 37177 INC L         ; }
 37178 LD A,(HL)     ; A = framebuffer byte 2
 37179 LD (47457),A  ; A save to scratch buffer+2 (#R47455+2)
 37182 DEC L         ; {DEC L x2: restore HL to start of 3-byte sequence
 37183 DEC L         ; }
 37184 EXX           ; EXX: back to main registers. HL'/DE' hold
                     ; framebuffer/tile pointers.
 37185 LD HL,47455   ; HL = mask scratch buffer (#R47455).
 37188 CALL 36949    ; #R36949: load AND mask from tile data into scratch
                     ; buffer.
 37191 EXX           ; EXX: activate HL=framebuffer, DE=tile for #R37004.
 37192 CALL 37004    ; #R37004: draw one scanline of sprite pixels to
                     ; framebuffer.
 37195 EXX           ; EXX: back to main registers (now point to next
                     ; scanline).
 37196 LD HL,47455   ; HL = scratch buffer (reload).
 37199 POP DE        ; DE = framebuffer address of the scanline just rendered.
 37200 LD A,(DE)     ; {framebuffer byte 0 (w/sprite); AND scratch byte 0
 37201 AND (HL)      ; (mask); restore transparent areas
 37202 LD (DE),A     ; }
 37203 INC HL        ; {next byte
 37204 INC E         ; }
 37205 LD A,(DE)     ; {framebuffer byte 1; AND scratch byte 1; restore
 37206 AND (HL)      ; transparent areas
 37207 LD (DE),A     ; }
 37208 INC HL        ; {next byte
 37209 INC E         ; }
 37210 LD A,(DE)     ; {framebuffer byte 2; AND scratch byte 2; restore
 37211 AND (HL)      ; transparent areas
 37212 LD (DE),A     ; }
 37213 EXX           ; restore HL=framebuffer, DE=tile ptr (next scanline)
 37214 POP BC        ; recover B=scanlines remaining
 37215 DJNZ 37161    ; copied one scanline. Repeat for all scanlines
 37217 RET           ; tile rendering complete

; Composite tile renderer dispatcher.
;
; Used by the routine at #R36910.
;
; .
;
; Dispatches sub-tiles from a definition sequence for complex sprites that span
; multiple simple tiles.
; .
; Reads control byte from DE (bit7=1 marks composite); indexes table at #R48433
; for sequence pointer in BC at #R48269.
; .
; Each sequence byte bits7-6 select renderer (11=AND-masked, 00=direct,
; 01/10=edge); bits4-0=scanlines for B.
; .
; Original mirror bit6 XORs 01/10 modes to swap edge renderers. Bit5=1 on next
; byte ends sequence.
; .
; INPUT: A = control byte (bit7=1, bit6=mirror, bits5-0=index 0-63). HL =
; framebuffer address. DE = tile pointer.
; .
; OUTPUT: None. DESTROYS: AF,AF',BC.
; .
; Setup: extracts index from control byte and loads definition sequence
; pointer.
@label=comp_tile_dispatcher
c37218 LD C,A        ; {Saves original control byte (C and AF') for mirror test
 37219 EX AF,AF'     ; and index extraction.}
 37220 LD A,C        ; Recovers control byte from C to A.
 37221 AND 63        ; {Extracts index (0-63) stripping mirror flag and bit7;
 37223 CALL 37317    ; loads BC with sequence pointer via #R37317.}
; Main loop: reads definition bytes and dispatches to renderer based on mode
; bits7-6 with mirror XOR for edges.
 37226 LD A,(BC)     ; {Main dispatch loop: loads next definition byte into A;
*37227 AND 192       ; isolates render mode bits7-6.}
 37229 CP 192        ; {Tests for AND-mask mode (11) or direct-copy mode (00):
 37231 JR Z,37264    ; branches to dedicated paths.
 37233 CP 0          ;
 37235 JR Z,37280    ; }
 37237 EX AF,AF'     ; {Recovers original control byte; tests mirror flag bit6;
 37238 BIT 6,A       ; XOR 0xC0 if set to swap edge renderers.
 37240 JR Z,37254    ;
 37242 EX AF,AF'     ;
 37243 LD A,(BC)     ;
 37244 XOR 192       ; }
 37246 CALL 37296    ; {Dispatches edge renderer via #R37296 (advances BC;
 37249 BIT 5,A       ; A=next byte); tests bit5 end-of-sequence; loops or ends.
 37251 JR Z,37227    ;
 37253 RET           ;
*37254 EX AF,AF'     ;
 37255 LD A,(BC)     ;
 37256 CALL 37296    ;
 37259 BIT 5,A       ;
 37261 JR Z,37227    ;
 37263 RET           ; }
; AND-mask path: renders transparent sub-tile using B=scanline count via
; #R37161.
*37264 LD A,(BC)     ; {AND-mask path: extracts scanline count to B (bits4-0);
 37265 PUSH BC       ; renders sub-tile via #R37161; advances to next byte;
 37266 AND 31        ; tests bit5; loops or ends.
 37268 LD B,A        ;
 37269 CALL 37161    ;
 37272 POP BC        ;
 37273 INC BC        ;
 37274 LD A,(BC)     ;
 37275 BIT 5,A       ;
 37277 JR Z,37227    ;
 37279 RET           ; }
; Direct copy path: copies opaque sub-tile using B=scanline count via #R37333.
*37280 LD A,(BC)     ; {Direct copy path: extracts scanline count to B; renders
 37281 PUSH BC       ; sub-tile via #R37333; advances to next byte; tests bit5;
 37282 AND 31        ; loops or ends.
 37284 LD B,A        ;
 37285 CALL 37333    ;
 37288 POP BC        ;
 37289 INC BC        ;
 37290 LD A,(BC)     ;
 37291 BIT 5,A       ;
 37293 JR Z,37227    ;
 37295 RET           ; }

; Edge-mask sub-tile renderer.
;
; Used by the routine at #R37218.
;
; .
;
; Renders edge-masked sub-tile (left/right via bit6); extracts scanlines to B
; (bits4-0).
; .
; Bit6=0: left-edge AND-mask via #R36910 (entry 36943). Bit6=1: full AND-mask
; via #R36998.
; .
; Advances BC past current byte; returns next definition byte in A (bit5=1 ends
; sequence).
; .
; IN: A=definition byte (bits7-6=01/10, bit6=renderer, bits4-0=scanlines).
; BC=def pointer.
; .
; OUT: A=next def byte. BC=advanced. DESTROYS: AF, B, BC.
@label=edge_mask_renderer
c37296 PUSH BC       ; {Saves def pointer (BC); C=def byte (bit6 tested after B
 37297 LD C,A        ; set).}
 37298 AND 31        ; {Extracts scanline count to B (bits4-0).
 37300 LD B,A        ; }
 37301 BIT 6,C       ; Tests bit6 of C: 0=left-edge AND-mask, 1=AND-mask loop.
 37303 JR NZ,37310   ; Bit6=1: full AND-mask via #R36998 (B scanlines).
 37305 CALL 36943    ; Bit6=0: left-edge AND-mask via #R36910 (entry #R36943, B
                     ; scanlines).
 37308 JR 37313      ; Jump to common exit.
*37310 CALL 36998    ; AND-mask via #R36998
*37313 POP BC        ; {Restores def pointer; advances BC to next def byte.
 37314 INC BC        ; }
 37315 LD A,(BC)     ; Loads next def byte to A; returns for end-test in
                     ; caller.
 37316 RET           ; Return: A = next byte for end-of-def test in #R37218.

; Composite tile pointer resolver.
;
; Converts a composite tile index A (0-63) into a pointer BC to its definition
; byte sequence in #R48269, via the 2-byte pointer table at #R48433.
;
; .
;
; Gets the word offset into #R48433, reads the little-endian pointer at that
; entry and returns it in BC.
; .
; INPUT A composite tile index (0-63, derived from control byte AND 0x3F). HL
; framebuffer address (preserved unchanged). OUTPUT BC pointer to definition
; bytes in #R48269. DESTROYS AF, BC.
@label=comptile_ptr_resolver
c37317 PUSH HL       ; Saves framebuffer address.
 37318 ADD A,A       ; Computes 2-byte offset into pointer table.
 37319 LD C,A        ; {Forms full offset from low byte.
 37320 LD B,0        ;
 37322 LD HL,48433   ; }
 37325 ADD HL,BC     ; Locates table (#R48433) entry for this index.
 37326 LD C,(HL)     ; {Reads pointer into BC.
 37327 INC HL        ;
 37328 LD B,(HL)     ; }
 37329 POP HL        ; Restores framebuffer address.
 37330 RET           ; Returns with pointer in BC.

; Direct copy tile renderer.
;
; Used by the routine at #R36910.
;
; .
;
; Copies tile data directly to the framebuffer without masking: 3 bytes (24
; pixels) wide, B scanlines high.
; .
; Framebuffer advances 32 bytes per row; source DE stays in single 256-byte
; page.
; .
; INPUT: B scanline count (21 full tile or sub-tile height). DE tile source
; address (low byte only advanced). HL framebuffer destination.
; .
; OUTPUT: None. DESTROYS: AF,BC,DE,HL.
@label=direct_copy_tile_renderer
c37331 LD B,21       ; Sets B=21 for full tile height (entry from R36910).
; This entry point is used by the routine at #R37218.
*37333 PUSH HL       ; Saves start-of-scanline HL.
 37334 LD A,(DE)     ; {Copies source byte 0 to framebuffer.
 37335 LD (HL),A     ; }
 37336 INC E         ; {Points to the next byte and framebuffer address.
 37337 INC L         ; }
 37338 LD A,(DE)     ; Saves start-of-scanline HL.
 37339 LD (HL),A     ; {Copies source byte 1 to framebuffer.
 37340 INC E         ; }
 37341 INC L         ; {Points to the next byte and framebuffer address.
 37342 LD A,(DE)     ; }
 37343 LD (HL),A     ; Saves start-of-scanline HL.
 37344 INC E         ; Advances past 3rd source byte.
 37345 POP HL        ; Restores start-of-scanline HL.
 37346 PUSH DE       ; {Advances HL 32 bytes to next framebuffer row.
 37347 LD DE,32      ;
 37350 ADD HL,DE     ; }
 37351 POP DE        ; Recovers tile address.
 37352 DJNZ 37333    ; Repeats B times for full height.
 37354 RET           ; Returns.

; Resolve tile address.
;
; Used by the routines at #R37449, #R38103 and #R38367.
;
; .
;
; Resolves tile index A to sprite RAM address DE.
; .
; Selects by character type IYl (107=other #R40192; else barbarian #R49152).
; Computes DE=state block+(A*64); each tile=64 bytes (8x8).
; .
; INPUT: A = tile index 0-255. IY = character state block. OUTPUT: DE = sprite
; RAM address.
; .
; DESTROYS: AF,DE,HL.
@label=resolve_tile_address
c37355 LD D,A        ; Stores tile index in D to form index*256 in DE, ready
                     ; for the *64 computation via two right-shifts.
 37356 LD A,IYl      ; Loads character type IYl to select tile bank. (89)P1,
                     ; (98)P2 use #R49152. (107)goblin uses #R40192.
 37358 CP 107        ; If IYl is 107, dispatch to the secondary state block
                     ; #R40192.
 37360 LD A,D        ; Restores tile index to A.
 37361 JR NZ,37368   ; Not goblin - branch to barbarian state block #R49152.
 37363 LD DE,40192   ; Goblin path - load secondary state block base #R40192.
 37366 JR 37371      ; Jump to common offset calculation.
*37368 LD DE,49152   ; Barbarian path - load barbarian state block base
                     ; #R49152.
*37371 PUSH HL       ; Preserve callers HL.
 37372 LD H,A        ; {Load tile index into H to start index*256 in HL.
 37373 LD L,0        ; }
 37375 SRL H         ; {Two right-shifts on HL to obtain index*64 tile byte
 37377 RR L          ; offset.}
 37379 SRL H         ; Add tile byte offset to block base low byte.
 37381 RR L          ; Complete 16-bit addition to form final address.
 37383 ADD HL,DE     ; DE: final sprite RAM address.
 37384 EX DE,HL      ; Restore callers HL.
 37385 POP HL        ;
 37386 RET           ; Return with DE pointing to tile data.

; Rectangular screen copy.
;
; Used by the routine at #R39258.
;
; .
;
; Copies B bytes x C scanlines from DE to screen HL.
; .
; Advances scanline via #R36895 after each row.
; .
; Used for snake HUD (#R39258), row clears (#R38699) and stage blits.
; .
; INPUT: B = bytes per row, C = row count, DE = source, HL = framebuffer
; destination.
; .
; OUTPUT: None. DESTROYS: AF,BC,DE,HL.
@label=copy_rect
c37387 PUSH BC       ; Saves row counter.
 37388 PUSH HL       ; Saves start-of-row destination.
*37389 LD A,(DE)     ; {Copies one byte from source to destination.
 37390 LD (HL),A     ; }
 37391 INC HL        ; {Advances source and destination pointers.
 37392 INC DE        ; }
 37393 DJNZ 37389    ; Repeats for all bytes in row.
 37395 POP HL        ; Restores start-of-row destination.
 37396 CALL 36895    ; Advances to next framebuffer scanline via #R36895.
 37399 POP BC        ; Restores row counter.
 37400 DEC C         ; Decrements row counter.
 37401 JR NZ,37387   ; Repeats for all rows.
 37403 RET           ; Returns.

; Draws 4 rows of 3 tiles each from the sprite frame data.
;
; Used by the routine at #R37486.
;
; .
;
; HL is set to the framebuffer base for the character's current X tile position
; row. H=94 (framebuffer init), L=IY+3 (X tile).
; .
; Each of the 4 rows renders 3 tiles via #R37449 draw single tile, then
; advancing the framebuffer pointer by 663 bytes 21 scanlines x 32-byte stride
; to the next row.
; .
; If the mirror flag IY2 bit 0 is set, adds an extra 2 to the column offset C
; before each row of tiles and 4 more between rows for right-side alignment.
; .
; INPUT: DE = frame address. HL framebuffer row, L=IY+3 (X tile). C = initial
; column offset from frame data. IX = DE+1 tile index array.
; .
; OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX
@label=draws_4_x_3_tiles
c37404 LD B,4        ; B=4 outer loop counter, one iteration per sprite row 4
                     ; rows total.
 37406 LD A,(DE)     ; {Loads column offset from first frame data byte
 37407 LD C,A        ; post-column into C.}
 37408 INC DE        ; Advances DE past column offset byte, now points to tile
                     ; index array.
 37409 PUSH DE       ; {Saves DE tile index array start on stack, loads into IX
 37410 POP IX        ; for single-tile rendering.}
@label=4x3_outer_loop
*37412 LD A,(IY+2)   ; Loads IY2 mirror flags.
 37415 BIT 0,A       ; Tests mirror flag bit 0.
 37417 JR Z,37421    ; Mirror inactive or adjustment complete: C ready for
                     ; first tile of row (#R37421)..
 37419 INC C         ; {Mirror active: increments C by 2 for right-side column
 37420 INC C         ; adjustment before row}
@label=4x3_inner_loop
*37421 CALL 37449    ; Draws first tile of row via #R37449 using current C
                     ; offset.
 37424 CALL 37449    ; Draws second tile of row.
 37427 CALL 37449    ; Draws third tile of row, completing one sprite row.
 37430 LD DE,663     ; {Advances framebuffer HL by 663 bytes 21 scanlines to
 37433 ADD HL,DE     ; next sprite row.}
 37434 DEC B         ; Decrements row counter B.
 37435 RET Z         ; Repeats for all 4 rows until B=0.
 37436 LD A,(IY+2)   ; Loads mirror flag.
 37439 BIT 0,A       ; Tests mirror flag again.
 37441 JR Z,37412    ; Mirror inactive: Jumps to #R37412
 37443 INC C         ; {Mirror active: adds 4 to C for inter-row right-side
 37444 INC C         ; adjustment.
 37445 INC C         ;
 37446 INC C         ;
 37447 JR 37412      ; }

; Draws one sprite tile to the framebuffer.
;
; Used by the routine at #R37404.
;
; .
;
; Used by the 4x3 tile renderer to draw individual tiles in a character sprite.
; .
; Skips the draw if the tile index is 255 (empty slot).
; .
; Applies mirror correction to the tile index if needed based on direction.
; .
; INPUT: IX = column offset and sentinel; IY = character state block.
; .
; OUTPUT: C adjusted for next tile position (INC/DEC based on mirror flag).
; DESTROYS: AF, B, DE, HL.
@label=draw_single_tile
c37449 PUSH BC       ; Preserves caller's BC value.
 37450 LD B,170      ; Sets sentinel comparison value.
 37452 LD A,(BC)     ; Reads tile index from current slot.
 37453 INC A         ; Tests for empty slot sentinel.
 37454 JR Z,37471    ; Skips rendering if empty slot detected.
 37456 DEC A         ; Restores tile index.
 37457 LD (37462),A  ; Self-modified: loads displacement offset from table.
 37460 LD A,(IX+0)   ; Reloads tile index.
 37463 PUSH HL       ; Preserves framebuffer address.
 37464 CALL 37355    ; Resolves sprite RAM address for the tile.
 37467 CALL 36910    ; Renders the tile to framebuffer.
 37470 POP HL        ; Restores framebuffer address.
*37471 POP BC        ; Restores caller's BC value.
 37472 INC L         ; {Advances framebuffer pointer 3 bytes right (one tile).
 37473 INC L         ;
 37474 INC L         ; }
 37475 LD A,(IY+2)   ; Tests mirror flag in character state.
 37478 BIT 0,A       ; Checks mirror bit.
 37480 JR Z,37484    ;
 37482 DEC C         ; {Adjusts offset left if mirrored.
 37483 RET           ; }
*37484 INC C         ; Adjusts offset right if not mirrored.
 37485 RET           ; Returns with updated offset.

; Main sprite dispatcher.
;
; Used by the routine at #R39617.
;
; .
;
; Draws the sprite for the character pointed by IY.
; .
; Returns immediately if IY+0 is 0 (inactive character).
; .
; Loads frame index from IY+8, resolves frame data pointer from table #R44189.
; .
; Frame data starts with first byte as shape ID, followed by tile indices for
; the 4x3 sprite grid. Then sets the framebuffer row and calls #R37404 (4x3
; tile renderer).
; .
; INPUT: IY = character state block.
; .
; DESTROYS: BC, DE, HL, IX.
@label=sprite_dispatcher
c37486 PUSH AF       ; Preserve AF.
 37487 LD A,(IY+0)   ; {Load IY+0
 37490 OR A          ; }
 37491 JR Z,37534    ; return if zero (character inactive).
 37493 LD E,(IY+4)   ; {Load frame data pointer from IY+4 (low) and IY+5 (high)
 37496 LD D,(IY+5)   ; into DE.}
 37499 LD A,(DE)     ; {Read current frame byte from DE; compare with 17
 37500 CP 17         ; (decapitation frame).}
 37502 CALL Z,37866  ; If frame=17, call #R37866 (decapitation setup)
 37505 LD (IY+8),A   ; Update IY+8 with result.
 37508 LD HL,44189   ; Load #R44189 (frame pointer table) into HL
 37511 CALL 38304    ; call #R38304 to resolve frame address.
 37514 PUSH HL       ; Preserve resolved frame address on stack.
 37515 LD A,(HL)     ; {IX = Sprites shapes table (#R43520) + A (shape ID)
 37516 LD IXl,A      ;
 37518 LD IXh,170    ; }
 37521 INC HL        ; {Advance HL by 1; call #R38367 (sprites renderer,
 37522 CALL 38367    ; 12-slot loop).}
 37525 POP DE        ; {Restore DE=frame address; set L=IY+3 (X tile), H=94
 37526 LD L,(IY+3)   ; (framebuffer row)
 37529 LD H,94       ; }
 37531 CALL 37404    ; Call 4x3 tile rendered (#R37404).
*37534 POP AF        ; Recover AF.
 37535 RET           ; Return.

; Animation frame stepper.
;
; Used by the routines at #R39617 and #R39827.
;
; .
;
; Advances the animation frame pointer for the character pointed by IY, fires
; events for specific frame indices, and processes end-of-sequence sentinels.
; .
; Frames 20 and 33 trigger a goblin spawn check via #R37666. Frame 87 (dying)
; plays the tackle sound via #R39926 (The winner kicks the loser). Sentinel 253
; restarts the current movement via #R36838, 254 holds on the last frame, and
; 255 chains to the next queued animation.
; .
; INPUT: IY character state block.
; .
; OUTPUT: IY+4,IY+5 updated frame pointer. IY+8 new frame index.
; .
; DESTROYS: AF, DE.
@label=anim_frame_stepper
c37536 LD E,(IY+4)   ; {Load frame pointer from IY+4/IY+5 into DE.
 37539 LD D,(IY+5)   ; }
 37542 LD A,(DE)     ; Read current byte.
 37543 CP 20         ; Compare with 20.
 37545 CALL Z,37666  ; Frame 20 triggers goblin spawn check via #R37666.
 37548 INC DE        ; Increment DE (advance frame pointer)
 37549 LD (IY+4),E   ; {Store back in IY+4/IY+5
 37552 LD (IY+5),D   ; }
 37555 LD A,(DE)     ; Read new byte into A
 37556 LD (IY+8),A   ; Store in IY+8.
 37559 CP 33         ; Compare A with 33.
 37561 PUSH AF       ; {Frame 33 also triggers goblin spawn check via #R37666,
 37562 CALL Z,37666  ; preserving AF.
 37565 POP AF        ; }
 37566 INC DE        ; Increment DE.
 37567 PUSH AF       ;
 37568 CP 87         ; Compare A with 87.
 37570 PUSH DE       ;
 37571 PUSH AF       ;
 37572 CALL Z,39926  ; if frame 87 (dying), call #R39926 (loser receives a
                     ; kick).
 37575 POP AF        ;
 37576 POP DE        ;
 37577 LD A,(DE)     ; Read updated byte from DE.
 37578 CP 253        ; Compare with 253 (end-of-sequence sentinel).
 37580 JR C,37585    ; If <253, jump to #R37585 (normal frame, set RES 7,IY+2).
 37582 CALL 37622    ; Call #R37622 (clear bit 7 of IY+2: non-controllable flag
                     ; off).
*37585 DEC DE        ; Decrement DE.
 37586 POP AF        ; Recover AF from stack.
 37587 CP 253        ; {If A<253, return (normal case).
 37589 RET C         ; }
 37590 CP 253        ; {If A=253, Jump forward to #R37611 (load IY+6 (movement
 37592 JR Z,37611    ; ID) and call #R36843 to apply movement loop).}
 37594 CP 255        ; {If A=255 concatenates next animation (call #R37627 to
 37596 JR Z,37627    ; reset: INC DE, jump to #R37619).}
 37598 DEC DE        ; If else (A=254): restore frame pointer to DE-1;
 37599 LD (IY+4),E   ; {Update IY+4/IY+5 and IY+8.
 37602 LD (IY+5),D   ;
 37605 LD A,(DE)     ;
 37606 LD (IY+8),A   ; }
 37609 JR 37622      ; And jump to #R37622.
*37611 LD A,(IY+6)   ; {If A=253, (load IY+6 (movement ID) and call #R36843 to
 37614 CALL 36843    ; apply movement loop).}
 37617 JR 37622      ; Reset IY+2 and return.
*37619 CALL 36838    ; (A=255) Call #R36838 (to reload next animation).
*37622 RES 7,(IY+2)  ; {RES 7,IY+2; return (clears the non-controllable bit).
 37626 RET           ; }
*37627 INC DE        ; {INC DE; read byte; jump to #R37619.
 37628 LD A,(DE)     ;
 37629 JR 37619      ; }

; End-of-fight dispatcher.
;
; Used by the routine at #R38960.
;
; .
;
; Called when the loser's X tile reaches 30 (off-screen, "pulled" by the
; goblin).
; .
; Checks which player has won through checking who has frame 19 (victory) in
; IY+6, then dispatches to the appropriate end-of-fight sequence.
@label=end_of_fight_dispatcher
c37631 LD IY,46425   ; IY = player 1 state block #R46425.
 37635 LD A,(IY+6)   ; Load movement ID (IY+6).
 37638 CP 19         ; Is movement 19 (victory)?
 37640 JR NZ,37648   ; No - jump to #R37648 to check time/P2 (P1 has died).
 37642 CALL 37714    ; Yes - P1 wins: call #R37714 (score update, victory
                     ; sequence (P2 has died).
 37645 JP 36793      ; Jump to #R36793 to reinitialise P2 block for next round.
*37648 LD A,(46808)  ; Load round timer value from #R46808.
 37651 CP 255        ; Is time = 255 (non-timed game = 1P game)?
 37653 JP Z,35381    ; Yes - Game over. jump to #R35381 back to menu without
                     ; scoring.
 37656 LD IY,46434   ; No (It's a 2 players game); IY = P2 state block #R46434.
 37660 CALL 37748    ; Call #R37748 to run P2-wins sequence (P1 has died, timed
                     ; 2P mode).
 37663 JP 36776      ; Jump to #R36776 to reinitialise P1 block for next round.

; Goblin entry trigger.
;
; Called from #R37536 when the dying character's animation reaches frame index
; 20 or 33, signalling the body has settled and the goblin can enter.
; .
; Two guard conditions are checked before spawning: the goblin is already
; active (R46443=255), or the severed head is still in flight (#R46810 neither
; 0 nor 255). If no decapitation occurred (R46810=0) or the head has already
; landed (#R46810=255), both guards pass and the goblin is spawned via #R37701.
;
; .
;
; INPUT: IY = active character state block, preserved across the call.
; .
; OUTPUT: None. Side effect: goblin state block initialised and #R46443 set to
; 255 if spawn conditions are met.
; .
; DESTROYS: AF.
@label=goblin_entry
c37666 LD A,(46443)  ; {Skip if the goblin is already active (#R46443=255).
 37669 CP 255        ;
 37671 RET Z         ; }
 37672 LD A,(46810)  ; {Head landed or no decapitation(#R46810=255): proceed to
 37675 CP 255        ; spawn.
 37677 JR Z,37681    ; }
 37679 OR A          ; {Head still in flight (#R46810!=255): return and wait.
 37680 RET NZ        ; }
*37681 PUSH IY       ; Save the caller's IY before goblin initialisation
                     ; overwrites it.
 37683 LD A,30       ; Select movement 30 (goblin entrance animation).
 37685 CALL 37701    ; Spawn and initialise the goblin via #R37701.
 37688 XOR A         ; {Reset goblin frame counter (#R46446), mirror
 37689 LD (46446),A  ; flags(#R46445), and tackle collision flag (#R47576).
 37692 LD (46445),A  ;
 37695 LD (47576),A  ; }
 37698 POP IY        ; Restore the caller's IY.
 37700 RET           ; Return.

; Activate goblin and initialise its state block.
;
; Called exclusively by #R37666 once all spawn guard conditions pass.
;
; .
;
; Sets IY to #R46443 (goblin state block base) and calls #R36838 with movement
; ID 30 to initialise IY+2,4,5,6,8 and start the goblin entrance animation.
; Then, writes 255 to #R46443 (IY+0) as the active sentinel.
; .
; 0 = goblin inactive (cleared by #R39617 when body exits screen at X=29).
; .
; 255 = goblin active (set here, guards re-entry in #R37666).
; .
; INPUT: A = 30 (movement ID for goblin entrance animation). OUTPUT: None.
; DESTROYS: AF, BC, IY.
@label=init_goblin
c37701 LD IY,46443   ;  IY = #R46443 goblin state block base address.
 37705 CALL 36838    ;  Call #R36838 with A=30 to initialise movement and
                     ; animation data.
 37708 LD A,255      ;  A = 255: goblin active sentinel.
 37710 LD (46443),A  ;  Write 255 to #R46443: marks goblin as active for
                     ; #R37666 and #R39617 guard checks.
 37713 RET           ;  Return.

; P1-wins end-of-fight sequence.
;
; Used by the routine at #R37631.
;
; .
;
; Called by #R37631 when P1 movement ID equals 19 (Victory), meaning P2 has
; been defeated.
; .
; Updates P1 score and drains the round timer (#R37791).
@label=p1_wins_seq
c37714 CALL 37791    ; Score update and timer drain via #R37791; never returns
                     ; to caller.
; The rest of the routine contains UNREACHABLE CODE. In other versions of the
; game, after the end of fight, it applies movement 35 (walk-out animation) to
; exit arena on P1 state block via #R37772. This seems to be a remaining of
; that.
 37717 CALL 37772    ; Walk-out animation (movement 35) on P1; Z set if mirror
                     ; flag clear.
 37720 RET NZ        ; Mirror flag active: nothing to do.
 37721 XOR 1         ; Activate mirror flag (one-shot).
 37723 LD (46427),A  ; Write mirror flag to #R46427.
 37726 LD A,(46428)  ; Read P1 row position.
 37729 ADD A,4       ; Advance row by 4.
 37731 CP 24         ; Out of bounds check (row >= 24).
 37733 RET NC        ; Row out of bounds: return without update.
 37734 CP 24         ; [Dead code] Unreachable compare.
 37736 JR Z,37742    ; [Dead code] Unreachable branch.
 37738 LD (46428),A  ; Write updated row position.
 37741 RET           ; Return.
*37742 LD A,23       ; [Dead code] Clamp row to 23.
 37744 LD (46428),A  ; [Dead code] Would write clamped value.
 37747 RET           ; Return.

; P2-wins end-of-fight sequence.
;
; Used by the routine at #R37631.
;
; .
;
; Called by #R37631 in timed 2P mode (#R46808 != 255) with IY pointing to the
; P2 state block #R46434, signalling that P1 has been defeated.
; .
; Symmetric counterpart to #R37714: same structure but operates on the P2
; mirror flag (#R46436 bit 0).
; .
; Calls #R37819 to update P2 score and decrement round timer.
@label=p2_wins_seq
c37748 CALL 37819    ; Score update and timer decrement (P2 side).
; The rest of the routine contains UNREACHABLE CODE. In other versions of the
; game, after the end of fight, it applies movement 35 (walk-out animation) to
; exit arena on P2 state block via #R37772. This seems to be a remaining of
; that.
 37751 CALL 37772    ; Walk out animation (movement 35) on P2; Z set if mirror
                     ; flag clear.
 37754 RET NZ        ; Mirror flag already set: nothing to do.
 37755 XOR 1         ; Toggle bit 0 to activate mirror flag (one-shot).
 37757 LD (46436),A  ; Write mirror flag to #R46436.
 37760 LD A,(46437)  ; Read P2 row position (#R46437).
 37763 SUB 4         ; Decrement row by 4.
 37765 CP 24         ; Underflow check (row < 0 after subtraction).
 37767 RET NC        ; Row out of bounds: return without update.
 37768 LD (46437),A  ; Write updated row position (#R46437).
 37771 RET           ; Return.

; Post-fight winner setup. (UNUSED)
;
; Sets the winner's energy bar to full, applies movement 35 (walk-out
; animation) via #R36838, and returns the mirror flag state in Z.
;
; .
;
; Never executed in this version: the only callers are #R37714 and #R37748,
; which invoke #R37791 and #R37819 immediately before the CALL to this routine.
; Those routines always exit via JP or JR without returning, making this entire
; routine unreachable. Other versions of the game do execute it and display the
; walk-out animation.
; .
; INPUT: IY = winning character state block.
; .
; OUTPUT: Z set if IY+2 bit 0 is clear (not mirrored).
; .
; DESTROYS AF.
@label=post_fight_setup
c37772 LD A,13       ; Load the full energy value (13).
 37774 LD (IY+7),A   ; Write it to the winner's energy display field.
 37777 CALL 39367    ; Refresh the energy bar on screen immediately via
                     ; #R39367.
 37780 LD A,35       ; Select movement 35 - walk-out animation.
 37782 CALL 36838    ; Apply movement 35 to the winner's state block via
                     ; #R36838.
 37785 LD A,(IY+2)   ; Fetch the winner's current orientation state.
 37788 BIT 0,A       ; Test mirror bit; Z set if not mirrored, Z clear if
                     ; mirrored.
 37790 RET           ; Return with Z reflecting the winner's orientation.

; P2-death score update and time drain loop.
;
; Called by #R37714 (P1-wins sequence) after P2 has been defeated.
;
; .
;
; MODE 1P/DEMO (#R46808=255): jumps immediately to #R35487 end-of-match handler
; without touching the score. The timer is never decremented.
; .
; MODE 2P (#R46808=0..90): awards 10 points to P1 score (#R47429) and refreshes
; the score display via #R35426, then calls #R37852 to decrement the timer by 1
; and update the HUD. Loops until #R37852 returns Z (#R46808 has reached 0),
; then falls through to #R37843.
; .
; Each iteration awards +10 to P1 and drains 1 timer unit, so the total bonus
; equals remaining_time * 10.
@label=p2_death_score_update
c37791 LD A,(46808)  ; Read the round timer (#R46808).
 37794 CP 255        ; Is it 255 (1P/demo mode - infinite time)?
 37796 JP Z,35487    ; Yes - jump to #R35487 end-of-match handler without
                     ; scoring.
*37799 LD HL,(47429) ; HL = current P1 score (#R47429).
 37802 LD DE,10      ; DE = 10 points to add.
 37805 ADD HL,DE     ; HL = score + 10.
 37806 LD (47429),HL ; Write updated score back to #R47429.
 37809 CALL 35426    ; Refresh P1 score display via #R35426.
 37812 CALL 37852    ; Decrement timer by 1 and update HUD via #R37852. Returns
                     ; Z if timer=0.
 37815 JR NZ,37799   ; Timer not zero - loop back to award another +10.
 37817 JR 37843      ; Timer exhausted - fall through to #R37843.

; P1-death score update and time drain loop.
;
; Symmetric counterpart to #R37791. Called by #R37748 (P2-wins sequence) after
; P1 has been defeated.
;
; .
;
; MODE 1P/DEMO (#R46808=255): returns immediately without scoring. The CPU
; never accumulates a time bonus in 1P mode.
; .
; MODE 2P (#R46808=0..90): awards +10 to P2 score (#R47431) per timer unit
; drained via #R37852, until #R46808 reaches 0. Falls through to #R37843
; implicitly when the loop terminates.
@label=p1_death_score_update
c37819 LD A,(46808)  ; Read the round timer (#R46808).
 37822 CP 255        ; Is it 255 (1P/demo mode)?
 37824 RET Z         ; Yes - return without scoring.
*37825 LD HL,(47431) ; HL = current P2 score (#R47431).
 37828 LD DE,10      ; DE = 10 points to add.
 37831 ADD HL,DE     ; HL = score + 10.
 37832 LD (47431),HL ; Write updated score back to #R47431.
 37835 CALL 35435    ; Refresh P2 score display via #R35435.
 37838 CALL 37852    ; Decrement timer by 1 and update HUD via #R37852. Returns
                     ; Z if timer=0.
 37841 JR NZ,37825   ; JTimer not zero - loop back to award another +10. Falls
                     ; through to #R37843 when timer reaches 0.

; Post-drain wait and end-of-round jump.
;
; Called by #R37819 or #R37791 in a 2 Players game, once the score-drain loop
; terminates (#R46808=0).
;
; .
;
; Waits 2 x 112 ms (~224 ms pause) then jumps to #R35381 to clear combat state
; and back to the menu.
@label=post_drain_wait
c37843 CALL 39846    ; {Wait 224 ms.
 37846 CALL 39846    ; }
 37849 JP 35381      ; Jump to #R35381 to clear state and back to the menu.

; Round timer tick: decrement, refresh HUD and play sound.
;
; Decrements #R46808 by 1, refreshes the timer display via #R36105 and plays
; the tick sound via #R39962.
; .
; Called once per loop iteration by #R37791 and #R37819 while draining the
; remaining time as bonus score.
;
; .
;
; INPUT: None. OUTPUT: Z set if the timer has reached 0, NZ if time remains.
; DESTROYS: AF.
@label=timer_tick
c37852 DEC A         ; Load timer value from #R46808 and decrement by 1.
 37853 LD (46808),A  ; Write updated timer value back to #R46808.
 37856 PUSH AF       ; Preserve decremented value and flags across the HUD and
                     ; sound calls.
 37857 CALL 36105    ; Refresh the timer display via #R36105.
 37860 CALL 39962    ; Play timer tick sound via #R39962.
 37863 POP AF        ; Restore timer value and flags.
 37864 OR A          ; Set Z if timer reached 0, NZ if time still remains.
 37865 RET           ; Return.

; Decapitation setup.
;
; Called from #R37486 when the sprite dispatcher encounters frame index 17.
;
; .
;
; IY points to the attacker state block on entry.
; .
; Identifies the defender (opposite character) and applies movement 37
; (decapitation fall) to them via #R36838. Then, if no head is already in
; flight (#R46810 != 1), computes the head spawn position in the framebuffer
; from the attacker X tile column plus a 15-row vertical offset, and
; initialises the flying-head state block at #R46809 via #R37944.
; .
; IN: IY attacker state block (#R46425 or #R46434).
; .
; OUT: None. #R46809 initialised if #R46810 != 1.
; .
; DESTROYS AF, AF', IY.
@label=decap_setup
c37866 PUSH AF       ; Preserve AF (frame index that triggered this call).
 37867 PUSH IY       ; Preserve IY (attacker state block).
 37869 LD A,IYl      ; A = attacker type: low byte of IY base address (89=P1,
                     ; 98=P2).
 37871 LD IY,46425   ; Default: IY = P1 state block R46425 (defender if
                     ; attacker is P2).
 37875 CP 89         ; Is attacker P1 (type 89)?
 37877 JR NZ,37883   ; No (attacker is P2) -> defender is P1, keep IY =
                     ; #R46425.
 37879 LD IY,46434   ; Yes (attacker is P1) -> defender is P2, set IY =
                     ; #R46434.
*37883 LD A,37       ; A = 37: movement code for decapitation fall.
 37885 CALL 36838    ; Apply movement 37 to the defender via #R36838.
 37888 POP IY        ; Restore IY: now points to the attacker block.
 37890 LD A,(46810)  ; Read head active state from #R46810.
 37893 CP 1          ; Is head already in flight (state = 1)?
 37895 JR Z,37942    ; Yes -> skip initialisation, jump to #R37942.
 37897 LD A,(IY+3)   ; A = attacker X tile position (IY+3).
 37900 LD L,A        ; L = column offset in framebuffer.
 37901 LD H,94       ; H = 0x5E: framebuffer base #R24066.
 37903 LD DE,480     ; DE = 480 (15 rows * 32): vertical offset to head spawn
                     ; row.
 37906 ADD HL,DE     ; HL = framebuffer address at attacker column, 15 rows
                     ; down.
 37907 LD A,(IY+2)   ; A = mirror flags byte (IY+2).
 37910 AND 1         ; Isolate bit 0: mirror flag (1 = attacker facing left).
 37912 JR Z,37918    ; Not mirrored -> head spawns directly at attacker column,
                     ; no adjustment needed.
 37914 LD DE,6       ; DE = 6: hardcoded horizontal offset for head spawn
                     ; position (mirrored sprites only).
 37917 ADD HL,DE     ; Shift head spawn point 6 bytes right.
*37918 EX AF,AF'     ; Save mirror bit to AF', free A for next operations.
 37919 XOR A         ; A = 0.
 37920 LD (46825),A  ; Write 0 to #R46825 (redundant: always 0, never read from
                     ; this buffer).
 37923 LD DE,47017   ; DE = #R47017: 18-entry head flight trajectory table
                     ; (Dx,Dy pairs per frame).
 37926 LD BC,46853   ; BC = #R46853: P2 head tile sequence (default, used when
                     ; attacker is P2).
 37929 LD A,IYl      ; A = attacker type (IY+0 low byte).
 37931 CP 98         ; Is attacker P2 (type 98)?
 37933 JR Z,37938    ; Yes -> keep BC = #R46853 (P2 head tiles), jump to
                     ; #R37938.
 37935 LD BC,46835   ; No (attacker is P1) -> BC = R46835 (P1 head tiles).
*37938 EX AF,AF'     ; Restore A = mirror bit from AF'.
 37939 CALL 37944    ; Initialise flying-head state block #R46809 via #R37944.
*37942 POP AF        ; Restore AF.
 37943 RET           ; Return.

; Initialise flying head state block.
;
; Called by #R37866 when the decapitation hit frame 17 is detected and no head
; is already in flight.
;
; .
;
; Writes the direction flag and framebuffer position directly into #R46809 and
; #R46815, then falls through to R37950 to set the active state, trajectory
; pointer and tile sequence pointer.
; .
; INPUT: A = direction flag (0=right, 1=left). HL = initial framebuffer
; address. DE = trajectory data pointer (#R47017). BC = tile sequence pointer
; (#R46835 or #R46853).
; .
; OUTPUT: None. DESTROYS: A.
@label=head_init
c37944 LD (46809),A  ; Write direction flag to #R46809.
 37947 LD (46815),HL ; Write framebuffer address to #R46815 (16-bit store).
; Second entry point used by #R37964 when the goblin kicks the severed head.
; Re-activates the head with a new trajectory and tile source without touching
; direction #R46809 or current position #R46815; the head is already on screen
; and just needs a new bounce arc.
; .
; INPUT: DE = #R47085 kicked-head bounce trajectory. BC = tile sequence pointer
; (#R46835or #R46853).
@label=head_reactivate
*37950 LD A,1        ; A = 1, head active and bouncing.
 37952 LD (46810),A  ; #R46810 = 1: mark head as active, re-enables R37997
                     ; movement logic.
 37955 LD (46813),DE ; #R46813 = DE: trajectory data pointer.
 37959 LD (46811),BC ; #R46811 = BC: tile frame sequence pointer.
 37963 RET           ; Return.

; Goblin kicks the severed head off-screen.
;
; Used by the routine at #R39617.
;
; .
;
; Called from #R39617 when the goblin X position matches the head screen
; column.
; .
; Rewinds the tile sequence pointer by 16: reads the current pointer from
; #R46811, subtracts 16 to recover the original sequence base (#R46835 P1 or
; #R46853 P2), and passes it to #R37950 as BC. This restarts the head tile
; animation from frame 0 for the kick arc.
; .
; Switches the trajectory to #R47085 (kicked-head bounce), which opens with a
; sharp upward arc (6 scanlines up per frame, control byte bit 0 = move-up).
; .
; INPUT: B = Goblin X position. OUTPUT None. DESTROYS: AF, DE, HL.
@label=goblin_kicks
c37964 LD A,(46810)  ; {Guard: A = #R46810 (head state flag); RET Z if 0 (head
 37967 OR A          ; inactive).
 37968 RET Z         ; }
 37969 PUSH BC       ; Preserve goblin X position.
 37970 CALL 39926    ; {Plays sound tick.
 37973 XOR A         ; }
 37974 LD HL,(46811) ; Load current tile sequence pointer from #R46811.
 37977 AND A         ; Clear carry before subtraction.
 37978 LD BC,16      ; BC = 16 (number of frames elapsed since head spawned).
 37981 SBC HL,BC     ; Rewind pointer to start of tile sequence (base address
                     ; of the original sequence).
 37983 PUSH HL       ; Preserve rewound pointer.
 37984 POP BC        ; BC = rewound tile sequence base (#R46835 P1 or #R46853
                     ; P2).
 37985 LD DE,47085   ; DE = #R47085 kicked-head bounce trajectory, will be
                     ; written to #R46813 by #R37950.
 37988 CALL 37950    ; Re-activates head via #R37950 with rewound tile sequence
                     ; and kick trajectory.
 37991 XOR A         ; {#R46809 = 0: reset head direction to right, kicked
 37992 LD (46809),A  ; off-screen right.}
 37995 POP BC        ; Restore goblin X position.
 37996 RET           ; Return.

; Flying head animator.
;
; Called once per frame from the main game loop via #R35319.
; .
; Moves and renders the severed head using the 8-byte state block at #R46809,
; addressed via IX.
;
; .
;
; Movement control data: 2-byte pairs (control byte, magnitude). Bit 0 = move
; up (#R38201), bit 1 = move down (#R38191). Pointer at IX+4,5 advances 2 bytes
; per frame.
; .
; Tile sequence at IX+2,3 advances 1 byte per frame. When the byte value is
; 255, INC A wraps to 0 and triggers #R38180: sets #R46810=255 (landed),
; unblocking goblin spawn in #R37666.
; .
; After horizontal movement, column byte (L AND 31) is checked against 0, 1 and
; 29. Any edge column triggers #R38186: sets #R46810=0 (fully inactive).
; .
; Landed path: #R46810=255, INC A wraps to 0, JR Z jumps to #R38103 skipping
; all movement logic. The head is redrawn in place each frame until #R37964
; re-activates it.
; .
; IN None. OUT None. DESTROYS AF, BC, DE, HL, IX.
@label=head_animator
c37997 LD IX,46809   ; IX = #R46809 head state block base.
 38001 LD A,(IX+1)   ; A = #R46810 state byte.
 38004 OR A          ; Test if inactive (state = 0).
 38005 RET Z         ; Return if inactive.
 38006 INC A         ; INC A: wraps 255 (landed) to 0.
 38007 JR Z,38103    ; Landed: jump to draw-only path at #R38103.
 38009 CALL 38137    ; Bouncing: draw ground shadow via #R38137.
 38012 CALL 38103    ; Draw head tile at current position via #R38103.
 38015 LD L,(IX+4)   ; {HL = IX+4,5 (movement control pointer, #R46813).
 38018 LD H,(IX+5)   ; }
 38021 LD C,(HL)     ; C = control byte (bit 0=up, bit 1=down).
 38022 INC HL        ; Advance past control byte.
 38023 LD B,(HL)     ; B = magnitude (scanlines to move this frame).
 38024 LD L,(IX+6)   ; {HL = IX+6,7 (current framebuffer address, #R46815).
 38027 LD H,(IX+7)   ; }
 38030 BIT 0,C       ; Bit 0 set: move up.
 38032 CALL NZ,38201 ; Move up B scanlines via #R38201.
 38035 BIT 1,C       ; Bit 1 set: move down.
 38037 CALL NZ,38191 ; Move down B scanlines via #R38191.
 38040 LD A,(IX+0)   ; A = IX+0 direction flag.
 38043 CP 1          ; Direction = left?
 38045 CALL Z,38212  ; Yes: DEC L (move one column left) via #R38212.
 38048 CALL NZ,38216 ; No: INC L (move one column right) via #R38216.
 38051 LD (IX+6),L   ; {Store updated framebuffer address back to IX+6,7
 38054 LD (IX+7),H   ; (#R46815).}
 38057 LD A,L        ; Read column byte from updated framebuffer address (L).
 38058 AND 31        ; Mask to 5 bits to get screen column (0-31).
 38060 OR A          ; Column = 0: left edge, deactivate.
 38061 JR Z,38186    ; Deactivate via #R38186.
 38063 CP 1          ; Column = 1: near left edge, deactivate.
 38065 JR Z,38186    ; Deactivate via #R38186.
 38067 CP 29         ; Column = 29: right edge, deactivate.
 38069 JR Z,38186    ; Deactivate via #R38186.
 38071 LD L,(IX+2)   ; {HL = IX+2,3 (tile animation sequence pointer, #R46811).
 38074 LD H,(IX+3)   ; }
 38077 INC HL        ; Advance sequence pointer by 1.
 38078 LD A,(HL)     ; A = current tile index byte.
 38079 INC A         ; INC A: test for end-of-sequence sentinel (255 wraps to
                     ; 0).
 38080 JR Z,38180    ; Sentinel: mark head as landed via #R38180.
 38082 LD (IX+2),L   ; {Store updated tile sequence pointer back to IX+2,3
 38085 LD (IX+3),H   ; (#R46811).}
 38088 LD L,(IX+4)   ; {HL = IX+4,5 (movement control pointer, #R46813).
 38091 LD H,(IX+5)   ; }
 38094 INC HL        ; {Advance movement control pointer past the consumed pair
 38095 INC HL        ; (2 bytes).}
 38096 LD (IX+4),L   ; {Store updated movement control pointer back to IX+4,5
 38099 LD (IX+5),H   ; (#R46813).}
 38102 RET           ; Return.

; Render head or P2 overlay tile to framebuffer.
;
; Used by the routines at #R37997 and #R38220.
;
; .
;
; Shared tile renderer for the flying head (#R46809) and the P2 overlay
; (#R46817). Reads the tile index from the sequence pointer at IX+2,3,
; temporarily patches the sprite bank selector at #R37368 to use the head bank
; (#R40192), resolves the tile address via #R37355, then restores the normal
; bank (#R49152).
; .
; Checks tile orientation against the head direction via #R38158; on mismatch,
; flips bit 6 of the tile index and mirrors the tile in-place via #R38340.
; Renders the result to the framebuffer at IX+6,7 via #R36910.
; .
; INPUT: IX = state block (#R46809 flying head, #R46817 P2 overlay); IX+2,3 =
; tile sequence pointer; IX+6,7 = framebuffer destination.
; .
; OUTPUT: None. DESTROYS: AF, BC, DE, HL.
@label=render_head_tile
c38103 LD L,(IX+2)   ; {Load tile sequence pointer low byte from IX+2,3; HL now
 38106 LD H,(IX+3)   ; points to the current tile.}
 38109 LD A,(HL)     ; Read tile index at current sequence position.
 38110 LD HL,40192   ; Load head sprite bank base address (#R40192).
 38113 LD (37369),HL ; Patch sprite bank operand at 37369 (#R37368); overrides
                     ; normal bank (#R49152).
 38116 CALL 37355    ; Resolve tile address into DE via #R37355.
 38119 LD HL,49152   ; Load normal sprite bank base address (#R49152).
 38122 LD (37369),HL ; Restore sprite bank operand at 37369 (#R37368) to normal
                     ; bank.
 38125 CALL 38158    ; Check tile orientation vs head direction via #R38158;
                     ; draw mirrored variant if mismatched.
 38128 LD L,(IX+6)   ; {Load framebuffer destination IX+6,7 into HL.
 38131 LD H,(IX+7)   ; }
 38134 JP 36910      ; Tail-call #R36910 to render the tile.

; Flying head ground shadow renderer.
;
; Used by the routine at #R37997.
;
; .
;
; Draws a ground shadow for the flying head each frame. Calculates the shadow
; VRAM address from the current head column (#R46815) and the ground row, then
; calls #R36910 to blit the shadow tile (#R40576).
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, DE, HL.
@label=shadow_head
c38137 LD A,(46434)  ; {Guard: return if #R46434 is zero (never true during
 38140 OR A          ; normal gameplay).
 38141 RET Z         ; }
 38142 LD DE,40576   ; Load head shadow tile source address (#R40576).
 38145 LD A,(46815)  ; Read current head column from framebuffer address
                     ; (#R46815).
 38148 AND 31        ; {Build VRAM column byte: got the equivalent address in
 38150 OR 224        ; the ground.}
 38152 LD H,101      ; {Complete VRAM address in HL.
 38154 LD L,A        ; }
 38155 JP 36910      ; Tail-call #R36910 to render the shadow tile.

; Head tile orientation selector.
;
; Checks the facing direction and mirrors it if required.
;
; .
;
; On a match (Z set), returns immediately. On a mismatch, flips bit 6 of the
; tile index in the head sprite bank RAM (#R40192) and mirrors the tile pixel
; data in-place at that address via #R38340. The caller #R38103 then renders
; the updated tile to the framebuffer.
; .
; INPUT: DE = tile index address in head sprite bank (#R37355 via #R38103).
; IX+0 = direction flag (#R46809): 1=left, 0=right.
; .
; OUTPUT: Z set: orientation correct, no action. Z clear: orientation
; corrected, tile mirrored. DESTROYS AF, B.
@label=head_mirroring
c38158 LD A,(IX+0)   ; {Map direction flag to bit-6 mask (two RRCA: bit 0 ->
 38161 RRCA          ; bit 6; left=0x40, right=0x00).
 38162 RRCA          ; }
 38163 LD B,A        ; B = expected orientation bit.
 38164 LD A,(DE)     ; {Read tile index; isolate orientation bit (bit 6).
 38165 AND 64        ; }
 38167 CP B          ; {Orientation already matches - return Z set.
 38168 RET Z         ; }
 38169 PUSH DE       ; Mismatch - save tile index pointer.
 38170 LD A,(DE)     ; {Reload tile index; flip orientation bit (XOR 0x40).
 38171 XOR 64        ; }
 38173 LD (DE),A     ; Write corrected index back to head sprite bank RAM.
 38174 INC E         ; Advance to tile pixel data.
 38175 CALL 38340    ; Mirror tile pixel data in-place in the head sprite bank
                     ; via #R38340.
 38178 POP DE        ; Restore tile index pointer.
 38179 RET           ; Return Z clear.

; Mark head landed.
;
; Mark flying head as landed: trajectory exhausted, enter draw-only phase.
;
; .
;
; Reached when #R37997 detects the end-of-trajectory sentinel in the tile
; animation sequence.
; .
; Sets #R46810 to 255, switching #R37997 from movement mode to draw-only mode
; each frame.
; .
; Also unblocks goblin spawn: #R37666 waits for #R46810 = 255 before the goblin
; enters the arena.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF.
@label=mark_head_landed
c38180 LD A,255      ; End of bounce trajectory - mark head as landed.
 38182 LD (IX+1),A   ; Set #R46810 to 255 - head is now in draw-only landed
                     ; state.
 38185 RET           ; Return.

; Deactivate flying head: exited screen.
;
; Called from #R37997 when the head column reaches 0, 1 or 29 (screen edges).
;
; .
;
; Writes 0 to IX+1 (#R46810): head is now fully inactive.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF.
@label=deactivate_head
c38186 XOR A         ; Head has left the screen - clear active flag.
 38187 LD (IX+1),A   ; {Set #R46810 to 0: head deactivated.
 38190 RET           ; }

; Move screen pointer down by B scanlines.
;
; Used by the routine at #R37997.
;
; .
;
; Counterpart to #R38201. Adds 32 to HL up to B times, advancing the
; framebuffer address one scanline per iteration.
; .
; INPUT: B = number of scanlines. HL = current framebuffer address. OUTPUT: HL
; = updated address. DESTROYS: A, DE.
@label=move_scanl_down
c38191 LD A,B        ; {Return immediately if B is 0.
 38192 OR A          ;
 38193 RET Z         ; }
*38194 LD DE,32      ; DE = 32 - one scanline.
 38197 ADD HL,DE     ; {Advance HL by one scanline, loop B times.
 38198 DJNZ 38194    ; }
 38200 RET           ; Return.

; Move screen pointer up by B scanlines.
;
; Used by the routine at #R37997.
;
; .
;
; Counterpart to #R38191. Subtracts 32 from HL up to B times, stepping the
; framebuffer address back one scanline per iteration.
; .
; SBC HL,DE requires carry = 0 on entry; not guaranteed by all callers.
; .
; INPUT: B number of scanlines. HL = current framebuffer address. OUTPUT: HL =
; updated address. DESTROYS: A, DE.
@label=move_scanl_up
c38201 LD A,B        ; {Return immediately if B is 0.
 38202 OR A          ;
 38203 RET Z         ; }
*38204 LD DE,32      ; DE = 32 - one scanline.
 38207 SBC HL,DE     ; {Step HL back one scanline, loop B times.
 38209 DJNZ 38204    ; }
 38211 RET           ; Return.

; Move framebuffer pointer one column left (decrements L by 1).
;
; Used by the routine at #R37997.
;
; .
;
; Counterpart to #R38216. Decrements L by 1 while preserving all flags.
; .
; INPUT: HL = current framebuffer address. OUTPUT: HL = HL - 1. DESTROYS none.
@label=move_col_left
c38212 PUSH AF       ; {Save flags, move one column left.
 38213 DEC L         ; }
 38214 POP AF        ; {Restore flags and return.
 38215 RET           ; }

; Move framebuffer pointer one column right.
;
; Used by the routine at #R37997.
;
; .
;
; Counterpart to #R38212. Increments L by 1 while preserving all flags.
; .
; INPUT: HL current framebuffer address.
; .
; OUTPUT: HL = HL + 1. DESTROYS none.
@label=move_col_right
c38216 PUSH AF       ; {Save flags, move one column right.
 38217 INC L         ; }
 38218 POP AF        ; {Restore flags and return.
 38219 RET           ; }

; Player 2 overlay tile renderer.
;
; Composites a single extra tile on top of the P2 sprite each frame to visually
; differentiate P2 from P1, which share the same base sprite bank.
;
; .
;
; #R47223 holds a 1-byte-per-frame overlay tile index (0-52 = tile, 255 = no
; draw) choosen from (#R40192)
; .
; #R47329 holds a 1-byte-per-frame position table: bits 0-5 = scanline offset
; down from row 94; bits 6-7 (after 2x RLCA) = column offset 0-3 right of P2 X
; tile, inverted as 6-L when P2 is mirrored.
; .
; The overlay state block at #R46817 mirrors the layout of the head state block
; at #R46809, letting #R38103 and #R38158 serve both.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, B, DE, HL, IX.
@label=p2_overlay_tile
c38220 LD A,(46434)  ; {Guard: return if #R46434 is zero (never true during
 38223 OR A          ; normal gameplay).
 38224 RET Z         ; }
 38225 LD A,(46437)  ; {Load P2 X tile (#R46437) and framebuffer row base (H =
 38228 LD E,A        ; 94) into DE.
 38229 LD D,94       ; }
 38231 LD A,(46442)  ; Load P2 frame index (#R46442) for table lookups.
 38234 PUSH DE       ; Save DE on stack.
 38235 LD HL,47329   ; {Fetch position byte for this frame from #R47329.
 38238 CALL 38318    ; }
 38241 POP DE        ; Restore DE.
 38242 LD L,A        ; Save full position byte in L.
 38243 AND 63        ; {Extract scanline offset (bits 0-5) into H.
 38245 LD H,A        ; }
 38246 LD A,L        ; Restore full position byte from L.
 38247 AND 192       ; {Extract column offset (bits 6-7) and shift to bits 0-1
 38249 RLCA          ; via 2x RLCA.
 38250 RLCA          ; }
 38251 LD L,A        ; L = column offset (0-3).
 38252 LD A,(46436)  ; {Read P2 mirror flag (#R46436 bit 0).
 38255 AND 1         ; }
 38257 LD (46817),A  ; Store P2 mirror flag in overlay state block (#R46817
                     ; IX+0) for #R38103.
 38260 JR Z,38266    ; Not mirrored - column offset unchanged.
 38262 LD A,6        ; {Mirrored - invert as 6-L so overlay aligns on the
 38264 SUB L         ; correct side.
 38265 LD L,A        ; }
*38266 LD A,E        ; {Add column offset to P2 X tile; final framebuffer
 38267 ADD A,L       ; column into E.
 38268 LD E,A        ; }
 38269 LD B,H        ; {B = scanline offset (H); EX DE,HL sets HL = framebuffer
 38270 EX DE,HL      ; base (H = 94, L = column).}
 38271 LD DE,32      ; {Walk HL down B scanlines (stride 32 each); HL is now
*38274 ADD HL,DE     ; the exact framebuffer destination.
 38275 DJNZ 38274    ; }
 38277 LD (46823),HL ; Store framebuffer destination in overlay state block
                     ; (#R46823, IX+6,7) for #R38103.
 38280 LD A,(46442)  ; {Reload P2 frame index; compute tile index address from
 38283 LD E,A        ; #R47223 + frame index.
 38284 LD D,0        ;
 38286 LD HL,47219   ;
 38289 ADD HL,DE     ; }
 38290 LD (46819),HL ; Store tile sequence pointer in overlay state block
                     ; (#R46819, IX+2,3) for #R38103.
 38293 LD A,(HL)     ; Read tile index for this frame.
 38294 CP 255        ; 255 = no overlay tile this frame.
 38296 RET Z         ; Return if no tile to draw.
 38297 LD IX,46817   ; IX = #R46817, point to P2 overlay state block.
 38301 JP 38103      ; Tail-call #R38103 to blit tile using shared head/overlay
                     ; draw path.

; Generic 16-bit pointer lookup.
;
; Used by the routines at #R35458, #R35765, #R36053, #R36838, #R37486, #R39211
; and #R39317.
;
; .
;
; Reads a pointer from a table given a index in A. Adds A*2 to HL and reads the
; 2-byte entry.
; .
; INPUT: A = index. HL = table base address. OUTPUT: HL = resolved pointer.
; DESTROYS: AF, DE, HL.
@label=solve_pointer
c38304 PUSH DE       ; {Save table base (HL) on the stack.
 38305 PUSH HL       ; }
 38306 LD L,A        ; {HL = A * 2 (byte offset into the pointer table; each
 38307 LD H,0        ; entry is 2 bytes).
 38309 ADD HL,HL     ; }
 38310 POP DE        ; DE = table base.
 38311 ADD HL,DE     ; HL = table base + offset, points to the target entry.
 38312 LD E,(HL)     ; {DE = 16-bit pointer from table entry.
 38313 INC HL        ;
 38314 LD D,(HL)     ; }
 38315 POP HL        ; Restore HL (table base).
 38316 EX DE,HL      ; Swap DE and HL: HL = resolved pointer.
 38317 RET           ; Return.

; Read byte from address.
;
; Get byte value pointed by HL+A
;
; .
;
; INPUT: A = offset. HL = base address. OUTPUT: A = Byte value. DESTROYS: HL.
@label=get_byte_value
c38318 ADD A,L       ; {Add the offset to the low byte of the address.
 38319 LD L,A        ; }
 38320 JR NC,38323   ; {Handle carry: if addition overflowed, increment the
 38322 INC H         ; high byte of the address.}
*38323 LD A,(HL)     ; Read the byte from the calculated address.
 38324 RET           ; Return with the byte value in A.

; Hit section table search.
;
; Scans the hit section table at HL for an entry whose first byte matches the
; attacker frame ID in A.
;
; .
;
; Scans a table of 3-byte entries (frame ID with hit + 2 bytes) until matching
; A or sentinel = 128. On a match, DE is loaded with the 2-byte data pair from
; that entry and Z is set.
; .
; INPUT: A = attacker frame ID. HL = base address of the hit section table
; (#R45015 or #R46747).
; .
; OUTPUT: Z set on match; DE = 2-byte data pair from the matched entry.
; DESTROYS: HL, DE, AF, BC.
@label=find_hit_section
c38325 LD D,(HL)     ; {Read entry key into D; advance HL to the end of the
 38326 INC HL        ; 3-byte entry.
 38327 INC HL        ;
 38328 INC HL        ; }
 38329 BIT 7,D       ; Sentinel reached (128): return NZ (no match).
 38331 RET NZ        ;
 38332 CP D          ; {Frame ID does not match: loop back to next entry.
 38333 JR NZ,38325   ; }
 38335 DEC HL        ; {Match found: backtrack HL and load the 2-byte data pair
 38336 LD D,(HL)     ; into DE.
 38337 DEC HL        ;
 38338 LD E,(HL)     ; }
 38339 RET           ; Return with Z set.

; Mirrors a tile horizontally in-place.
;
; For each scanline: reverses bits of the 3 bytes via table at #R23296.
;
; .
;
; Called from #R38367, #R39258 and #R38158.
; .
; INPUT: B = scanline count. DE = tile address.
; .
; OUTPUT: DE advanced past tile. Tile mirrored in-place. DESTROYS: AF, BC, HL.
@label=mirror_tile_inplace
c38340 LD B,21       ; B=21h: full tile height.
; This entry point is used by the routine at #R39258.
*38342 LD H,91       ; HL base = bit-reversal table (#R23296).
*38344 LD A,(DE)     ; A = byte 0 index from tile.
 38345 LD L,A        ; HL points to reversed byte 0.
 38346 LD C,(HL)     ; C = reversed byte 0.
 38347 INC DE        ; {Next: byte 1 index.
 38348 LD A,(DE)     ; }
 38349 LD L,A        ; HL points to reversed byte 1.
 38350 LD A,(HL)     ; A = reversed byte 1.
 38351 LD (DE),A     ; Write reversed byte 1 in place.
 38352 INC DE        ; {Next: byte 2 index.
 38353 LD A,(DE)     ; }
 38354 LD L,A        ; HL points to reversed byte 2.
 38355 LD A,(HL)     ; A = reversed byte 2.
 38356 DEC DE        ; {Back to byte 0 position.
 38357 DEC DE        ; }
 38358 LD (DE),A     ; {Write reversed byte 2 to byte 0 position.
 38359 INC DE        ; }
 38360 INC DE        ; Advance to byte 2 position.
 38361 LD A,C        ; Recover reversed byte 0 (in C).
 38362 LD (DE),A     ; Write it to byte 2 position.
 38363 INC DE        ; Advance DE to next scanline.
 38364 DJNZ 38344    ; Repeat for B scanlines.
 38366 RET           ; Return.

; Sprites mirror checker and correcter.
;
; Used by the routine at #R37486.
;
; .
;
; Check the 12 tiles of a sprite if needs to be mirrored and do it if required.
; .
; Mirror correction: for each active tile, 3x RLA on the low byte of DE
; extracts the tile orientation bit and compares it with IY+2 bit 0 (mirror
; flag). If they mismatch, bit 6 of the tile index is flipped (XOR 64) and
; #R38340 mirrors the tile pixel data in-place.
; .
; INPUT: IX = Current sprite shapes table. HL = frame data pointer (index 1).
; IY = character state block.
; .
; OUTPUT: None. Framebuffer at H=0x5B updated in place. DESTROYS: AF, BC, DE,
; HL, IX.
@label=sprites_mirror_checker
c38367 LD B,12       ; B=12 tiles to draw.
*38369 LD A,(IX+0)   ; Read slot byte from shapes table via IX+0.
 38372 INC A         ; INC A: test for empty slot (255 wraps to 0).
 38373 JR Z,38407    ; Continue to the next tile shape without changing
                     ; anything else.
; Normal path. Check orientation and paint mirrored if required.
 38375 LD A,(HL)     ; {Read tile index from (HL). Advance HL past tile index.
 38376 INC HL        ; }
 38377 CALL 37355    ; Call #R37355 into DE.
 38380 LD A,(IY+2)   ; Read mirror flag from IY+2, isolate bit 0 into C.
 38383 AND 1         ; {Store mirror flag bit in C.
 38385 LD C,A        ; }
 38386 LD A,(DE)     ; Load low byte of DE (tile orientation byte).
 38387 RLA           ; Shift orientation bit towards bit 0 (RLA x1).
 38388 RLA           ; Shift orientation bit towards bit 0 (RLA x2).
 38389 RLA           ; Shift orientation bit towards bit 0 (RLA x3).
 38390 AND 1         ; Isolate bit 0: tile orientation flag.
 38392 CP C          ; Compare tile orientation with character mirror flag.
 38393 JR Z,38407    ; Orientation matches - tile already correct, skip
                     ; mirroring.
 38395 LD A,(DE)     ; Orientation mismatch - reload tile index.
 38396 XOR 64        ; Flip orientation bit (64) to match it with the new
                     ; orientation.
 38398 LD (DE),A     ; Write corrected tile index back to DE.
 38399 INC E         ; Advance to tile pixel data.
 38400 PUSH HL       ; {Preserve HL and BC across mirror call.
 38401 PUSH BC       ; }
 38402 CALL 38340    ; Mirror tile pixel data in-place via #R38340.
 38405 POP BC        ; {Restore BC and HL.
 38406 POP HL        ; }
; Empty slot path: skip draw.
*38407 INC IX        ; Advance IX to next slot.
 38409 DJNZ 38369    ; Decrement loop counter, repeat for all 12 slots.
 38411 RET           ; Return.

; Flush framebuffer to screen.
;
; Used by the routine at #R35240.
;
; .
;
; Copies 89 scanlines (28 bytes each) from the RAM framebuffer at #R24066 to
; the ZX Spectrum VRAM, using the pre-built VRAM address table at #R23552.
; .
; SP is redirected to #R23560 (#R23552+8), stepping past the top address so
; only the 89 game-area rows are blitted. 28 unrolled LDI instructions copy
; each row without inner-loop overhead.
; .
; Counterpart to #R38547, which fills the framebuffer each frame from the
; active stage background.
; .
; INPUT: None. OUTPUT: None. DESTROYS: All registers. SP: is saved to #R46452
; and restored on exit.
@label=frmbuf_to_scr
c38412 LD (46452),SP ; Save SP to #R46452.
 38416 LD SP,23560   ; Redirect SP to #R23560 - first game-area entry in the
                     ; VRAM address table (#R23552+8 skipping the not updatable
                     ; area).
 38419 LD HL,24194   ; Set HL to #R24194 - framebuffer start of the game area
                     ; (128 bytes past #R24066).
 38422 LD B,89       ; Set B to 89 - game-area row counter.
 38424 LD C,0        ; Set C to 0 - required for LDI to decrement BC correctly.
*38426 POP DE        ; Load the next VRAM row address into DE via POP from the
                     ; redirected SP.
 38427 LDI           ; {Copy one 28-byte scanline from framebuffer to VRAM via
 38429 LDI           ; 28 unrolled LDI instructions.
 38431 LDI           ;
 38433 LDI           ;
 38435 LDI           ;
 38437 LDI           ;
 38439 LDI           ;
 38441 LDI           ;
 38443 LDI           ;
 38445 LDI           ;
 38447 LDI           ;
 38449 LDI           ;
 38451 LDI           ;
 38453 LDI           ;
 38455 LDI           ;
 38457 LDI           ;
 38459 LDI           ;
 38461 LDI           ;
 38463 LDI           ;
 38465 LDI           ;
 38467 LDI           ;
 38469 LDI           ;
 38471 LDI           ;
 38473 LDI           ;
 38475 LDI           ;
 38477 LDI           ;
 38479 LDI           ;
 38481 LDI           ; }
 38483 INC HL        ; {Skip the 4-byte border gap to keep HL aligned to the
 38484 INC HL        ; next framebuffer row.
 38485 INC HL        ;
 38486 INC HL        ; }
 38487 DJNZ 38426    ; Repeat for all 89 game-area rows.
 38489 LD SP,(46452) ; Restore SP from #R46452.
 38493 RET           ; Return.

; Interrupt Vector Table Generator
;
; Used by the routine at #R48896.
;
; .
;
; Will generate all the 257 bytes of the interrupt table where, in loading
; time, are the game start routines never used later.
; .
; INPUT: C = 240, B = 0, HL = 48896 (#R48896)
@label=i_v_t_generator
c38494 LD (HL),C     ; Copy 240($F0) to the future Vector Table (#R48896).
 38495 INC HL        ; Increments in 1 HL
 38496 DJNZ 38494    ; Decrements B and compare with 0 (this loop will execute
                     ; 256 times).
 38498 LD (HL),C     ; After copying the 256 bytes, we need to copy F0 once
                     ; more (257 times).
 38499 RET           ; Returns to #R35244

; Interrupt Service Routine
;
; Triggered by Z80 interrupt mode 2 (IM 2).
;
; .
;
; In execution time, this routine is written by #R49031 to 0xF0F0/61680 (more
; info in #R61569) so the Vector table can call it.
; .
; Two responsibilities: frequency divider via #R47474, combat timer decrement
; via #R46808.
; .
; OUTPUT: #R47474 incremented or reset; #R46808 decremented.
@label=int_serv_routine
c38500 PUSH AF       ; {Preserve AF, BC
 38501 PUSH BC       ; }
 38502 LD A,(47474)  ; #R47474 (ISR frame counter, cycles 0-8).
 38505 INC A         ; Advance counter.
 38506 CP 9          ; Has the counter reached 9 (one timer tick)?
 38508 JR Z,38515    ; Yes: reset counter and process timer.
 38510 LD (47474),A  ; No: store updated counter and exit ISR.
 38513 JR 38542      ; Jump to exit.
*38515 XOR A         ; {Counter reached 9 and is reset to 0.
 38516 LD (47474),A  ; }
 38519 LD A,(46808)  ; #R46808 (combat timer: 90->0 in 2P mode; 255 =
                     ; infinite/1P).
 38522 CP 255        ; Is it infinite-time mode (1P/Demo)?
 38524 JR Z,38542    ; Yes: skip decrement, exit.
 38526 OR A          ; Is timer already 0?
 38527 JR Z,38542    ; Yes: already expired, skip decrement, exit.
 38529 LD B,A        ; No: preserve timer value in B.
 38530 LD A,(46443)  ; {(goblin active flag: 0=inactive, 255=active). Is the
 38533 CP 255        ; goblin currently active?}
 38535 LD A,B        ; Restore timer value into A.
 38536 JR Z,38542    ; Goblin active: freeze timer, exit without decrementing.
 38538 DEC A         ; Decrement combat timer by 1.
 38539 LD (46808),A  ; Store updated timer value back to #R46808.
*38542 POP BC        ; {Restore BC and AF.
 38543 POP AF        ; }
 38544 EI            ; Re-enable interrupts.
 38545 RETI          ; Return from interrupt.

; Copy stage background to framebuffer.
;
; Used by the routine at #R35240.
;
; .
;
; Fills the #R24066 with the active stage background graphics each frame, ready
; for sprite rendering.
; .
; Copies 94 scanlines of 28 bytes each via 28 unrolled LDI instructions per
; row. After each row, four INC DE instructions skip the 4-byte border gap,
; keeping the destination aligned to the next framebuffer row (stride 32,
; graphics width 28).
; .
; INPUT: None. OUTPUT: None. DESTROYS AF, BC, DE, HL.
@label=copy_bg_to_frmbuff
c38547 LD HL,(46459) ; {Load active background address from #R46459 into HL, it
 38550 LD DE,1008    ; adds the offset of the upper (not updatable part).
 38553 ADD HL,DE     ; }
 38554 LD DE,24066   ; Set DE to #R24066, framebuffer start.
 38557 LD B,94       ; B = 94, total scanline rows to copy.
 38559 LD C,0        ; C = 0, initialises BC so LDI decrements BC correctly
                     ; each copy.
*38561 LDI           ; {Copy one 28-byte scanline via 28 unrolled LDI
 38563 LDI           ; instructions.
 38565 LDI           ;
 38567 LDI           ;
 38569 LDI           ;
 38571 LDI           ;
 38573 LDI           ;
 38575 LDI           ;
 38577 LDI           ;
 38579 LDI           ;
 38581 LDI           ;
 38583 LDI           ;
 38585 LDI           ;
 38587 LDI           ;
 38589 LDI           ;
 38591 LDI           ;
 38593 LDI           ;
 38595 LDI           ;
 38597 LDI           ;
 38599 LDI           ;
 38601 LDI           ;
 38603 LDI           ;
 38605 LDI           ;
 38607 LDI           ;
 38609 LDI           ;
 38611 LDI           ;
 38613 LDI           ;
 38615 LDI           ; }
 38617 INC DE        ; {Skip the 4-byte border gap to align DE to the next
 38618 INC DE        ; framebuffer row.
 38619 INC DE        ;
 38620 INC DE        ; }
 38621 DJNZ 38561    ; Repeat for all 94 scanlines.
 38623 RET           ; Return.

; Clear attributes for a row.
;
; Used by the routine at #R38699.
;
; .
;
; Modify colour attributes with customizable width via B and height via C. Used
; in this case to clear attibutes to a complete row.
; .
; Writes A to B consecutive attribute bytes starting at HL, then steps down one
; attribute row (32 bytes) and repeats for C rows total. Produces a solid
; colour fill across the given area.
; .
; Called from #R38699 during the fade-out sequence to progressively blacken
; attribute rows.
; .
; INPUT: HL = top-left tile attribute address. B = tiles per row (28). C = row
; count (01). A = attribute value to write (0 for black).
; .
; OUTPUT: None. DESTROYS: C, DE, HL.
@label=clear_attr_row
c38624 PUSH HL       ; {Save address and counters.
 38625 PUSH BC       ; }
*38626 LD (HL),A     ; {Write attribute value to current tile; advance to next.
 38627 INC HL        ; }
 38628 DJNZ 38626    ; Repeat for all B tiles in this row.
 38630 POP BC        ; {Restore counters and row start address.
 38631 POP HL        ; }
 38632 LD DE,32      ; {Advance HL one attribute row down (stride 32).
 38635 ADD HL,DE     ; }
 38636 DEC C         ; {Decrement row counter; loop if rows remain.
 38637 JR NZ,38624   ; }
 38639 RET           ; Return.

; Fade ink colour to black.
;
; Used by the routine at #R36673.
;
; .
;
; For each of C rows, reads the ink bits of each attribute byte via AND 7 and
; decrements the ink value by 1 unless it is already 0. Processes B tiles per
; row, then advances HL 32 bytes to the next attribute row.
; .
; Called from #R36673 to progressively darken the game window during the
; fade-out transition.
; .
; INPUT: HL = first attribute address (top-left tile). B = tiles per row (26).
; C row count (3).
; .
; OUTPUT: None. DESTROYS A, C, DE, HL.
@label=fade_ink
c38640 PUSH HL       ; {Save row start address and counters.
 38641 PUSH BC       ; }
*38642 LD A,(HL)     ; {Read ink bits from current attribute (AND 7).
 38643 AND 7         ; }
 38645 OR A          ; {Ink already 0 - skip decrement.
 38646 JR Z,38651    ; }
 38648 LD A,(HL)     ; {Reload attribute and decrement ink by 1.
 38649 DEC A         ; }
 38650 LD (HL),A     ; Write decremented value back to attribute byte.
*38651 INC HL        ; Advance to next tile in row.
 38652 DJNZ 38642    ; Repeat for all B tiles in this row.
 38654 POP BC        ; {Restore counters and row start address.
 38655 POP HL        ; }
 38656 LD DE,32      ; {Advance HL one row (stride 32).
 38659 ADD HL,DE     ; }
 38660 DEC C         ; {Decrement row counter; loop if rows remain.
 38661 JR NZ,38640   ; }
 38663 RET           ; Return.

; Step each attribute ink colour one level toward a target.
;
; Called from #R36706 each frame to drive the menu rainbow colour animation.
;
; .
;
; For each of B tiles in the row, reads the ink bits via AND 7. If already at
; the target value A, leaves the tile unchanged. Otherwise increments the ink
; by 1, sets BRIGHT, and writes the result back. After all B tiles, advances HL
; by 32 bytes to the next attribute row and decrements C. If C>1, the outer
; PUSHes accumulate on the stack but are only popped once on exit, corrupting
; the caller's stack.
; .
; The caller relies on DE=32 on return to step between rows via ADD HL,DE.
; .
; INPUT: HL = first attribute address in the row. A = target ink value (0-7). B
; = tiles per row. C = row count (always 1 in game).
; .
; OUTPUT: DE = 32 (row stride; used by caller via ADD HL,DE to advance between
; rows).
; .
; DESTROYS: None (HL, BC, AF all restored via PUSH/POP).
@label=step_ink_up
c38664 PUSH HL       ; {Save row-start address, tile count and target ink for
 38665 PUSH BC       ; final restoration.
 38666 PUSH AF       ; }
 38667 PUSH HL       ; {Save the same values again to preserve B (tile counter)
 38668 PUSH BC       ; and C (row count) across the inner tile loop.
 38669 PUSH AF       ; }
 38670 LD C,A        ; Copy target ink value to C for per-tile comparison.
*38671 LD A,(HL)     ; {Read the ink bits of the current attribute (AND 7).
 38672 AND 7         ; }
 38674 CP C          ; {Already at target - skip this tile without writing.
 38675 JR Z,38683    ; }
 38677 LD A,(HL)     ; {Increment ink by 1, set BRIGHT, and write back to the
 38678 INC A         ; attribute.
 38679 SET 6,A       ;
 38681 LD (HL),A     ; }
 38682 INC HL        ; Advance to the next tile.
*38683 DJNZ 38671    ; Repeat for all B tiles in this row.
 38685 POP AF        ; {Restore tile count, row count and row-start address.
 38686 POP BC        ;
 38687 POP HL        ; }
 38688 LD DE,32      ; {Set DE to 32 (row stride) and advance HL to the next
 38691 ADD HL,DE     ; attribute row.}
 38692 DEC C         ; {Decrement row counter; loop back if rows remain.
 38693 JR NZ,38664   ; }
 38695 POP AF        ; {Restore caller's HL, BC and AF.
 38696 POP BC        ;
 38697 POP HL        ; }
 38698 RET           ; Return.

; Game window row-by-row wipe to black.
;
; Used by the routines at #R36130 and #R36673.
;
; .
;
; Clears the game window from top to bottom one tile row per 112 ms step,
; producing a visible wipe effect. Rows that share columns with the snake HUD
; are cleared via #R38811, which preserves those columns; all other rows use
; #R38796, which clears all 28 tiles. The two bottom rows at attribute-map
; level are cleared separately via #R38624.
; .
; INPUT: None. OUTPUT: None. DESTROYS A, BC, HL.
@label=sweep_transition
c38699 LD HL,16610   ; Set HL to the first tile of the top game window row.
 38702 LD B,2        ; Set loop counter to 2.
*38704 PUSH BC       ; Preserve loop counter before call.
 38705 CALL 38811    ; Clear one snake-edge row preserving HUD columns via
                     ; #R38811.
 38708 POP BC        ; Restore loop counter.
 38709 DJNZ 38704    ; Repeat for the top 2 snake-edge rows.
 38711 LD B,2        ; {Set loop counter to 2.
*38713 PUSH BC       ; }
 38714 CALL 38796    ; {Clear one full 28-tile row and wait 112 ms via #R38796.
 38717 POP BC        ; }
 38718 DJNZ 38713    ; Repeat for the next 2 full rows.
 38720 LD B,3        ; {Set loop counter to 3.
*38722 PUSH BC       ; }
 38723 CALL 38811    ; {Clear one snake-edge row via #R38811.
 38726 POP BC        ; }
 38727 DJNZ 38722    ; Repeat for the next 3 snake-edge rows.
 38729 LD B,8        ; {Set loop counter to 8.
*38731 PUSH BC       ; }
 38732 CALL 38796    ; {Clear one full row and wait 112 ms via #R38796.
 38735 POP BC        ; }
 38736 DJNZ 38731    ; Repeat for 8 full rows.
 38738 XOR A         ; A=0, black attribute value.
 38739 LD HL,23234   ; Set HL to the penultimate attribute row of the game
                     ; window.
 38742 LD BC,7169    ; B=28 (full row width), C=1 (single row).
 38745 CALL 38624    ; Clear the penultimate attribute row to black via
                     ; #R38624.
 38748 CALL 39846    ; Wait 112 ms via #R39846.
 38751 XOR A         ; A=0, black attribute value.
 38752 LD HL,23269   ; Set HL to the last attribute row of the game window.
 38755 LD BC,5633    ; B=22 (erasable tiles in the last partial row), C=1.
 38758 CALL 38624    ; Clear the last row attributes to black via #R38624.
 38761 JP 39846      ; Wait 112 ms and return; tail-calls #R39846.

; Single scanline clear with attribute wipe.
;
; Clears one pixel scanline byte and sets the attribute to black (0) for each
; of the 28 tiles in a row. Called 8 times per tile row by #R38796 to erase all
; pixel data of a full row. #R38790 also shares the inner loop from 38767 with
; B=26 to preserve the leftmost snake column.
;
; .
;
; INPUT: HL = VRAM address of the scanline byte to clear.
; .
; OUTPUT; HL = restored to the entry value. DESTROYS: A, B, DE.
@label=clear_scanline_ink_attr
c38764 PUSH HL       ; Preserve the entry VRAM address.
 38765 LD B,28       ; B=28, one iteration per tile column across the full game
                     ; window row.
; This entry point is used by the routine at #R38790.
*38767 XOR A         ; A=0, value to clear with.
 38768 LD (HL),A     ; {Clear the current VRAM scanline byte.
 38769 CALL 38781    ; }
 38772 LD E,L        ; {Form the full attribute address in DE using A and the
 38773 LD D,A        ; column byte from L.}
 38774 XOR A         ; A=0, black attribute value.
 38775 LD (DE),A     ; Write black attribute (ink=0, paper=0) to this tile.
 38776 INC HL        ; Advance to the next tile column.
 38777 DJNZ 38767    ; Repeat for all tile columns.
 38779 POP HL        ; Restores the caller's HL value.
 38780 RET           ; Return.

; Derive attribute high byte from a VRAM pixel address.
;
; Converts the high byte of a VRAM pixel address to the corresponding attribute
; high byte. Extracts the screen third (0-2) from H and combines it with the
; attribute area base (0x58) to produce 0x58, 0x59 or 0x5A. L is not touched,
; so the caller can form the full attribute address directly from A and L.
;
; .
;
; INPUT: HL = VRAM pixel address. OUTPUT: A attribute high byte (0x58, 0x59 or
; 0x5A). DESTROYS: A.
@label=get_attr_address
c38781 LD A,H        ; {Shift H right by 3 and mask to bits 1-0 to isolate the
 38782 RRCA          ; screen third (0-2).
 38783 RRCA          ;
 38784 RRCA          ;
 38785 AND 3         ; }
 38787 OR 88         ; OR 0x58 to set the attribute area base, forming the
                     ; attribute high byte.
 38789 RET           ; Return with the attribute high byte in A.

; Single scanline clear for snake-edge rows (26 central tiles).
;
; Used by the routine at #R38811.
;
; .
;
; Setups a counter of 26 loops and deletes the pointed scanline of a complete
; row. Used by #R38811.
; .
; INPUT: HL = VRAM address of the first tile of the row.
; .
; OUTPUT: HL = restored to the entry value. DESTROYS A, B, DE.
@label=single_scanline_clear
c38790 PUSH HL       ; Preserve the entry VRAM address.
 38791 LD B,26       ; B=26, skipping the leftmost snake column.
 38793 INC HL        ; Advance past the leftmost snake column.
 38794 JR 38767      ; Jump into the shared scanline-clear loop at #R38764.

; Clear all 28 tiles of one game-window row to black.
;
; Used by the routine at #R38699.
;
; .
;
; Calls #R38764 once per scanline (8 times, one per pixel row within the tile)
; to zero the pixel data and set attributes to black. After the loop, HL
; naturally points to the first scanline of the tile row below. Tail-calls
; #R39846 to insert a 112 ms pause, producing the visible row-by-row wipe delay
; in #R38699.
; .
; INPUT: HL = VRAM address of the first scanline of the tile row to clear.
; .
; OUTPUT: HL = VRAM address of the first scanline of the next tile row.
; .
; DESTROYS: A, B, DE.
@label=clear_row
c38796 LD B,8        ; B=8, one iteration per scanline within the tile row.
*38798 PUSH BC       ; Preserve the loop counter.
 38799 CALL 38764    ; Clear pixel data and attributes for this scanline via
                     ; #R38764.
 38802 CALL 36895    ; Advance HL to the next scanline via #R36895.
 38805 POP BC        ; Restore the loop counter.
 38806 DJNZ 38798    ; Repeat for all 8 scanlines of the tile row.
 38808 JP 39846      ; Tail-call #R39846 to wait 112 ms before returning.

; Clear one game-window row preserving snake edge columns.
;
; Used by the routine at #R38699.
;
; .
;
; Variant of #R38796 for tile rows that share pixel columns with the snake
; border. Iterates 8 scanlines via #R38790, which skips the leftmost column.
; For both snake edge columns only the paper bits in the attribute are cleared
; to black, keeping the ink colour intact. Tail-calls #R39846 for the 112 ms
; inter-row pause.
; .
; INPUT: HL = VRAM address of the first scanline of the tile row to clear.
; OUTPUT: HL = VRAM address of the first scanline of the next tile row.
; DESTROYS: A, B, DE.
@label=clear_snake_row
c38811 LD B,8        ; B=8, one iteration per scanline within the tile row.
 38813 CALL 38781    ; Derive the attribute page high byte for the leftmost
                     ; column via #R38781.
 38816 LD E,L        ; {Form the full attribute address for the left snake
 38817 LD D,A        ; column in DE.}
 38818 LD A,(DE)     ; {Read the left snake column attribute, clear its paper
 38819 AND 199       ; bits to black and write it back.
 38821 LD (DE),A     ; }
*38822 PUSH BC       ; Preserve the loop counter.
 38823 CALL 38790    ; Clear the 26 central tile columns for this scanline via
                     ; #R38790.
 38826 CALL 36895    ; Advance HL to the next scanline via #R36895.
 38829 POP BC        ; Restore the loop counter.
 38830 DJNZ 38822    ; Repeat for all 8 scanlines of the tile row.
 38832 CALL 38781    ; Derive the attribute page high byte from the current HL
                     ; position via #R38781.
 38835 LD E,L        ; {Form the attribute address of the first column of the
 38836 LD D,A        ; next tile row in DE.}
 38837 DEC DE        ; {Step DE back 5 bytes to reach the rightmost column
 38838 DEC DE        ; (column 27) of the current tile row.
 38839 DEC DE        ;
 38840 DEC DE        ;
 38841 DEC DE        ; }
 38842 LD A,(DE)     ; {Read the right snake column attribute and clear its
 38843 AND 199       ; paper bits to black.}
 38845 LD (DE),A     ; Write the updated attribute back to the right snake
                     ; column.
 38846 JP 39846      ; Tail-call #R39846 to wait 112 ms before returning.

; Blit stage background to screen row by row.
;
; Used by the routine at #R35240.
;
; .
;
; Copies backfround tile graphics and RLE colour attributes from the active
; background source to VRAM one row at a time, inserting a 112 ms pause after
; each of the first 15 rows to produce a visible top-to-bottom reveal. The
; final 2 rows are blitted without a pause. Resets the attribute stream pointer
; #R46461 to its initial value on exit so the next call starts from the
; beginning of the attribute table.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, BC, DE, HL.
@label=paints_stage_screen
c38849 LD HL,(46461) ; {Load the initial attribute stream address from #R46614
 38852 PUSH HL       ; and preserve it on the stack for the reset at the end.}
 38853 LD DE,(46459) ; Load the active stage graphics source address from
                     ; #R46459 into DE (#R26752 stage 1, #R30112 stage 2).
 38857 LD HL,16610   ; Set HL to the VRAM address of the first tile of the game
                     ; window.
 38860 LD B,15       ; B=15, one iteration per row for the top section; the
                     ; last 2 rows are handled separately without a pause.
*38862 PUSH BC       ; Preserve the loop counter.
 38863 CALL 38936    ; Copy one full tile row (28 tiles, 8 scanlines) from
                     ; source to VRAM via #R38936; DE and HL advance to the
                     ; next row.
 38866 CALL 38898    ; Apply RLE colour attributes to the current VRAM row via
                     ; #R38898; #R46461 advances to the next attribute entry.
 38869 CALL 39846    ; Wait 112 ms via #R39846.
 38872 POP BC        ; Restore the loop counter.
 38873 DJNZ 38862    ; Repeat for all 15 rows.
 38875 LD HL,22466   ; Advance DE and HL to the penultimate row.
 38878 CALL 38898    ; Copy the penultimate row via #R38936.
 38881 CALL 39846    ; Apply attributes to the penultimate row via #R38898.
 38884 LD HL,22501   ; Advance DE and HL to the last row.
 38887 CALL 38898    ; Copy the last row via #R38936.
 38890 CALL 39846    ; Apply attributes to the last row via #R38898.
 38893 POP HL        ; Restore initial attribute stream address from the stack.
 38894 LD (46461),HL ; Write restored address to #R46461, resetting the
                     ; attribute stream pointer for the next call.
 38897 RET           ; Return.

; Apply RLE colour attributes to a screen row.
;
; Used by the routine at #R38849.
;
; .
;
; Reads the RLE attribute stream from #R46461 and writes colour attributes. The
; stream is a sequence of count+value byte pairs. Each pair applies one
; attribute byte to the next <count> consecutive tiles. A count of 255 signals
; the end of the row.
; .
; After the row is processed, #R46461 is advanced past the end-of-row marker,
; ready for the next row.
; .
; INPUT: HL = VRAM address of any scanline within the target screen row.
; #R46461 active stage attribute stream pointer. OUTPUT: None. DESTROYS: AF,
; BC, DE, HL, alternate registers.
@label=apply_bg_attr_row
c38898 PUSH HL       ; Pushes the VRAM row address to carry it across the EXX
                     ; boundary.
 38899 EXX           ; Switches to the alternate register set.
 38900 POP HL        ; Recovers the VRAM row address in the now-active
                     ; alternate HL.
 38901 CALL 36879    ; Steps back to the top scanline of this tile row via
                     ; #R36879.
 38904 CALL 38781    ; Derives the attribute RAM high byte for this row via
                     ; #R38781.
 38907 LD H,A        ; {Forms DE as the attribute RAM address for the first
 38908 EX DE,HL      ; tile of this row.}
 38909 LD HL,(46461) ; {Loads the stream pointer from #R46461 and reads the
*38912 LD A,(HL)     ; next stream byte into A.}
; Stream format: count+value byte pairs. The first byte of each pair is the
; number of consecutive tiles to colour; the second is the attribute value to
; apply. A count of 255 ends the row.
 38913 CP 255        ; {End-of-row check; jumps to the pointer update step if
 38915 JR Z,38930    ; the stream byte is 255.}
 38917 LD B,A        ; Stores the tile run length in B.
 38918 INC HL        ; Advances to the attribute value byte of this pair.
 38919 LD A,(HL)     ; {Reads the attribute value and writes it to the current
*38920 LD (DE),A     ; tile in attribute RAM.}
 38921 INC DE        ; Advances to the next tile in attribute RAM.
 38922 DJNZ 38920    ; Repeats for all tiles in this run.
 38924 INC HL        ; Advances to the next count+value pair in the stream.
 38925 LD (46461),HL ; Saves the updated stream pointer to #R46461.
 38928 JR 38912      ; Loops back to process the next pair.
*38930 INC HL        ; Advances past the end-of-row marker.
 38931 LD (46461),HL ; Saves the updated stream pointer to #R46461.
 38934 EXX           ; Restores the caller's alternate registers.
 38935 RET           ; Returns.

; Copy one tile row from stage background directly to screen.
;
; Used by the routine at #R38849.
;
; .
;
; Copies all 8 scanlines of a 28-tile-wide row from the stage background
; graphics to the ZX Spectrum screen VRAM. Called from #R38849 to paint the
; stage row by row during screen transitions.
; .
; INPUT: DE = stage background source address. HL = VRAM destination address,
; top scanline of the target tile row.
; .
; OUTPUT: HL = VRAM address of the next tile row below. DE = advanced by 224
; bytes (28 bytes x 8 scanlines).
; .
; DESTROYS AF, B.
@label=copy_bg_row
c38936 LD B,8        ; Sets the scanline counter to 8, one iteration per
                     ; scanline of the tile row.
*38938 PUSH BC       ; {Saves the loop counter and the address for the current
 38939 PUSH HL       ; scanline.}
 38940 CALL 38951    ; Copies one 28-byte scanline from the stage background to
                     ; VRAM via #R38951.
 38943 POP HL        ; Restores the VRAM address to the start of the current
                     ; scanline.
 38944 CALL 36895    ; Advances the VRAM pointer to the next scanline via
                     ; #R36895.
 38947 POP BC        ; Restores the loop counter.
 38948 DJNZ 38938    ; Repeats for all 8 scanlines of the tile row.
 38950 RET           ; Returns once the full tile row has been copied.

; Copy one 28-byte scanline from stage background to screen.
;
; Copies exactly 28 bytes from the stage background source at DE to the screen
; at HL, advancing both pointers. Called 8 times per tile row by #R38936.
;
; .
;
; INPUT: DE = stage background source address. HL = VRAM destination address.
; .
; OUTPUT: DE and HL both advanced by 28 bytes. DESTROYS AF, B.
@label=copy_bg_scanline
c38951 LD B,28       ; Sets the tile column counter to 28.
*38953 LD A,(DE)     ; {Reads one background byte and writes it to VRAM.
 38954 LD (HL),A     ; }
 38955 INC HL        ; {Advances both source and destination pointers.
 38956 INC DE        ; }
 38957 DJNZ 38953    ; Repeats for all 28 tile columns.
 38959 RET           ; Returns to #R38936.

; Loser X tile position controller
;
; Used by the routine at #R39020.
;
; .
;
; Advances the active character X tile by the per-frame animation delta.
; .
; If the character is in an exit animation (mv29, 31, 32 or 33), increments X
; by 1 per frame until X reaches 30, then tail-calls #R37631 to end the fight.
; .
; For all other animations, applies the signed delta from the frame
; displacement table, clamping to the play-area boundary (column 23).
; .
; INPUT: IY = active character state block.
; .
; OUTPUT: IY+3 = updated X tile, or tail-call to #R37631 when exit animation
; clears the screen. DESTROYS: AF, B, HL.
@label=x_pos_controller
c38960 LD A,(IY+6)   ; Load active movement ID from IY+6.
 38963 CP 31         ; {Test for exit animations (mv29, 31, 32, 33); if
 38965 JR Z,39007    ; matched, jump to exit path (#R39007).
 38967 CP 29         ;
 38969 JR Z,39007    ;
 38971 CP 32         ;
 38973 JR Z,39007    ;
 38975 CP 33         ;
 38977 JR Z,39007    ; }
 38979 LD A,(IY+8)   ; {Read per-frame X displacement for the current animation
 38982 LD HL,61568   ; frame from the table at #R61568.
 38985 CALL 38318    ; }
 38988 BIT 0,(IY+2)  ; {Check mirror flag in IY+2; if set, negate (mirrors) the
 38992 JR Z,38996    ; displacement for a left-facing character.
 38994 NEG           ; }
*38996 LD B,(IY+3)   ; Load current X tile from IY+3.
 38999 ADD A,B       ; Apply displacement to get new X tile.
 39000 CP 24         ; Discard if result reaches or exceeds play-area boundary
                     ; (column 24).
 39002 RET NC        ; Return without updating IY+3.
 39003 LD (IY+3),A   ; Store updated X tile in IY+3.
 39006 RET           ; Return.
; Exit animation path.
*39007 LD A,(IY+3)   ; {Increment X by 1 toward the right screen edge and store
 39010 INC A         ; in IY+3.
 39011 LD (IY+3),A   ; }
 39014 CP 30         ; Check whether X has reached column 30 (character fully
                     ; off-screen).
 39016 RET NZ        ; Not yet: return and continue exit animation.
 39017 JP 37631      ; Tail-call #R37631 to end the fight.

; X position update and tackle proximity gate.
;
; Used by the routine at #R39827.
;
; .
;
; Advances the active character X position tile via #R38960, then recomputes
; the fighter distance. If the new distance is negative (bit 7 set), the
; fighters have overlapped after the step. In that case, if neither fighter is
; in an exit or death movement, tackle detection is armed (#R47575=1). If one
; fighter is rolling (mv17) and the other has reached the jump-over frames (8
; or 9), the flag stays set and #R39968 handles the cross-side sequence. If no
; roll/jump-over match is found, the step is reversed.
; .
; INPUT: IY = active character state block. B = X tile before the step (saved
; by #R39827).
; .
; OUTOUT: #R47575 set to 1 if tackle condition is met; 0 if the step was rolled
; back. DESTROYS: AF, BC.
; .
; Advances the active character X tile and recomputes fighter distance.
@label=x_update_and_tackle_gate
c39020 CALL 38960    ; Advance the X tile for the current frame via #R38960.
 39023 LD C,B        ; Save pre-step X tile for possible rollback.
 39024 LD A,(46834)  ; Load pre-step distance from #R46834.
 39027 LD B,A        ; Save pre-step distance for possible rollback.
 39028 PUSH BC       ; Save pre-step X tile and distance on the stack.
 39029 CALL 39856    ; Recompute fighter distance after the step via #R39856.
 39032 POP BC        ; Restore pre-step values.
; Returns immediately if a tackle sequence is already active.
 39033 LD A,(47575)  ; Load tackle state from #R47575.
 39036 OR A          ; Test if a tackle sequence is already active.
 39037 RET NZ        ; Return - tackle already in progress.
; Checks whether the step produced an overlap (negative distance, bit 7 set).
 39038 LD A,(46834)  ; Load updated distance to test for overlap.
 39041 BIT 7,A       ; Bit 7 set means the step produced a negative distance -
                     ; fighters have overlapped.
 39043 JR NZ,39046   ; Overlap detected - proceed to exit-movement guards.
 39045 RET           ; No overlap - fighters are still apart, return.
; Guards: returns if either fighter is in an exit or death movement.
*39046 LD A,(46431)  ; Load P1 movement ID to screen for exit or death
                     ; animations.
 39049 CP 8          ; P1 is decapitated (mv8 #R44558).
 39051 RET Z         ; Return - no tackle during this movement.
 39052 CP 27         ; P1 is in a death animation (mv27 #R44647).
 39054 RET Z         ; Return.
 39055 CP 31         ; P1 is in a body-drag exit (mv31 #R44686).
 39057 RET Z         ; Return.
 39058 CP 29         ; P1 is in a body-drag exit (mv29 #R44675).
 39060 RET Z         ; Return.
 39061 CP 33         ; P1 is in a body-drag exit (mv33 #R44702).
 39063 RET Z         ; Return.
 39064 CP 32         ; P1 is in a body-drag exit (mv32 #R44694).
 39066 RET Z         ; Return.
 39067 LD A,(46440)  ; Load P2 movement ID to screen for exit or death
                     ; animations.
 39070 CP 8          ; P2 is decapitated (mv8 #R44558).
 39072 RET Z         ; Return.
 39073 CP 27         ; P2 is in a death animation (mv27 #R44647).
 39075 RET Z         ; Return.
 39076 CP 31         ; P2 is in a body-drag exit (mv31 #R44686).
 39078 RET Z         ; Return.
 39079 CP 29         ; P2 is in a body-drag exit (mv29 #R44675).
 39081 RET Z         ; Return.
 39082 CP 33         ; P2 is in a body-drag exit (mv33 #R44702).
 39084 RET Z         ; Return.
 39085 CP 32         ; P2 is in a body-drag exit (mv32 #R44694).
 39087 RET Z         ; Return.
; Arms tackle detection and checks whether either fighter is rolling.
 39088 LD A,1        ; Both fighters are eligible for tackle detection.
 39090 LD (47575),A  ; Arm tackle detection in #R47575.
 39093 LD A,(46431)  ; Load P1 movement ID to check for an active roll.
 39096 CP 17         ; P1 is rolling (mv17 #R44605) - check whether P2 is in
                     ; the jump-over phase.
 39098 JR Z,39120    ; P1 rolling confirmed - jump to jump-over check.
 39100 LD A,(46440)  ; Load P2 movement ID to check for an active roll.
 39103 CP 17         ; P2 is rolling (mv17 #R44605) - check whether P1 is in
                     ; the jump-over phase.
 39105 JR Z,39131    ; P2 rolling confirmed - jump to jump-over check.
; Rollback: reverses the overlap step and clears the tackle flag.
*39107 XOR A         ; Neither fighter is rolling - reverse the overlap step.
 39108 LD (47575),A  ; Clear tackle flag.
 39111 LD A,B        ; Recover pre-step distance.
 39112 LD (46834),A  ; Restore pre-step distance to #R46834.
 39115 LD A,C        ; Recover pre-step X tile.
 39116 LD (IY+3),A   ; Undo the overlap step by restoring the pre-step X tile.
 39119 RET           ; Return.
; P1 rolling: checks whether P2 has reached the jump-over phase (frame 8 or 9).
*39120 LD A,(46442)  ; P1 rolling - load P2 frame index to check jump-over
                     ; state.
 39123 CP 8          ; P2 is at jump-over frame 8. #R43829
 39125 RET Z         ; Return with tackle flag set - #R39968 drives the
                     ; cross-side phase.
 39126 CP 9          ; P2 is at jump-over frame 9. #R43838
 39128 RET Z         ; Return.
 39129 JR 39107      ; P2 not yet in jump-over phase - reverse the overlap
                     ; step.
; P2 rolling: checks whether P1 has reached the jump-over phase (frame 8 or 9).
*39131 LD A,(46433)  ; P2 rolling - load P1 frame index to check jump-over
                     ; state.
 39134 CP 8          ; P1 is at jump-over frame 8. #R43829
 39136 RET Z         ; Return with tackle flag set - #R39968 drives the
                     ; cross-side phase.
 39137 CP 9          ; P1 is at jump-over frame 9. #R43838
 39139 RET Z         ; Return.
 39140 JR 39107      ; P1 not yet in jump-over phase - reverse the overlap
                     ; step.

; Mirror-corrected directional input.
;
; Used by the routines at #R35765 and #R39156.
;
; .
;
; If the character is mirrored (IY+2 bit 0 set) and a horizontal direction is
; pressed (bits 0 or 1 of A), swaps Right (bit 0) and Left (bit 1) via XOR 3.
; .
; This ensures the movement table lookup in #R39211 always treats
; towards-opponent as Right and away-from-opponent as Left, regardless of which
; side the character faces.
; .
; INPUT: A = key state bitmask (bit 0=Right, bit 1=Left, bit 2=Down, bit 3=Up,
; bit 4=Fire). IY+2 bit 0 mirror flag.
; .
; OUTPUT: A = adjusted key state with Left/Right possibly swapped. DESTROYS: B.
@label=input_mirror_correcter
c39142 LD B,A        ; {Save key state; mask to horizontal bits only (AND 3).
 39143 AND 3         ; }
 39145 LD A,B        ; {No horizontal input pressed; restore A and return
 39146 RET Z         ; unchanged.}
 39147 BIT 0,(IY+2)  ; {Mirror flag clear; return unchanged.
 39151 RET Z         ; }
 39152 LD A,B        ; {Swap Right and Left bits (XOR 3) to correct for
 39153 XOR 3         ; mirrored facing.}
 39155 RET           ; Return with adjusted key state in A.

; Input-gated movement transition.
;
; Called every frame from #R39827. Runs through three gates before attempting a
; movement change; returns early if any fails:
;
; .
;
; 1. Current movement is non-interruptible (bit 6 of its properties byte in
; #R44755).
; .
; 2. A special event is active (#R47575 != 0, e.g. tackle or collision).
; .
; 3. Current frame is non-controllable (IY+2 bit 7 set).
; .
; If all gates pass, mirror-corrects the input via #R39142, resolves a
; candidate movement via #R39211, and returns unchanged if the result is 255 or
; matches the current movement. On a valid new movement, applies it via #R36838
; and rewinds the frame pointer by 1 so the animation starts at its first real
; frame.
; .
; INPUT: IY = character state block (#R46425 or #R46434).
; .
; OUTPUT: None. Updates IY+6 (movement ID), IY+4/IY+5 (frame pointer) and IY+2
; (mirror flag) via #R36838. DESTROYS: AF, HL.
@label=input_gated_moves
c39156 LD A,(IY+6)   ; {Read movement properties byte from #R44755 using the
 39159 LD HL,44755   ; current movement ID; test the non-interruptible flag
 39162 CALL 38318    ; (bit 6).
 39165 BIT 6,A       ; }
 39167 RET NZ        ; Non-interruptible movement active (death, victory);
                     ; return.
 39168 LD A,(47575)  ; {Special event in progress (#R47575 != 0); return.
 39171 OR A          ;
 39172 RET NZ        ; }
 39173 LD A,(IY+1)   ; {Read key state and apply mirror correction for
 39176 CALL 39142    ; direction via #R39142.}
 39179 BIT 7,(IY+2)  ; {Current frame is non-controllable (IY+2 bit 7); return.
 39183 RET NZ        ; }
 39184 CALL 39211    ; Resolve candidate movement ID from current input via
                     ; #R39211.
 39187 CP 255        ; No transition defined for this input/movement
                     ; combination; return.
 39189 RET Z         ;
 39190 CP (IY+6)     ; {Candidate matches current movement; return without
 39193 RET Z         ; change.}

; Force-apply new movement.
;
; Used by #R39518 (hit collision resolver) to bypass all input gates and push a
; new movement directly onto the character block, regardless of controllability
; state.
;
; .
;
; INPUT: A new movement ID. IY defender character state block.
; .
; OUTPUT: None. DESTROYS: AF, BC, HL
@label=force_apply_moves
c39194 CALL 36838    ; Apply new movement to the character block via #R36838.
 39197 LD L,(IY+4)   ; {Rewind the frame pointer (IY+4/IY+5) by 1 so the new
 39200 LD H,(IY+5)   ; animation starts at its first real frame.
 39203 DEC HL        ;
 39204 LD (IY+4),L   ;
 39207 LD (IY+5),H   ; }
 39210 RET           ; Return.

; Movement transition resolver.
;
; Called from #R39156 with the mirror-adjusted key state in A.
;
; .
;
; Performs a two-level table lookup to find the candidate movement ID:
; .
; Level 1: maps the lower 4 direction bits of the key state to an input class
; (0-8) via #R47458, collapsing 16 combos into 9 meaningful classes.
; .
; Level 2: uses the Fire button (IY+1 bit 4) to select the transition table -
; #R44795 (no fire: walks, crouches, rolls) or #R44851 (fire: attacks) - then
; resolves a pointer for the current movement ID and reads the resulting
; movement ID at the input class offset.
; .
; Returns 255 if no transition is defined for the current input/movement
; combination.
; .
; INPUT: A = adjusted key state. IY = character state block.
; .
; OUTPUT: A = new movement ID, or 255 if no transition applies. DESTROYS: AF,
; DE, HL.
@label=moves_solver
c39211 AND 15        ; Strip the Fire bit; keep only the 4 direction bits.
 39213 LD HL,47458   ; {Look up the input class index (0-8) for this direction
 39216 CALL 38318    ; combination via #R47458.}
 39219 LD E,A        ; {Store the input class as a 16-bit offset for the
 39220 LD D,0        ; pointer walk.}
 39222 BIT 4,(IY+1)  ; {Fire pressed - jump to attack transition table at
 39226 JR NZ,39233   ; #R39233.}
 39228 LD HL,44795   ; Fire not pressed - select the movement transition
                     ; pointer table #R44795.
 39231 JR 39236      ; Skip to shared table resolution.
*39233 LD HL,44851   ; Fire pressed - select the attack transition pointer
                     ; table #R44851.
*39236 LD A,(IY+6)   ; {Resolve the 2-byte transition row pointer for the
 39239 CALL 38304    ; current movement ID via #R38304.}
 39242 ADD HL,DE     ; Advance the pointer by the input class offset to reach
                     ; the target transition entry.
 39243 LD A,(HL)     ; {Read and return the resulting movement ID.
 39244 RET           ; }

; Read movement properties byte.
;
; Used by the routines at #R36838 and #R39617.
;
; .
;
; Reads the properties byte for the given movement ID from the table at
; #R44755.
; .
; INPUT: A = movement ID. OUTPUT: A = properties byte. DESTROYS: None.
@label=get_moves_properties
c39245 PUSH HL       ; {Preserve HL and DE.
 39246 PUSH DE       ; }
 39247 LD HL,44755   ; Load movement properties table base #R44755.
 39250 LD E,A        ; {Form a 16-bit offset from the movement ID.
 39251 LD D,0        ; }
 39253 ADD HL,DE     ; Advance to the target entry.
 39254 LD A,(HL)     ; Read the properties byte.
 39255 POP DE        ; {Restore HL and DE.
 39256 POP HL        ; }
 39257 RET           ; Return.

; Snake energy bar renderer.
;
; Used by the routines at #R35240 and #R35381.
;
; .
;
; Blits the current snake animation frame to the HUD energy bar for each
; character whose draw phase is active (high nibble of IY+7 non-zero).
; .
; P1 bar (VRAM 16416): the sprite is mirrored in-place before blitting and
; restored afterwards, since P1 faces right and needs the flipped orientation.
; .
; P2 bar (VRAM 16445): blitted in its natural orientation.
; .
; INPUT: None. OUTPUT: None. DESTROYS: IY, AF, BC, DE, HL.
@label=draw_snakes_sprites
c39258 LD IY,46425   ; Select P1 state block. (#R46425)
 39262 LD A,(IY+7)   ; Load P1 packed energy/phase byte.
 39265 AND 240       ; Isolate draw phase index.
 39267 JR Z,39295    ; Phase idle - skip P1 bar update.
 39269 CALL 39317    ; Advance draw phase and fetch snake sprite pointer via
                     ; #R39317.
 39272 PUSH DE       ; Save sprite pointer for the restore pass.
 39273 PUSH DE       ; Save sprite pointer for the blit pass.
 39274 LD B,30       ; Set scanline count for the mirror operation.
 39276 CALL 38342    ; Mirror snake sprite in-place via #R38342.
 39279 POP DE        ; Restore pointer to the now-mirrored sprite data.
 39280 LD HL,16416   ; Set P1 energy bar VRAM destination.
 39283 LD BC,798     ; Set blit dimensions - 3 bytes wide, 30 scanlines.
 39286 CALL 37387    ; Blit mirrored sprite to P1 energy bar via #R37387.
 39289 POP DE        ; Restore pointer to the mirrored sprite data.
 39290 LD B,30       ; Set scanline count for the restore pass.
 39292 CALL 38342    ; Un-mirror sprite in-place via #R38342, restoring
                     ; original data for reuse.
*39295 LD IY,46434   ; Select P2 state block.
 39299 LD A,(IY+7)   ; Load P2 packed energy/phase byte.
 39302 AND 240       ; Isolate draw phase index.
 39304 RET Z         ; Phase idle - return.
 39305 CALL 39317    ; Advance draw phase and fetch snake sprite pointer via
                     ; #R39317.
 39308 LD HL,16445   ; Set P2 energy bar VRAM destination.
 39311 LD BC,798     ; Set blit dimensions - 3 bytes wide, 30 scanlines.
 39314 JP 37387      ; Tail-call to blit sprite to P2 energy bar via #R37387.

; Snake animation phase stepper.
;
; Used by the routine at #R39258.
;
; .
;
; Advances the draw phase index in the high nibble of IY+7 by 1 each call,
; leaving the current energy value in the low nibble intact.
; .
; When the index reaches 14 the animation cycle is complete and it resets to 0
; (idle). Uses the resulting index to resolve a pointer to the corresponding
; snake sprite frame via the table at #R47528.
; .
; IY+7 byte layout: bits 7-4 draw phase (0 idle, 1-13 active, 14->0 wrap); bits
; 3-0 current energy value (0-13).
; .
; INPUT: IY = character state block (#R46425 P1 or #R46434 P2).
; .
; OUTPUT: A = first byte of the snake sprite frame. DE = pointer to the next
; byte.
; .
; DESTROYS: AF, BC, DE, HL.
@label=update_snake_frame_id
c39317 LD A,(IY+7)   ; Load packed energy/phase byte from IY+7.
 39320 AND 240       ; {Extract the draw phase index from the high nibble and
 39322 RLCA          ; advance it by 1.
 39323 RLCA          ;
 39324 RLCA          ;
 39325 RLCA          ;
 39326 INC A         ;
 39327 LD B,A        ; }
 39328 RRCA          ; {Shift the incremented index back to the high nibble
 39329 RRCA          ; position.
 39330 RRCA          ;
 39331 RRCA          ;
 39332 LD C,A        ; }
 39333 LD A,(IY+7)   ; {Merge the updated phase index with the preserved energy
 39336 AND 15        ; nibble and write back to IY+7.
 39338 OR C          ;
 39339 LD (IY+7),A   ; }
 39342 LD A,B        ; {Check whether the 14-step animation cycle has
 39343 CP 14         ; completed.}
 39345 JR NZ,39356   ; Cycle not complete - jump to table lookup with the
                     ; current phase index.
 39347 LD A,(IY+7)   ; {Cycle complete - clear the phase index in IY+7,
 39350 AND 15        ; resetting the bar to idle.
 39352 LD (IY+7),A   ; }
 39355 XOR A         ; Use index 0 to address the idle-state table entry.
*39356 LD HL,47528   ; Load snake animation pointer table base #R47528.
 39359 CALL 38304    ; Resolve the sprite frame pointer for the current phase
                     ; index via #R38304.
 39362 PUSH HL       ; {Transfer the frame pointer, load the first sprite byte,
 39363 POP DE        ; and advance past it.
 39364 LD A,(DE)     ;
 39365 INC E         ; }
 39366 RET           ; Return.

; Energy decrement, bar display and KO detection.
;
; Used by the routines at #R36822, #R37772 and #R39518.
;
; .
;
; Called by #R39518 after a hit connects with a non-zero knockback type.
; .
; Decrements the energy value stored in the low nibble of IY+7 (range 0-13).
; .
; If energy underflows (was 0, DEC wraps to 255), triggers KO sequence: sets
; movement 27 (death) on the loser and movement 36 (victory pose) on the
; winner, then forces the energy display to show the empty bar.
; .
; SELF-MODIFYING TARGET: the instruction at #R39371 is patched from RET Z to
; NOP by #R36212 and #R36508 on game start. In the unpatched binary it prevents
; P1 from ever losing energy (demo/attract mode protection).
; .
; INPUT: IY = defender state block (#R46425 P1 or #R46434 P2).
; .
; OUTPUT: None. DESTROYS: AF, BC, DE, HL.
@label=energy_dec
c39367 LD A,IYl      ; Load character type to determine if this is P1.
 39369 CP 89         ; P1 check - fall through to energy gate if P1.
@label=p1_energy_gate
 39371 RET Z         ; SELF-MODIFYING CODE TARGET. Patched to NOP on game
                     ; start; as shipped, RET Z skips P1 energy loss entirely.
 39372 LD A,(IY+7)   ; Load packed energy/phase byte from IY+7.
 39375 AND 15        ; Isolate the current energy value.
 39377 DEC A         ; Decrement energy.
 39378 CP 255        ; Energy underflowed - jump to KO sequence.
 39380 JR Z,39434    ; Jump to KO sequence if underflow.
*39382 OR 16         ; Activate energy bar redraw cycle for this character.
 39384 LD (IY+7),A   ; Write updated energy byte back to IY+7.
; Redraws the 3-chars energy bar at column 0 (player 1) or 29 (P2/P2).
 39387 AND 15        ; Convert energy to a segment display index.
 39389 SRL A         ; Halve to get the 3-segment bar index (0-6).
 39391 LD HL,46827   ; Base of energy bar attribute data #R46827.
 39394 CALL 38318    ; Read display byte for this segment via #R38318.
 39397 EX AF,AF'     ; Save display byte across the address calculation.
 39398 LD H,64       ; Set attribute page base.
 39400 LD A,IYl      ; Reload character type.
 39402 CP 89         ; {Jump to P2 bar address if not P1.
 39404 JR NZ,39410   ; }
 39406 LD L,0        ; P1 energy bar column - left HUD.
 39408 JR 39412      ; Jump to shared draw.
*39410 LD L,29       ; P2 energy bar column - right HUD.
*39412 LD B,3        ; Draw 3 bar segments.
 39414 EX AF,AF'     ; Restore display byte.
*39415 LD C,A        ; Copy display byte for segment extraction.
 39416 AND 3         ; Extract first segment type (bits 0-1).
 39418 ADD A,58      ; Convert to UDG ASCII code for this segment shape.
 39420 PUSH BC       ; Preserve loop state.
 39421 PUSH HL       ; Preserve screen address.
 39422 CALL 35996    ; Draw segment glyph via #R35996.
 39425 POP HL        ; Restore screen address.
 39426 POP BC        ; Restore loop state.
 39427 INC L         ; Advance to next column.
 39428 LD A,C        ; Reload display byte.
 39429 RRA           ; Shift to next segment field.
 39430 RRA           ; Shift again to align to the next 2-bit field.
 39431 DJNZ 39415    ; Repeat for all 3 segments.
 39433 RET           ; Return - energy decremented and bar redrawn.
; If energy underflows from 0 to 255 (DEC A wraps), triggers the KO sequence.
*39434 LD A,27       ; KO - apply death movement to loser.
 39436 CALL 36838    ; Apply movement 27 via #R36838.
 39439 PUSH IY       ; Preserve loser state block.
 39441 LD A,IYl      ; Load loser character type.
 39443 CP 89         ; Was loser P1?
 39445 JR Z,39453    ; Yes - winner is P2, select P2 state block.
 39447 LD IY,46425   ; P1 block - winner when loser was P2.
 39451 JR 39457      ; Jump to apply victory movement.
*39453 LD IY,46434   ; P2 block - winner when loser was P1.
*39457 LD A,36       ; Apply victory pose movement 36 to winner.
 39459 CALL 36838    ; Apply movement 36 via #R36838.
 39462 POP IY        ; Restore loser state block.
 39464 LD A,16       ; Set display value for empty bar.
 39466 JR 39382      ; Jump back to redraw bar as empty.

; Per-frame hit detection.
;
; Used by the routine at #R35240.
;
; .
;
; Called once per frame from the main game loop.
; .
; Skips entirely if #R47475 is non-zero (throttled by #R40092).
; .
; Runs the attacker/defender check twice: first with P1 as attacker and P2 as
; defender, then reversed. For each pass, reads the attacker frame index and
; searches the hit section table #R45015 via #R38325. On a match, walks
; .
; the section pairs comparing defender frame index against IY+8. On a match,
; calls #R39518 to validate range and resolve the hit.
; .
; Hit section table #R45015 format: each section starts with the attacker frame
; ID, followed by (defender frameID, hitTypeIndex) pairs, terminated by 0xFF.
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX, IY.
@label=hit_detection
c39468 LD A,(47475)  ; {Read frame skip counter #R47475 - return if non-zero.
 39471 OR A          ;
 39472 RET NZ        ; }
 39473 LD IX,46425   ; {Set up P1 as attacker (IX) and P2 as defender (IY).
 39477 LD IY,46434   ; }
 39481 CALL 39492    ; Call #R39492 to run hit detection for this
                     ; attacker/defender pair.
 39484 LD IY,46425   ; Set up P2 as attacker (IX) and P1 as defender (IY).
 39488 LD IX,46434   ; Fall through to #R39492 for the reversed pass.
@label=hit_check
*39492 LD A,(IX+8)   ; Load attacker frame index from IX+8.
 39495 LD HL,45015   ; {Search hit section table #R45015 for the attacker frame
 39498 CALL 38325    ; via #R38325.}
 39501 RET NZ        ; Return if attacker frame not found - no active hit this
                     ; frame.
 39502 PUSH DE       ; {Read candidate defender frame ID from the current table
 39503 POP HL        ; pair.
@label=hit_pair_scan
*39504 LD A,(HL)     ; }
 39505 CP 255        ; {Compare against defender frame index IY+8.
 39507 RET Z         ; }
 39508 CP (IY+8)     ; Match - call #R39518 to validate range and apply the
                     ; hit.
 39511 CALL Z,39518  ; Advance to the next pair.
 39514 INC HL        ; {Loop until 0xFF sentinel - no more pairs for this
 39515 INC HL        ; attacker frame.
 39516 JR 39504      ; }

; Hit range validation and combat event dispatch.
;
; Used by the routine at #R39468.
;
; .
;
; Called by #R39468 when attacker and defender frame states match a hit table
; entry. Validates the hit by comparing #R46834 fighter distance against the
; four packed range values in byte 0 of the #R46308  indexed by hit type. If no
; range matches, the hit is silently ignored.
; .
; On a valid hit, byte 1 gives the defender reaction movement ID (255 = no
; change), applied via #R39194. Byte 2 high nibble gives the combat event type
; stored in #R46803. Byte 2 low nibble gives the knockback type passed
; .
; to #R39367 to decrement energy.
; .
; INPUT: HL = pointer into hit section pair (defender frame ID, hit type
; index). IX = attacker state block, IY defender state block.
; .
; OUTPUT: None. DESTROYS: AF, BC, DE, HL.
@label=collision_solver
c39518 PUSH HL       ; Preserve HL.
 39519 INC HL        ; Advance to hit type index byte.
 39520 LD A,(HL)     ; {Read hit type index.
 39521 LD E,A        ; }
 39522 LD D,0        ; Zero-extend index to 16 bits.
 39524 LD HL,46308   ; HL base of hit type parameter table #R46308.
 39527 ADD HL,DE     ; {Select the 3-byte entry for this hit type.
 39528 ADD HL,DE     ;
 39529 ADD HL,DE     ; }
; Range validation - byte 0 contains four packed 2-bit range fields.
 39530 LD A,(HL)     ; Read byte 0 - four packed range values.
 39531 AND 3         ; {Extract range field 0 and compare against fighter
 39533 LD C,A        ; distance #R46834.
 39534 LD A,(46834)  ; }
 39537 CP C          ; {Match - jump to valid-hit path at #R39580.
 39538 JR Z,39580    ; }
 39540 LD A,(HL)     ; {Extract range field 1 and compare against fighter
 39541 AND 12        ; distance.
 39543 RRCA          ;
 39544 RRCA          ;
 39545 LD C,A        ; }
 39546 LD A,(46834)  ; Match - jump to #R39580.
 39549 CP C          ; {Extract range field 2 and compare against fighter
 39550 JR Z,39580    ; distance.
 39552 LD A,(HL)     ;
 39553 AND 48        ; }
 39555 RRCA          ; {Match - jump to #R39580.
 39556 RRCA          ;
 39557 RRCA          ; }
 39558 RRCA          ; {Extract range field 3 and compare against fighter
 39559 LD C,A        ; distance.
 39560 LD A,(46834)  ;
 39563 CP C          ;
 39564 JR Z,39580    ; }
 39566 LD A,(HL)     ; {Match - jump to #R39580.
 39567 AND 192       ;
 39569 RLCA          ;
 39570 RLCA          ;
 39571 LD C,A        ; }
 39572 LD A,(46834)  ; {No range matched - hit misses silently.
 39575 CP C          ;
 39576 JR Z,39580    ; }
 39578 JR 39615      ; Jump to exit at #R39615.
; Valid hit - apply defender reaction movement (byte 1).
*39580 INC HL        ; Advance to reaction movement field.
 39581 LD A,(HL)     ; {Movement ID 255 means no reaction - skip.
 39582 CP 255        ; }
 39584 JR Z,39591    ; Jump to #R39591.
 39586 PUSH HL       ; {Apply defender reaction movement via #R39194.
 39587 CALL 39194    ;
 39590 POP HL        ; }
; Combat event dispatch - byte 2 high nibble.
*39591 INC HL        ; Advance to combat event / knockback byte.
 39592 LD A,(HL)     ; Read byte 2.
 39593 AND 240       ; Isolate event type (high nibble).
 39595 OR A          ; {Event type 0 - skip storage.
 39596 JR Z,39609    ; }
 39598 RRCA          ; {Shift event type to low nibble.
 39599 RRCA          ;
 39600 RRCA          ;
 39601 RRCA          ; }
 39602 LD (46803),A  ; Store event type in #R46803.
 39605 LD (46804),IX ; Store attacker state block pointer in #R46804.
; Knockback and energy decrement - byte 2 low nibble.
*39609 LD A,(HL)     ; {Isolate knockback type (low nibble).
 39610 AND 15        ; }
 39612 CALL NZ,39367 ; Non-zero knockback - decrement defender energy via
                     ; #R39367.
*39615 POP HL        ; Restore HL.
 39616 RET           ; Return.

; Main combat loop.
;
; Used by the routine at #R35240.
;
; .
;
; Executed once per frame during active combat. Handles input, animation,
; rendering and death exit for both fighters and the goblin.
; .
; Frame processing order:
; .
; 1. Compute horizontal fighter distance via #R39856, stored in #R46834.
; .
; 2. Dispatch input or AI for P2 then P1 via #R35713.
; .
; 3. Update animation, movement and X position for P2 then P1 via #R39827.
; .
; 4. Draw P1 and P2 sprites via #R37486; Z-order determined by movement
; properties bit 0.
; .
; 5. Draw the P2 overlay tile via #R38220.
; .
; 6. If the goblin (#R46443) is inactive, return immediately. Otherwise advance
; and draw it via #R37536 and #R37486, skipping the frame advance if the skip
; counter (#R47475) is non-zero.
; .
; 7. Death check: if P1 holds movement 8 or 27, set P2 to movement 19 (victory)
; with IY=P1 as the dying character. Otherwise set P1 to movement 19 with IY=P2
; as the dying character.
; .
; 8. Goblin sync and exit: when the goblin's X tile reaches 29, deactivate the
; goblin and select exit animation 29, 31, 32 or 33 based on mirror flag and
; movement ID.
; .
; Movement IDs: 8 = decapitation death, 27 = standard death, 19 = victory pose.
; .
; INPUT: None. OUTPUT: None. Framebuffer, character state blocks and #R46834
; updated in place.
; .
; DESTROYS: AF, BC, DE, HL, IY, IX.
; .
; Frame processing: compute fighter distance, dispatch input or AI for both
; characters, update animation and X position, draw sprites in Z-order, draw P2
; overlay tile, and advance and draw the goblin if active.
@label=combat_loop
c39617 CALL 39856    ; Compute fighter distance and store in #R46834.
 39620 LD IY,46434   ; {Point IY at P2 state block and dispatch input or AI for
 39624 CALL 35713    ; P2.}
 39627 CALL 39827    ; Update P2 frame, movement and X position.
 39630 LD IY,46425   ; {Point IY at P1 state block and dispatch input or AI for
 39634 CALL 35713    ; P1.}
 39637 CALL 39827    ; Update P1 frame, movement and X position.
 39640 LD A,(46431)  ; {Load P1 movement ID and read its properties byte via
 39643 CALL 39245    ; #R39245.}
 39646 BIT 0,A       ; Test draw-order flag (bit 0 of the properties byte).
 39648 LD IY,46425   ; {If bit clear, draw P1 then P2 (P2 on top). If bit set,
 39652 PUSH IY       ; draw P2 only here (P1 draws on top at #R39674).
 39654 CALL Z,37486  ;
 39657 LD IY,46434   ;
 39661 CALL NZ,37486 ;
 39664 CALL Z,37486  ; }
 39667 PUSH AF       ; Save draw-order flag.
 39668 CALL 38220    ; Draw P2 overlay tile.
 39671 POP AF        ; Restore draw-order flag.
 39672 POP IY        ; Restore P1 state block pointer.
 39674 CALL NZ,37486 ; Draw-order bit set: draw P1 sprite on top.
 39677 LD IY,46443   ; Point IY at the goblin state block.
 39681 LD A,(IY+0)   ; Load goblin active flag.
 39684 OR A          ; Test if zero.
 39685 RET Z         ; Return if goblin is inactive.
 39686 LD A,(47475)  ; Load frame skip counter.
 39689 OR A          ; Test if non-zero.
 39690 JP NZ,37486   ; Skip counter active: draw current goblin frame without
                     ; advancing animation.
 39693 LD A,(IY+3)   ; Load goblin X tile counter.
 39696 INC A         ; Increment X tile counter.
 39697 AND 31        ; Wrap to 0-31.
 39699 LD (IY+3),A   ; Write updated X tile counter back.
 39702 CALL 37536    ; Advance goblin animation frame.
 39705 CALL 37486    ; Draw goblin sprite.
; Death check: if P1 holds movement 8 or 27, assign victory (movement 19) to P2
; with P1 as the dying character; otherwise assign victory to P1 with P2 as the
; dying character.
 39708 LD IY,46425   ; Point IY at P1 state block for death check.
 39712 LD A,(IY+6)   ; Load P1 current movement ID.
 39715 CP 8          ; Is P1 in the decapitation death animation (movement 8)?
 39717 JR Z,39725    ; Yes: take the P1 dying path.
 39719 CP 27         ; Is P1 in the standard death animation (movement 27)?
 39721 JR Z,39725    ; Yes: take the P1 dying path.
 39723 JR 39740      ; P1 not dying: take the P2 dying path.
*39725 LD IY,46434   ; {P1 dying: point IY at P2 and load A=19 for victory.
 39729 LD A,19       ; }
 39731 CALL 36838    ; Apply movement 19 victory to P2 via #R36838.
 39734 LD IY,46425   ; Point IY back at P1 state block (dying character).
 39738 JR 39749      ; Jump to position check.
*39740 LD A,19       ; P2 dying: load A=19 for victory.
 39742 CALL 36838    ; Apply movement 19 victory to P1 via #R36838.
 39745 LD IY,46434   ; Point IY at P2 state block (dying character) for
                     ; position check.
; Goblin sync and exit: synchronise goblin step-over with the dying character
; body, trigger the flying head final phase, and when the goblin X tile reaches
; 29 deactivate it and select the exit animation based on mirror flag and
; movement ID.
*39749 LD B,(IY+3)   ; Load dying character's X tile position into B.
 39752 LD A,7        ; Load constant 7 for sync offset.
 39754 ADD A,B       ; Add X tile to compute goblin sync threshold (X+7).
 39755 LD B,A        ; Save sync threshold in B.
 39756 LD A,(46446)  ; Load goblin X tile position from #R46446.
 39759 CP B          ; Compare goblin X tile with sync threshold.
 39760 JR NZ,39765   ; No match: skip body nudge, jump to head sync check.
; Goblin step-over sync fires when #R46446 matches #R46815 AND 31 - 1 AND 31.
; Triggers once as the goblin steps over the landed head, launching it
; rightward.
 39762 INC (IY+3)    ; Sync match: nudge dying character X position by 1 for
                     ; body alignment.
*39765 LD B,A        ; Preserve goblin X tile position in B.
 39766 LD A,(46815)  ; Load low byte of head framebuffer address from #R46815.
 39769 AND 31        ; Extract screen column (0-31).
 39771 DEC A         ; Offset by 1 to align with goblin X tracking.
 39772 AND 31        ; Wrap to 0-31 column range.
 39774 CP B          ; Compare adjusted head column with goblin X tile.
 39775 CALL Z,37964  ; Match: trigger flying head final-phase update via
                     ; #R37964.
 39778 LD A,B        ; Reload goblin X tile position into A.
 39779 CP 29         ; Test if goblin X tile has reached 29 (body exits the
                     ; screen).
 39781 RET NZ        ; Not yet: return, fight sequence continues.
 39782 XOR A         ; {Goblin X reached 29: deactivate goblin by clearing
 39783 LD (46443),A  ; #R46443.}
 39786 LD A,(IY+2)   ; Load the dying character's mirror flag byte.
 39789 BIT 0,A       ; Test bit 0: is the character mirrored (facing left)?
 39791 JR Z,39810    ; Not mirrored: jump to #R39810.
; Exit animation selection when mirrored (facing left): movement 27 (death):
; exit 32 (drag left, mirrored); movement 8 (decapitation): exit 29 (drag left
; mirrored with decap).
 39793 LD A,(IY+6)   ; Mirrored: load dying character's movement ID.
 39796 CP 27         ; Is it movement 27 (standard death)?
 39798 JR Z,39805    ; Yes: jump to #R39805.
 39800 LD A,29       ; {No (decapitation): apply drag-left (mirrored) with
 39802 JP 36838      ; decap exit animation (29) via #R36838.}
*39805 LD A,32       ; {Standard death mirrored: apply drag-left (mirrored)
 39807 JP 36838      ; exit animation (32) via #R36838.}
; Exit animation selection when not mirrored (facing right): movement 27
; (death): exit 33 (drag right); movement 8 (decapitation): exit 31 (drag right
; with decap).
*39810 LD A,(IY+6)   ; Not mirrored: load dying character's movement ID.
 39813 CP 27         ; Is it movement 27 (standard death)?
 39815 JR Z,39822    ; Yes: jump to #R39822.
 39817 LD A,31       ; {No (decapitation): apply drag-right with decap exit
 39819 JP 36838      ; animation (31) via #R36838.}
*39822 LD A,33       ; {Standard death not mirrored: apply drag-right exit
 39824 JP 36838      ; animation (33) via #R36838.}

; Per-frame character update.
;
; Called from #R39617 for each fighter with IY pointing to their state block.
;
; .
;
; Returns immediately if IY+0=0 (inactive) or #R47475 non-zero (3-frame cycle
; skip, see #R40092).
; .
; INPUT: IY = character state block. OUTPUT: None. DESTROYS: AF, BC, HL.
@label=char_frame_update
c39827 LD A,(IY+0)   ; Load fighter block state.
 39830 OR A          ; {Return if zero (inactive).
 39831 RET Z         ; }
 39832 LD A,(47475)  ; Load #R47475 (hit-detection skip counter)
 39835 OR A          ; {Return if non-zero (frame skip).
 39836 RET NZ        ; }
 39837 CALL 39156    ; Process input/movement transition.
 39840 CALL 37536    ; Advance frame pointer, trigger frame events.
 39843 JP 39020      ; Tail-call to #R39020 and returns directly to #R39617.

; 112 ms delay loop.
;
; Used by the routines at #R35514, #R35937, #R36363, #R36673, #R36706, #R37843,
; #R38699, #R38796, #R38811 and #R38849.
;
; .
;
; Busy-wait timing routine used by menu and animation code. Runs a nested loop
; over B and C to burn a fixed number of T-states, roughly one frame at 50 Hz.
@label=waits_112ms
c39846 LD BC,24672   ; Load BC with the loop counters (B=96, C96).
*39849 DEC B         ; Inner loop: decrement B.
 39850 JR NZ,39849   ; If B is not zero, repeat the inner loop.
 39852 DEC C         ; Outer loop: decrement C.
 39853 JR NZ,39849   ; If C is not zero, restart the inner loop.
 39855 RET           ; Return after both counters have reached zero (after 9216
                     ; loops).

; Calculate horizontal distance between fighters.
;
; Used by the routines at #R39020 and #R39617.
;
; .
;
; Reads tile X position of both characters and computes the absolute
; difference. Result stored in #R46834, used by #R39518 to validate hit ranges.
; .
; Direction is determined by the mirror flag of P1 (#R46427 bit 0).
@label=calc_distance
c39856 LD A,(46427)  ; {Load #R46427 (P1 flags); test bit 0 (mirror flag).
 39859 BIT 0,A       ;
 39861 JR NZ,39873   ; }
 39863 LD A,(46428)  ; {Not mirrored: load P1 X (#R46428) into B, load P2 X
 39866 LD B,A        ; (#R46437), subtract B.
 39867 LD A,(46437)  ;
 39870 SUB B         ;
 39871 JR 39881      ; }
*39873 LD A,(46437)  ; {Mirrored: load P2 X (#R46437) into B, load P1 X
 39876 LD B,A        ; (#R46428), subtract B.
 39877 LD A,(46428)  ;
 39880 SUB B         ; }
*39881 LD (46834),A  ; Store result (absolute X delta) in #R46834.
 39884 RET           ; Return.

; Beeper sound engine.
;
; Used by the routine at #R39926.
;
; .
;
; Plays a sequence of square-wave tones from a 0-terminated period table
; pointed by IX. For each non-zero period byte, emits one complete HIGH/LOW
; cycle via #R39897, then advances to the next byte.
; .
; Called by all combat sound dispatchers: #R39926 (tackle), #R39932 (kick),
; #R39938 (slash), #R39944 (head cut), #R39950 (guard 1), #R39956 (guard 2),
; #R39962 (round end).
; .
; INPUT: IX = base address of sound data table (period bytes, 0-terminated).
; OUTPUT: None. DESTROYS: AF, BC, IX.
@label=beeper_engine
c39885 LD A,(IX+0)   ; {Load next period byte from IX. Return if zero (end of
 39888 OR A          ; sequence).
 39889 RET Z         ; }
 39890 CALL 39897    ; Emit one square-wave cycle with this period via #R39897.
 39893 INC IX        ; {Advance IX to next period byte and repeat.
 39895 JR 39885      ; }

; Emits one square-wave pulse.
;
; Used by the routine at #R39885.
;
; .
;
; Plays one complete HIGH-LOW cycle for the given period value. Called by
; #R39885 once per non-zero period byte in the sound data table.
; .
; INPUT: A = period value (higher = lower pitch). OUTPUT: None. DESTROYS: AF,
; BC.
@label=beeper_emit
c39897 LD B,A        ; B = period value.
 39898 PUSH BC       ; Preserve BC across HIGH phase.
 39899 CALL 39906    ; HIGH phase: B-iteration delay loop then speaker HIGH via
                     ; #R39906.
 39902 POP BC        ; Restore BC.
 39903 JP 39916      ; LOW phase: B-iteration delay loop then speaker LOW via
                     ; #R39916.

; Beeper HIGH phase.
;
; Used by the routine at #R39897.
;
; .
;
; B-iteration delay then OUT (254),16 to drive speaker HIGH.
; .
; INPUT  B = number of delay iterations. DESTROYS AF, B.
@label=beep_high_phase
c39906 NOP           ; {NOP x3 + DJNZ timing loop, B iterations.
 39907 NOP           ;
 39908 NOP           ;
 39909 DJNZ 39906    ; }
 39911 LD A,16       ; {A = 16; drive speaker HIGH via OUT 254,A.
 39913 OUT (254),A   ; }
 39915 RET           ; Return.

; Beeper LOW phase.
;
; Used by the routine at #R39897.
;
; .
;
; B-iteration delay then OUT (254),0 to drive speaker LOW.
; .
; INPUT:  B = number of delay iterations. DESTROYS: AF, B.
@label=beep_low_phase
c39916 NOP           ; {NOP x3 + DJNZ timing loop, B iterations.
 39917 NOP           ;
 39918 NOP           ;
 39919 DJNZ 39916    ; }
 39921 LD A,0        ; {A = 0; drive speaker LOW via OUT 254,A.
 39923 OUT (254),A   ; }
 39925 RET           ; Return.

; Combat Sound Effects List.
;
; Used by the routines at #R35531, #R37536 and #R37964.
;
; .
;
; Loads IX with the sound data pointer for this event and plays it via #R39885.
; Then returns to the caller routine.
; .
; INPUT: A = sound index. OUTPUT: None. DESTROYS: AF, BC, DE, HL, IX.
; .
; Sound: kick
@label=sound_tackle
c39926 LD IX,48180   ; {Points to sound data #R48180 and plays it.
 39930 JR 39885      ; }
; Sound: tackle
; .
; Called from #R35531.
@label=sound_kick
*39932 LD IX,48200   ; {Points to sound data #R48200 and plays it.
 39936 JR 39885      ; }
; Sound: slash
; .
; Called from #R35531.
@label=sound_slash
*39938 LD IX,48210   ; {Points to sound data #R48210 and plays it.
 39942 JR 39885      ; }
; Sound: Head Cut
; .
; Called from #R35514, #R35531 and #R35937.
@label=sound_head_cut
*39944 LD IX,48158   ; {Points to sound data #R48158 and plays it.
 39948 JR 39885      ; }
; Sound: guard 1
; .
; Called from #R35531.
@label=sound_guard_1
*39950 LD IX,48241   ; {Points to sound data #R48241 and plays it.
 39954 JR 39885      ; }
; Sound: guard 2
; .
; Called from #R35531.
@label=sound_guard_2
*39956 LD IX,48251   ; {Points to sound data #R48251 and plays it.
 39960 JR 39885      ; }
; Sound: round end.
; .
; Plays when the post-fight score sequence runs.
; .
; Called from #R37852 (post-fight handler, score + time HUD update). NOT part
; of the in-combat sounds, dispatch chain in #R35531.
@label=sound_round_end
*39962 LD IX,48261   ; {Points to sound data #R48261 plays it.
 39966 JR 39885      ; }

; Tackle cross-side animation controller.
;
; Used by the routine at #R35240.
;
; .
;
; Two-phase sequencer for roll/jump-over side-swap. Triggered by #R39020 when
; one fighter rolls (mv17 frame 38) while the other jumps over (frames 8-9).
; .
; Gated by #R47475 (3-frame cycle via #R40092) and #R47575 (phase selector).
; .
; Phase 1 (#R47575=1): apply mv34 (changeside) to both, advance to phase 2.
; .
; Phase 2 (#R47575=2): wait for mid-swap frame (P1 IY+8=16), apply mv0 + mirror
; flip + X correction (+-2 tiles).
; .
; Called pre-HALT at #R35325; reads #R47475 set by previous frame's #R40092
; (post-HALT).
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF, BC, DE, HL, IY.
@label=tackle_side_swap
c39968 LD A,(47475)  ; {Guard: return if #R47475 != 0 (skip frames 1-2) or
 39971 OR A          ; #R47575 == 0 (not active).
 39972 RET NZ        ;
 39973 LD A,(47575)  ;
 39976 OR A          ;
 39977 RET Z         ; }
 39978 CP 2          ; {Test phase selector #R47575: phase 2 jumps to #R40021.
 39980 JR Z,40021    ; }
; Phase 1: scan for roll-complete frame (mv17 frame 38).
 39982 LD A,(46433)  ; {Check P1 frame index #R46433 == 38; jump if match.
 39985 CP 38         ;
 39987 JR Z,39997    ; }
 39989 LD A,(46442)  ; {Check P2 frame index #R46442 == 38; jump if match.
 39992 CP 38         ; }
 39994 JR Z,39997    ;
 39996 RET           ;
*39997 LD A,34       ; {Apply mv34 (changeside) to P1 then P2 via #R36838; set
 39999 LD IY,46425   ; #R47575=2 (phase 2).
 40003 CALL 36838    ;
 40006 LD A,34       ;
 40008 LD IY,46434   ;
 40012 CALL 36838    ;
 40015 LD A,2        ;
 40017 LD (47575),A  ;
 40020 RET           ; }
; Phase 2: wait for mid-swap sync.
*40021 LD A,(46433)  ; {Guard: return unless P1 frame index #R46433 == 16
 40024 CP 16         ; (mid-changeside).
 40026 RET NZ        ; }
 40027 XOR A         ; {Clear #R47575; IY = P1 block #R46425.
 40028 LD (47575),A  ;
 40031 LD IY,46425   ;
 40035 BIT 0,A       ; }
 40037 CALL 40077    ; Call #R40077 (mv0 + mirror flip); Z/NZ selects X
                     ; correction.
 40040 CALL Z,40066  ; Z set (now facing right): IY+3 += 2.
 40043 CALL NZ,40055 ; NZ clear (now facing left): IY+3 -= 2.
 40046 LD IY,46434   ; IY = P2 block #R46434.
 40050 CALL 40077    ; Call #R40077 for P2.
 40053 JR Z,40066    ; Z set (P2 now right): IY+3 += 2.
*40055 PUSH AF       ; {NZ clear (P2 now left): IY+3 -= 2 (move character 2
 40056 LD A,(IY+3)   ; tiles left after swap).
 40059 SUB 2         ;
 40061 LD (IY+3),A   ;
 40064 POP AF        ;
 40065 RET           ; }
*40066 PUSH AF       ; {Z set (P2 now right): IY+3 += 2 (move character 2 tiles
 40067 LD A,(IY+3)   ; right after swap).
 40070 ADD A,2       ;
 40072 LD (IY+3),A   ;
 40075 POP AF        ;
 40076 RET           ; }

; Apply idle movement and toggle facing direction.
;
; Used by the routine at #R39968.
;
; .
;
; Helper called twice by #R39968 phase 2 after the side-swap animation
; completes, once for each fighter.
; .
; Applies movement 0 (idle/stop) to reset the animation state, then flips bit 0
; of the mirror flag to reverse the character's facing direction.
; .
; The caller uses the returned Z flag to select the correct X tile correction:
; Z (now facing right) adds 2; NZ (now facing left) subtracts 2.
; .
; INPUT: IY = character state block. OUTPUT: Z = set if now facing right, NZ if
; now facing left. DESTROYS: A.
@label=stop_mov_and_mirror
c40077 XOR A         ; Select movement 0 (idle).
 40078 CALL 36838    ; Apply idle movement to the character via #R36838.
 40081 LD A,(IY+2)   ; Load the mirror and control flags byte.
 40084 XOR 1         ; Toggle the facing direction bit.
 40086 LD (IY+2),A   ; Write the updated flags byte back.
 40089 BIT 0,A       ; Isolate the new facing bit to set Z or NZ.
 40091 RET           ; Return with Z reflecting the new facing direction.

; 3-frame cycle counter advance.
;
; Used by the routine at #R35240.
;
; .
;
; Advances #R47475 by 1 each call.
; .
; Active frame (counter=0) runs #R39968 (pre-HALT) and #R39468 (hit detection).
; .
; INPUT: None. OUTPUT: None. DESTROYS: AF.
@label=frame_counter_hit_inc
c40092 LD A,(47475)  ; Load current counter from #R47475.
 40095 INC A         ; Increment the counter.
 40096 LD (47475),A  ; Store updated counter back to #R47475.
 40099 CP 2          ; Counter reached 2 - reset it to 0.
 40101 RET NZ        ; Not yet - return with counter at 1.
 40102 XOR A         ; Reset counter to 0.
 40103 LD (47475),A  ; Store reset value back to #R47475.
 40106 RET           ; Return.

