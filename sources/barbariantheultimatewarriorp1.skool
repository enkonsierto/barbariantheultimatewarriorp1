; Game Start Routine
;
; Called by #R35244
;
; .
;
; This area will be deleted by #R38494.
@label=game_start
c48896 XOR A         ; A = 0
 48897 OUT (254),A   ; Border Black
 48899 SET 7,A       ; {Set 128 (character controlled by CPU) to the address
 48901 LD (46425),A  ; #R46425 and #R46434. (Player 1 and 2 respectively).
 48904 LD (46434),A  ; }
; Copies the UDG table.
@label=copy_font_table
 48907 LD HL,26112   ; {Copy the fonts at #R26112 to the UDG address #R23720.
 48910 LD DE,23720   ;
 48913 LD BC,344     ;
 48916 LDIR          ; }
; Deletes the hud (where the text "Palace Software" in the loading screen is
; written.
 48918 LD B,16       ; Blanks the 16-tile score and time HUD area.
 48920 LD HL,16552   ; Points HL to the first HUD tile at 16552.
*48923 PUSH HL       ; {Saves BC and HL.
 48924 PUSH BC       ; }
 48925 LD A,58       ; Loads ASCII 58 as the blank tile index.
 48927 CALL 35996    ; Draws one tile via #R35996.
 48930 POP BC        ; {Restores BC and HL.
 48931 POP HL        ; }
 48932 INC L         ; Advances HL to the next HUD tile.
 48933 DJNZ 48923    ; Repeats 16 times.
; Copies the 100 bytes of #R49046 to #R61568. This area will be deleted by
; #R38494.
; .
; NOTE: destination #R61568 initially contains Barbarian tile data (unused
; tiles 194-195 of the sprite tileset at #R49216).
 48935 LD HL,49046   ; {Copies #R49046 to #R61568.
 48938 LD DE,61568   ;
 48941 LD BC,100     ;
 48944 LDIR          ; }
; Builds the bit-reversal lookup table at #R23296 (256 entries). Each entry
; maps a byte value to its horizontally mirrored equivalent (bits reversed).
; Used by #R39258 to horizontally mirror sprite tile data before blitting,
; avoiding per-pixel bit manipulation at render time.
@label=reversal_table_generator
 48946 LD HL,23296   ; Points HL to the bit-reversal table #R23296.
 48949 XOR A         ; {Initialises A 0 and B 0 as byte counter; C holds the
*48950 LD B,A        ; value to reverse.
 48951 LD C,A        ; }
 48952 SRL C         ; Shifts the least significant bit of C into the carry
                     ; flag.
 48954 RLA           ; Rotates carry into A, building the reversed byte from
                     ; MSB to LSB.
 48955 SRL C         ;
 48957 RLA           ;
 48958 SRL C         ;
 48960 RLA           ;
 48961 SRL C         ;
 48963 RLA           ;
 48964 SRL C         ;
 48966 RLA           ;
 48967 SRL C         ;
 48969 RLA           ;
 48970 SRL C         ;
 48972 RLA           ;
 48973 SRL C         ;
 48975 RLA           ;
 48976 LD (HL),A     ; Writes the completed reversed byte to the table.
 48977 LD A,B        ; {Increments the counter. B and C both hold the new value
 48978 INC A         ; for the next iteration.}
 48979 JR Z,48984    ; Counter reached 255; 256 entries written, jump to
                     ; #R48984.
 48981 LD L,A        ; Advances HL to the next table entry.
 48982 JR 48950      ; Loops back for the next byte.
; Builds the left-column scanline address table at #R23552 (84 entries,
; 23552-23718). Uses SP as a fast write pointer: sets SP to 23720 and PUSHes
; each scanline address while walking upward from the bottom-left of the game
; window. On return, SP is restored from the saved value.
*48984 LD (46452),SP ; Saves the current stack pointer.
 48988 LD SP,23720   ; Redirects SP to #R23720 top of the table area.
 48991 LD HL,22434   ; Points HL to the bottom-left of the game window, first
                     ; scanline of column 0.
 48994 LD B,84       ; B 84, one iteration per scanline entry.
*48996 PUSH HL       ; Pushes the scanline address to the table via SP.
 48997 DEC H         ; Steps HL up one scanline via #R36879.
 48998 LD A,H        ; Tests if H has crossed a tile boundary lower 3 bits of H
                     ; equal to 7.
 48999 CPL           ; {Inverts A and checks the 3 least significant bits for
 49000 AND 7         ; 0.}
 49002 JR NZ,49014   ; Tile boundary not crossed, address is ready, jump to
                     ; loop end.
 49004 LD A,L        ; Tile boundary crossed, calculate the row above.
 49005 SUB 32        ; {Decrements L by 32 to step up one tile row.
 49007 LD L,A        ; }
 49008 JR C,49014    ; If carry set, the screen third changed, address is
                     ; correct.
 49010 LD A,H        ; {If no carry, corrects H by adding 8.
 49011 ADD A,8       ;
 49013 LD H,A        ; }
*49014 DJNZ 48996    ; Decrements B and loops for the next entry.
 49016 LD SP,(46452) ; Restores the original stack pointer.
; Sets the interrupt table and mode. The routine will overwrite itself from
; #R48896 to 49152.
 49020 LD HL,48896   ; Sets #R48896 to HL. The starting of the Interrtupt
                     ; Vector Table.
 49023 LD C,240      ; Save 240 (F0) to compound the jump address (F0F0).
 49025 LD A,191      ; {Copy 191 (BF) to I. The vector table will go from
 49027 LD I,A        ; 0xBF00(48896) to 0xBFFF(49151).}
 49029 IM 2          ; Sets Interrupt mode 2.
 49031 LD A,195      ; {Writes "JP/C3(191) #R38500" at the address 61680
 49033 LD (61680),A  ; (F0F0).
 49036 LD DE,38500   ;
 49039 LD (61681),DE ; }
 49043 JP 38494      ; Jumps to #R38494. We move, so the running code won't be
                     ; affected by the overwritting.

; Per-frame horizontal X-delta table
;
; Indexed by IY+8 (current frame index) from #R38960. Each byte is a signed
; 8-bit displacement added to IY+3 (X tile). Positive values move right,
; negative values move left. The mirror flag (IY+2 bit 0) negates the value so
; mirrored characters always move in the correct direction.
@label=x_delta_table
b49046 DEFB 0,1,1,1,0,0,0,0             ; frames 0-7: walk forward, delta +1 on
                                        ; frames 1-3
 49054 DEFB 0,0,0,0,0,0,2,1             ; frames 8-15: enter arena, delta +2 on
                                        ; frame 14, +1 on frame 15
 49062 DEFB 1,0,0,0,0,0,0,0             ; frames 16-23: enter arena cont.,
                                        ; delta +1 on frame 16
 49070 DEFB 0,1,0,0,0,254,254,0         ; frames 24-31: frame 25 +1, frames
                                        ; 29-30 -2 (knockback/rollback)
 49078 DEFB 0,254,0,1,4,2,4,2           ; frames 32-39: frame 33 -2 (backward
                                        ; step in mv27 death), frame 35 +1,
                                        ; frames 36-39 roll displacement
 49086 DEFB 1,255,252,254,252,254,255,0 ; frames 40-47: frame 40 +1, frames
                                        ; 41-46 roll backward
                                        ; (-1,-4,-2,-4,-2,-1)
 49094 DEFB 0,0,0,1,255,255,255,255     ; frames 48-55: frame 51 +1, frames
                                        ; 52-55 -1 (fall/death drift)
 49102 DEFB 0,0,0,0,0,0,0,0             ; frames 56-63: no movement
 49110 DEFB 0,0,0,0,0,0,0,0             ; frames 64-71: no movement
 49118 DEFB 0,0,0,255,255,254,0,0       ; frames 72-79: frames 75-77 -1/-1/-2
                                        ; (drag anim)
 49126 DEFB 255,0,0,0,0,0,0,255         ; frames 80-87: frame 80 -1, frame 87
                                        ; -1
 49134 DEFB 0,0,0,0,2,254,1,0           ; frames 88-95: frame 92 +2, frame 93
                                        ; -2, frame 94 +1
 49142 DEFB 0,255,255,255,0,0,0,0       ; frames 96-103: frames 97-99 -1
 49150 DEFB 0,0                         ; frames 104-105: no movement

; Barbarian sprite tileset.
;
; .
;
; .
;
; Full tilesheet:
; .
; #IMGW(50)(barbarian_sheet.png)
; .
; 256 tiles, 64 bytes each. 24(8*3)h x 21vert px
; .
; RUNTIME OVERLAP: byte at #N49152 is overwritten to #N$F0 by #R38494 as the
; 257th byte of the IM 2 interrupt vector table (base #N$BF00, I=#N$BF).
; .
; This makes the ISR handler address = #N$F0F0, written by #R49031.
; .
; Tiles 195-196 (#N$F0C0-#N$F0FF): overwritten at runtime starting a #N$F0F0 by
; #R49031, which relocates the ISR code from #R38500 here. The ISR (~46 bytes)
; spans from tile 195 into tile 196.
; .
; Tile 253: transparent sentinel (all-zero pixel data), used as blank slot by
; #R37449.
; .
; Tile 254: (#N$FF80): unreferenced tile slot. Pixel data never read; no code
; reference to index 254 identified.
; .
; Tile 255: (#N$FFC0): skip-draw sentinel. Index 255 is caught by #R37449
; before any pixel data is read; bytes #N$FFC0-#N$FFFF are never accessed as
; tile graphics. Also Stack pointer is set in #N65535.
@label=barb_sprite_tileset
b49152 DEFB 0                               ; Tile 0 (blank transparent tile,
                                            ; all zeros)
 49153 DEFB 0,0,0,0,0,0,0,0                 ; {#IMG(tiles/barb_000.png)
 49161 DEFB 0,0,0,0,0,0,0,0                 ;
