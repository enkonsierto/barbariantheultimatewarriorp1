 40147 DEFB 0,0,0,0,0,0,0,0
 40155 DEFB 0,0,0,0,0,0,0,0
 40163 DEFB 0,0,0,0,0,0,0,0
 40171 DEFB 0,0,0,0,0,0,0,0
 40179 DEFB 0,0,0,0,0,0,0,0
 40187 DEFB 0,0,0,0,0

