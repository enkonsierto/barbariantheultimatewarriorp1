; Music player.
;
; Used by the routine at #R36130.
;
; .
;
; Title screen music player. Resets the melody and bass to the start, plays the
; music in loop and returns when a key is pressed.
@label=play_music
c33840 LD HL,34105   ; {Saves #R34105 (the main melody address) in position
 33843 LD (33867),HL ; #R33867.}
 33846 LD HL,34671   ; {Saves #R34671 (the bass melody address) in position
 33849 LD (33871),HL ; #R33871.}
 33852 DI            ; Disable interrupts.
*33853 CALL 33911    ; Plays Music.
 33856 CALL 654      ; Keyboard ROM Routine. (Returns the key pressed in
                     ; register E).
 33859 INC E         ; {If E = 255 no key was pressed and returns.
 33860 JR Z,33853    ; }
 33862 EI            ; Enable interrupts.
 33863 RET           ; Returns.

; Music engine state buffers.
;
; 12-byte working area for the 2-channel beeper music engine. Used by #R33911.
;
; .
;
; The loop-pointer slots at #R33869 and #R33873 are unused pointers where
; #R33840 would store a fixed restart address. Superseded by #R33903, which
; reads the restart address inline from the music data stream.
@label=melody_note
g33864 DEFB 0        ; Current melody note index; used by #R33889 to look up
                     ; period in #R34052
@label=bass_note
 33865 DEFB 0        ; Current bass note index; used by #R33889
@label=beeper_state
 33866 DEFB 0        ; Speaker output bit state, 0 or 16; toggled each
                     ; half-cycle by #R33911
@label=melody_ptr
 33867 DEFW 60000    ; Current read position in melody sequence #R34105;
                     ; updated by #R33876
@label=melody_loop_ptr
 33869 DEFW 34106    ; - UNUSED. Melody loop-back address; never written in the
                     ; final build
@label=bass_ptr
 33871 DEFW 61000    ; Current read position in bass sequence #R34671; updated
                     ; by #R33876
@label=bass_loop_ptr
 33873 DEFW 34672    ; - UNUSED. Bass loop-back address; never written in the
                     ; final build
@label=note_duration
 33875 DEFB 240      ; Duration counter for the current note; loaded each note
                     ; by #R33911

; Selects the next pointer and the note.
;
; Reads the next note from a music sequence and updates the pointer.
; .
; If it finds the end marker (64), it restarts the sequence in a loop.
;
; .
;
; INPUT: HL = address of sequence pointer (#R33867 or #R33871).
; .
; OUTPUT: HL = next pointer, A = note value.
; .
; DESTROYS: DE.
@label=select_music_pointer
c33876 LD E,(HL)     ; {Loads the current note address into DE (low and high
 33877 INC HL        ; byte).
 33878 LD D,(HL)     ; }
 33879 INC DE        ; DE now points to the next note.
; This entry point is used by the routine at #R33903.
*33880 LD A,(DE)     ; Reads the note value into A.
 33881 CP 64         ; Compares with 64 (end of sequence marker).
 33883 JR Z,33903    ; If 64, jumps to #R33903 to restart.
 33885 LD (HL),D     ; {Saves the new pointer (updates position in sequence).
 33886 DEC HL        ;
 33887 LD (HL),E     ; }
 33888 RET           ; Returns with note in A.

; Converts note value to period.
;
; Converts a note value to a time period for the beeper.
; .
; Adds 12 to the value (transposition) and uses #R34052 as period table.
;
; .
;
; INPUT: HL = address of note buffer (#R33864 or #R33865).
; .
; OUTPUT: H = note period, L = 1, DE = note value + 12 (Octave).
; .
; DESTROYS: A.
@label=note_to_period_converter
c33889 LD A,(HL)     ; Reads note value from buffer.
 33890 ADD A,12      ; Adds 12 (octave/transposition adjustment).
 33892 LD E,A        ; E = adjusted note value.
 33893 LD D,0        ; D = 0.
 33895 LD HL,34052   ; HL = base address of period table #R34052.
 33898 ADD HL,DE     ; HL = table + note index.
 33899 LD H,(HL)     ; H = period from table.
 33900 LD L,1        ; L = initial half-cycle counter value.
 33902 RET           ; Returns with period in HL.

; Restarts sequence at loop point.
;
; Processes the end of sequence marker (64).
; .
; Reads the restart address and updates the pointer to loop.
@label=restart_music
c33903 INC HL        ; Advances to low byte of loop address.
 33904 LD E,(HL)     ; Reads low byte of restart address.
 33905 INC HL        ; Advances to high byte.
 33906 LD D,(HL)     ; Reads high byte of restart address.
 33907 DEC HL        ; {Goes back two bytes (returns to start of pointer).
 33908 DEC HL        ; }
 33909 JR 33880      ; Jumps to #R33880 to read note from new position.

; Plays music (Beeper 2-channel engine).
;
; 2-channel music engine for the beeper speaker.
;
; .
;
; #HTML(<audio src="../audio/music.ogg" controls>Your browser does not support
; the <code>audio</code> element.</audio>)
; .
; Plays melody (#R34105) and bass (#R34671) simultaneously.
; .
; Uses port 254 (bit 4) to generate square waves.
; .
; Technique: Channel mixing with independent period counters.
; .
; Timing: Uses NOPs and alternate registers for precise timing.
; .
; DESTROYS: AF, BC, DE, HL, IX, IY, AF', BC', DE', HL'.
@label=music_engine
c33911 LD HL,33867   ; Loads melody pointer address #R33867.
 33914 CALL 33876    ; Gets next melody note (call to #R33876).
 33917 LD (33864),A  ; Saves note in melody buffer #R33864.
 33920 LD HL,33871   ; Loads bass pointer address #R33871.
 33923 CALL 33876    ; Gets next bass note (call to #R33876).
 33926 LD (33865),A  ; Saves note in bass buffer #R33865.
 33929 LD HL,33864   ; HL = melody buffer address #R33864.
 33932 CALL 33889    ; Converts bass melody to period (call to #R33889).
 33935 RL E          ; Rotates E left to extract bit 7 into Carry flag.
 33937 JP C,34106    ; Dead branch: if note+12 >= 128 would jump into melody
                     ; data at #R34106. The note range 0-40 makes this
                     ; unreachable; the branch is residual defensive code.
 33940 PUSH HL       ; Preserves melody period on stack.
 33941 LD HL,33865   ; HL = bass buffer address #R33865.
 33944 CALL 33889    ; Converts bass note to period (call to #R33889).
 33947 POP DE        ; Recovers melody period into DE (D=melody).
 33948 LD A,H        ; {Checks if H (bass period) differs from 1.
 33949 DEC A         ; }
 33950 JR NZ,33956   ; If H-1 != 0, jumps to #R33956 (notes to play).
 33952 LD A,D        ; {Checks if D (melody period) differs from 1.
 33953 DEC A         ; }
 33954 JR Z,34022    ; If D-1 = 0, jumps to #R34022 (silence, both channels
                     ; muted).
*33956 LD A,(33875)  ; Loads duration/tempo from #R33875.
 33959 LD C,A        ; C = duration counter.
 33960 LD B,0        ; B = 0 (inner loop).
 33962 LD A,(33866)  ; Loads initial beeper state from #R33866.
 33965 EX AF,AF'     ; Saves to alternate registers (AF').
 33966 LD A,(33866)  ; Reloads (preparation).
 33969 LD IXh,D      ; IXh = melody period (D).
 33971 LD D,16       ; D = 16 (constant for XOR with beeper - toggle bit 4).
; This entry point is used by the routine at #R34004.
*33973 NOP           ; {NOPs for exact timing adjustment.
 33974 NOP           ; }
; This entry point is used by the routine at #R34004.
*33975 EX AF,AF'     ; Swaps with alternate registers (AF').
 33976 DEC E         ; Decrements melody period counter (E).
 33977 OUT (254),A   ; Sends current state to port 254 (beeper).
 33979 JR NZ,34004   ; If E != 0, jumps to #R34004 (continues same half-cycle).
 33981 LD E,IXh      ; Reloads E with melody period (IXh).
 33983 XOR D         ; Inverts beeper bit (XOR 16).
 33984 EX AF,AF'     ; Returns to alternate registers.
 33985 DEC L         ; Decrements bass period counter (L).
 33986 JP NZ,34011   ; If L != 0, jumps to #R34011 (continues same bass
                     ; half-cycle).
; This entry point is used by the routine at #R34004.
*33989 OUT (254),A   ; Sends bass state to beeper (port 254).
 33991 LD L,H        ; Reloads L with bass period (H).
 33992 XOR D         ; Inverts beeper bit (XOR 16).
 33993 DJNZ 33973    ; Decrements B and repeats inner loop (256 times).
 33995 INC C         ; Increments duration counter.
 33996 JP NZ,33975   ; If C != 0, continues playing (jumps to #R33975).
 33999 RET           ; End of note, returns.

; ADAM text
;
; ASCII bytes 97,100,97,109 = "ADAM". Coder Easter egg.
; .
; Unreachable code between the music engine routines.
u34000 DEFB 97,100,97,109

; Melody counter still running; check bass counter independently.
;
; Reached when the melody counter (E) has not yet expired. Checks the bass
; counter (L) independently so both channels can change phase at different
; times within the same loop iteration.
@label=melody_running
c34004 JR Z,34004    ; Dead code, Z is always clear on entry; never branches.
 34006 EX AF,AF'     ; Swaps with alternate registers.
 34007 DEC L         ; Decrements bass counter.
 34008 JP Z,33989    ; If L = 0, jumps to #R33989 (end of bass half-cycle).
; This entry point is used by the routine at #R33911.
*34011 OUT (254),A   ; Sends state to beeper.
 34013 NOP           ; {NOPs for timing adjustment.
 34014 NOP           ; }
 34015 DJNZ 33973    ; Decrements B and returns to main loop #R33973.
 34017 INC C         ; Increments duration counter.
 34018 JP NZ,33975   ; If C != 0, continues (jumps to #R33975).
 34021 RET           ; Returns.

; Silence routine.
;
; Generates silence when both channels have period 0.
; .
; Generates silence for the same duration as a note. Burns CPU cycles without
; toggling the beeper (port 254). CPL converts the duration so the loop count
; matches the timing of the main music engine.
@label=silence_routine
c34022 LD A,(33875)  ; Load duration and invert it (CPL) to compute the outer
                     ; loop count.
 34025 CPL           ;
 34026 LD C,A        ; C = outer loop counter (inverted duration).
 34027 PUSH BC       ; {Preserve BC and AF across the delay loops.
 34028 PUSH AF       ; }
 34029 LD B,0        ; B = 0: inner loop runs 256 iterations.
*34031 PUSH HL       ; {Save HL; load address 0 (ROM) as timing operand.
 34032 LD HL,0       ; }
 34035 SRA (HL)      ; Burn cycles: SRA on ROM address (write ignored, timing
                     ; only).
 34037 SRA (HL)      ; Burn cycles: SRA on ROM address (write ignored, timing
                     ; only).
 34039 SRA (HL)      ; Burn cycles: SRA on ROM address (write ignored, timing
                     ; only).
 34041 NOP           ; NOP: fine-tune T-state count to match music engine loop.
 34042 POP HL        ; Restore HL.
 34043 DJNZ 34031    ; Inner loop: 256 iterations.
 34045 DEC C         ; Decrement outer counter.
 34046 JP NZ,34031   ; Repeat until duration elapsed.
 34049 POP AF        ; Recovers AF.
 34050 POP BC        ; Recovers BC.
 34051 RET           ; Returns.

; Complete note period table (53 notes, 4+ octaves).
;
; Lookup table of 53 beeper periods covering the chromatic scale across 4+
; octaves.
;
; .
;
; Entries run from low notes (high period values) to high notes (low period
; values).
; .
; Used by #R33889, which adds 12 to the note index before lookup (transposition
; offset).
; .
; Adding 12 to the index shifts the pitch up one octave (12 semitones).
; .
; Approximate frequency: 437500 / (period * duration).
@label=note_table
b34052 DEFB 255,240,227,215,203,192,180,171 ; {Octave 1 (LOW): 255(C),240(C#)
 34060 DEFB 161,151,144,136,128             ; ,227(D),215(D#),203(E) ,192(F)
                                            ; ,180(F# ),171(G) ,161(G#) ,151(A)
                                            ; ,144(A#) ,136(B) ,128(C)}
 34065 DEFB 121,114,108,102,96,91,86,81     ; {Octave 2:
 34073 DEFB 76,72,68,64,61                  ; 121,114,108,102,96,91,86,81,76,72,68,64,61
                                            ; }
 34078 DEFB 57,54,51,48,45,43,40,38         ; {Octave 3:
 34086 DEFB 36,34,32,30,28                  ; 57,54,51,48,45,43,40,38,36,34,32,30,29
                                            ; }
 34091 DEFB 27,25,24,23,21,20,19,18         ; {Octave 4:
 34099 DEFB 17,16,15,14,13                  ; 28,27,25,24,23,21,20,19,18,17,16,15,14
                                            ; }
 34104 DEFB 12                              ; Octave 5 (HIGH): 13,12

; Melody music data.
;
; Main melody sequence for channel 1.
;
; .
;
; #HTML(<audio src="../audio/melody.ogg" controls>Your browser does not support
; the <code>audio</code> element.</audio>)
; .
; Note sequence: a note value followed by 41 plays it short (one tick).
; Repeated note values without 41 extend its duration (one tick per
; repetition). Value 41 acts as a timing separator between notes.
; .
; values 0-40 = notes, 41 = control, 64 = end. (causes loop at #R33903).
; .
; Notes (index table #R34052 + 12).
; .
; Referenced by #R33867 (initial pointer).
; .
; 566 bytes of musical data that loop infinitely.
@label=melody_data
b34105 DEFB 1                               ; Melody data (includes notes,
                                            ; separators and controls).
; Entry point for loop restart during music playback. (Never used).
*34106 DEFB 17,41,24,41,24,41,22,22
 34114 DEFB 22,41,24,24,24,41,22,22
 34122 DEFB 22,41,24,41,27,41,26,41
 34130 DEFB 24,41,24,41,22,41,24,24
 34138 DEFB 24,41,22,41,20,41,19,41
 34146 DEFB 17,41,15,41,12,12,12,12
 34154 DEFB 12,12,12,12,12,12,12,12
 34162 DEFB 12,12,12,12,12,12,12,12
 34170 DEFB 12,12,12,12,12,12,12,12
 34178 DEFB 12,12,12,12,12,12,12,12
 34186 DEFB 12,12,12,12,12,12,12,12
