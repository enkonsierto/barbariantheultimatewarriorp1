; Hit type parameter table.
;
; Indexed by hit type index from #R45015. Each entry is 3 bytes: range byte,
; reaction movement ID, and event/knockback byte.
; .
; Byte 0: four 2-bit distance thresholds packed into one byte (bits 1-0 = field
; 0, bits 3-2 = field 1, bits 5-4 = field 2, bits 7-6 = field 3). #R39518
; extracts each field and compares it against the fighter tile distance in
; #R46834. Any match validates the hit; all four misses discard it silently.
; .
; Byte 1: movement ID applied to the defender via #R39194 on a valid hit. 255 =
; no reaction.
; .
; Byte 2 high nibble: combat event type written to #R46803 (0 = no event). Low
; nibble: knockback type passed to #R39367 (0 = no energy decrement).
;
; .
;
; Types 0-3: stagger/fall, kick/slash, with energy damage.
; .
; Types 4-5: mv8 decapitation, headcut event, no energy damage.
; .
; Type  6: no reaction, guard2 event, no energy damage (full block).
; .
; Types 7-12: fall, kick/tackle, with or without energy damage.
; .
; Types 13-16: no reaction or stagger, guard1/guard2/slash, with or without
; damage.
; .
; Types 17-18: fall, tackle event, NO energy damage (roll forward hits).
; .
; Types 19-24: fall, slash event, with energy damage.
; .
; Types 25-31: stagger, slash event, with energy damage (range variants).
; .
; Types 32-35: fall, slash event, with energy damage (overhead slash
; exclusive).
; .
; Types 36-38: stagger, slash event, with energy damage (range variants,
; top/headcut area).
; .
; Types 32-35 are used exclusively by the overhead slash attacker frame
; (R45740): the only move that produces mv25 fall with slash event instead of
; kick event.
@label=hit_type_table
b46308 DEFB 27,13,50   ; Type 0: dist 0-3, mv13(stagger), slash energy-dmg
 46311 DEFB 26,13,50   ; Type 1: dist 0-2, mv13(stagger), slash energy-dmg
 46314 DEFB 21,13,50   ; Type 2: dist 0-1, mv13(stagger), slash energy-dmg
 46317 DEFB 0,25,34    ; Type 3: dist 0, mv25(fall), kick energy-dmg
 46320 DEFB 26,8,64    ; Type 4: dist 0-2, mv8(decap), headcut no-dmg
 46323 DEFB 21,8,64    ; Type 5: dist 0-1, mv8(decap), headcut no-dmg
 46326 DEFB 27,255,96  ; Type 6: dist 0-3, none(255), guard2 no-dmg
 46329 DEFB 27,25,34   ; Type 7: dist 0-3, mv25(fall), kick energy-dmg
 46332 DEFB 26,25,34   ; Type 8: dist 0-2, mv25(fall), kick energy-dmg
 46335 DEFB 21,25,34   ; Type 9: dist 0-1, mv25(fall), kick energy-dmg
 46338 DEFB 0,25,18    ; Type 10: dist 0, mv25(fall), tackle energy-dmg
 46341 DEFB 191,255,50 ; Type 11: dist 2-3, none(255), slash energy-dmg
 46344 DEFB 21,25,18   ; Type 12: dist 0-1, mv25(fall), tackle energy-dmg
 46347 DEFB 191,255,80 ; Type 13: dist 2-3, none(255), guard1 no-dmg
 46350 DEFB 26,255,96  ; Type 14: dist 0-2, none(255), guard2 no-dmg
 46353 DEFB 111,13,50  ; Type 15: dist 1-3, mv13(stagger), slash energy-dmg
 46356 DEFB 111,255,80 ; Type 16: dist 1-3, none(255), guard1 no-dmg
 46359 DEFB 0,25,32    ; Type 17: dist 0, mv25(fall), tackle no-dmg
 46362 DEFB 21,25,32   ; Type 18: dist 0-1, mv25(fall), tackle no-dmg
 46365 DEFB 0,25,50    ; Type 19: dist 0, mv25(fall), slash energy-dmg
 46368 DEFB 26,25,50   ; Type 20: dist 0-2, mv25(fall), slash energy-dmg
 46371 DEFB 21,25,50   ; Type 21: dist 0-1, mv25(fall), slash energy-dmg
 46374 DEFB 0,25,50    ; Type 22: dist 0, mv25(fall), slash energy-dmg
 46377 DEFB 26,25,50   ; Type 23: dist 0-2, mv25(fall), slash energy-dmg
 46380 DEFB 21,25,50   ; Type 24: dist 0-1, mv25(fall), slash energy-dmg
 46383 DEFB 26,13,50   ; Type 25: dist 0-2, mv13(stagger), slash energy-dmg
 46386 DEFB 21,13,50   ; Type 26: dist 0-1, mv13(stagger), slash energy-dmg
 46389 DEFB 27,13,50   ; Type 27: dist 0-3, mv13(stagger), slash energy-dmg
 46392 DEFB 0,13,50    ; Type 28: dist 0, mv13(stagger), slash energy-dmg
 46395 DEFB 21,13,50   ; Type 29: dist 0-1, mv13(stagger), slash energy-dmg
 46398 DEFB 0,13,50    ; Type 30: dist 0, mv13(stagger), slash energy-dmg
 46401 DEFB 26,13,50   ; Type 31: dist 0-2, mv13(stagger), slash energy-dmg
 46404 DEFB 26,25,50   ; Type 32: dist 0-2, mv25(fall), slash energy-dmg
 46407 DEFB 21,25,50   ; Type 33: dist 0-1, mv25(fall), slash energy-dmg
 46410 DEFB 27,25,50   ; Type 34: dist 0-3, mv25(fall), slash energy-dmg
 46413 DEFB 0,25,50    ; Type 35: dist 0, mv25(fall), slash energy-dmg
 46416 DEFB 27,13,50   ; Type 36: dist 0-3, mv13(stagger), slash energy-dmg
 46419 DEFB 26,13,50   ; Type 37: dist 0-2, mv13(stagger), slash energy-dmg
 46422 DEFB 21,13,50   ; Type 38: dist 0-1, mv13(stagger), slash energy-dmg

; Player 1 state block.
;
; 9-byte structure used by all combat routines.
;
; .
;
; Written by #R36822 (init), #R36838 (movement change), #R39367 (energy),
; #R35713 (input).
; .
; IY+0 controller type: 1=P1 keyboard #R47433, 2=P2 keyboard #R47440 (Sinclair
; 2 defaults), 3=Sinclair2 fixed #R47445 (keys 6-0), 4=Sinclair1 fixed #R47450
; (keys 1-5), 5=Kempston port 31. Bit 7 set=CPU-controlled.
; .
; Character type is implicitly IYl (low byte of IY base address: 89=P1, 98=P2,
; 107=goblin).
@label=p1_controller_type
g46425 DEFB 1        ; IY+0: Controller type (0=inactive, 1-5=human, bit 7
                     ; set=CPU).
@label=p1_input_state
 46426 DEFB 0        ; IY+1: Input state bitmask (bits 0-4: Right, Left, Down,
                     ; Up, Fire).
@label=p1_mirror_flags
 46427 DEFB 0        ; IY+2: Mirror and priority flags (bit 0=facing left, bit
                     ; 7=draw priority).
@label=p1_x_pos
 46428 DEFB 4        ; IY+3: X tile position (0-29).
@label=p1_frame_ptr
 46429 DEFW 44501    ; IY+4+5: Frame data pointer.
@label=p1_movement_id
 46431 DEFB 1        ; IY+6: Current movement ID (1-37).
@label=p1_energy_byte
 46432 DEFB 6        ; IY+7: Energy nibbles (bits 0-3=current energy 0-13, bits
                     ; 4-7=display update flag).
@label=p1_frame_index
 46433 DEFB 0        ; IY+8: Current frame index byte (read from frame data
                     ; pointer).

; Player 2 state block.
;
; 9-byte structure used by all combat routines.
;
; .
;
; Written by #R36822 (init), #R36838 (movement change), #R39367 (energy),
; #R35713 (input).
; .
; IY+0 controller type: 1=P1 keyboard #R47433, 2=P2 keyboard #R47440 (Sinclair
; 2 defaults), 3=Sinclair2 fixed #R47445 (keys 6-0), 4=Sinclair1 fixed #R47450
; (keys 1-5), 5=Kempston port 31. Bit 7 set=CPU-controlled.
; .
; Character type is implicitly IYl (low byte of IY base address: 89=P1, 98=P2,
; 107=goblin).
@label=p2_controller_type
g46434 DEFB 2        ; IY+0: Controller type (0=inactive, 1-5=human, bit 7
                     ; set=CPU).
@label=p2_input_state
 46435 DEFB 0        ; IY+1: Input state bitmask (bits 0-4: Right, Left, Down,
                     ; Up, Fire).
@label=p2_mirror_flags
 46436 DEFB 1        ; IY+2: Mirror and priority flags (bit 0=facing left, bit
                     ; 7=draw priority).
@label=p2_x_pos
 46437 DEFB 17       ; IY+3: X tile position (0-29).
@label=p2_frame_ptr
 46438 DEFW 44501    ; IY+4+5: Frame data pointer.
@label=p2_movement_id
 46440 DEFB 1        ; IY+6: Current movement ID (1-37).
@label=p2_energy_byte
 46441 DEFB 6        ; IY+7: Energy nibbles (bits 0-3=current energy 0-13, bits
                     ; 4-7=display update flag).
@label=p2_frame_index
 46442 DEFB 0        ; IY+8: Current frame index byte (read from frame data
                     ; pointer).

; Goblin state block.
;
; .
;
; .
;
; IY points here in #R37701. #R36838 writes IY+2, IY+4, IY+5, IY+6, IY+8.
; .
; IY+0: 0=goblin inactive (cleared by #R39617 when X=29), 255=active (set by
; #R37701).
@label=goblin_state_block
g46443 DEFB 0        ; IY+0: Active flag (0=inactive, 255=active).
 46444 DEFB 0        ; IY+1: Input state byte. Unused for goblin.
@label=goblin_mirror_flags
 46445 DEFB 0        ; IY+2: Mirror and control flags (bit 0=facing direction,
                     ; bit 7=non-controllable).
@label=goblin_x_pos
 46446 DEFB 0        ; IY+3: X tile position. Also used as frame counter by
                     ; #R39617.
@label=goblin_frame_ptr
 46447 DEFW 44522    ; IY+4+5: Frame data pointer.
@label=goblin_movement_id
 46449 DEFB 1        ; IY+6: Current movement ID (30=goblin entrance).
@label=goblin_energy_byte
 46450 DEFB 0        ; IY+7: Energy byte. Unused for goblin.
@label=goblin_frame_index
 46451 DEFB 0        ; IY+8: Current frame index byte.

; Saved stack pointer.
;
; 2-byte LE copy of SP redirecting SP to the VRAM address table #R23552.
;
; .
;
; Restored at the end of #R38412 via LD SP,46452.
@label=saved_sp
g46452 DEFB 0,0      ; Saved SP. Written and restored exclusively by #R38412.

; Active Background index.
;
; 0=Background 1 (graphics #R26752, attrs #R46614), 1=Background 2 (graphics
; #R30112, attrs #R46467).
;
; .
;
; Reset to 0 by #R35381 at the start of each new round.
; .
; Toggled via XOR 1 by #R35458 when the round timer expires.
; .
; Read exclusively by #R35458 to select the active Background pointers.
@label=active_bg
g46454 DEFB 0        ; Active Background index. 0=Background 1, 1=Background 2.

; Background Bitmap RLE pointers table.
;
; .
;
; .
;
; Used by #R35458 to toggle stages and resolve the active graphics pointer
; #R46459, read indirectly by #R35381 on game reset and by #R38547 when
; blitting the active stage background.
@label=bg_bitmap_ptr
b46455 DEFW 26752    ; Background 1 Bitmap pointer to #R26752
 46457 DEFW 30112    ; Background 2 Bitmap pointer to #R30112
@label=active_bg_bitmap_ptr
 46459 DEFW 26752    ; Active background 1 Bitmap pointer to #R26752
@label=active_bg_attr_ptr
 46461 DEFW 46614    ; Active background 1 Attributes pointer to #R46614
@label=bg_attr_ptr
 46463 DEFW 46614    ; Background 1 Attributes pointer to #R46614
 46465 DEFW 46467    ; Background 2 Attributes pointer to #R46467

; Background Attributes.
;
; .
;
; .
;
; RLE compressed attributes using pairs of [count, attribute] values. (28x11
; chars).
; .
; Example: [1,82] means "1 tile with attribute 82".
; .
; Each row ends with 255 marker.
; .
; Format per row: [count, attr, count, attr, ..., 255]
; .
; Graphics bytes are in #R26752 for Stage 1 and #R30112 for Stage 2.
@label=bg_2_attr_data
